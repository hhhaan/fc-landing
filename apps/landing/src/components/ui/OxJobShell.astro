---
import "../../styles/global.css";
import Favicon from "./Favicon.astro";

interface Props {
  title: string;
  description: string;
  department: string;
  roleTitle: string;
  location: string;
  employmentType?: string;
  applySubject: string;
  applyNote: string;
}

const {
  title,
  description,
  department,
  roleTitle,
  location,
  employmentType = "Full-time",
  applySubject,
  applyNote,
} = Astro.props;

const year = new Date().getFullYear();
const mailto = `mailto:careers@firstcrackiscoming.com?subject=${applySubject}`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-jd noise-overlay">
      <div class="ox-grid-bg" aria-hidden="true"></div>

      <header class="ox-auth-header">
        <nav class="ox-auth-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>
          <div class="ox-auth-nav-end">
            <a href="/careers" class="ox-utility-link">← Back to jobs</a>
          </div>
        </nav>
      </header>

      <div class="ox-jd-main">
        <div class="ox-shell ox-jd-layout">
          <article class="ox-jd-content">
            <header class="ox-jd-head">
              <span class="ox-jd-dept">{department}</span>
              <h1 class="ox-jd-title">{roleTitle}</h1>
              <div class="ox-jd-meta">
                <span class="ox-jd-loc">{location}</span>
                <span>{employmentType}</span>
              </div>
              <button type="button" class="ox-btn ox-btn-solid ox-btn-sm" id="ox-jd-apply-scroll">
                Apply
              </button>
            </header>

            <div class="ox-jd-body">
              <slot />
            </div>
          </article>

          <aside class="ox-jd-sidebar">
            <div class="ox-jd-apply-card" id="apply-form">
              <h2>Apply for this job</h2>
              <p>{applyNote}</p>
              <a href={mailto} class="ox-btn ox-btn-solid ox-btn-block">Apply via email</a>
            </div>
          </aside>
        </div>
      </div>

      <footer class="ox-utility-footer">
        <div class="ox-shell ox-utility-footer-inner">
          <span>© {year} First Crack</span>
          <nav aria-label="Footer">
            <a href="/about">About</a>
            <a href="/careers">Careers</a>
            <a href="/privacy">Privacy</a>
            <a href="mailto:contact@firstcrackiscoming.com">Contact</a>
          </nav>
        </div>
      </footer>
    </main>

    <script>
      document.getElementById("ox-jd-apply-scroll")?.addEventListener("click", () => {
        document.getElementById("apply-form")?.scrollIntoView({ behavior: "smooth" });
      });
    </script>
  </body>
</html>

<style is:global>
  body.ox {
    --ox-bg: #fafaf9;
    --ox-fg: #080503;
    --ox-muted: #5e534a;
    --ox-muted-bg: #ecebe7;
    --ox-border: rgba(8, 5, 3, 0.06);
    --ox-border-strong: rgba(8, 5, 3, 0.12);
    --ox-sans: "Instrument Sans", system-ui, -apple-system, sans-serif;
    --ox-mono: "JetBrains Mono", ui-monospace, monospace;
    --ox-max: 1400px;
    --ox-pad: 24px;

    margin: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.ox *,
  body.ox *::before,
  body.ox *::after {
    box-sizing: border-box;
  }

  body.ox a {
    color: inherit;
    text-decoration: none;
  }

  body.ox button {
    font-family: inherit;
    cursor: pointer;
    background: none;
    border: none;
    color: inherit;
  }

  .ox-shell {
    max-width: var(--ox-max);
    margin-inline: auto;
    padding-inline: var(--ox-pad);
  }

  .ox-brand-name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ox-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 0;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .ox-btn-sm {
    height: 32px;
    padding: 0 20px;
    font-size: 13px;
  }

  .ox-btn-block {
    width: 100%;
    height: 48px;
    font-size: 15px;
  }

  body.ox a.ox-btn-solid,
  body.ox .ox-btn-solid {
    background: var(--ox-fg);
    color: #fff;
    border-color: var(--ox-fg);
  }

  body.ox a.ox-btn-solid:hover,
  body.ox .ox-btn-solid:hover {
    opacity: 0.9;
  }

  .noise-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ox-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    background-image:
      linear-gradient(var(--ox-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ox-border) 1px, transparent 1px);
    background-size: 12.5% 12.5%;
  }

  .ox-auth-header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--ox-border);
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(16px);
  }

  .ox-auth-nav {
    max-width: var(--ox-max);
    margin: 0 auto;
    padding: 0 var(--ox-pad);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .ox-auth-nav-end {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ox-utility-link {
    font-size: 14px;
    color: rgba(8, 5, 3, 0.7);
    transition: color 0.2s ease;
  }

  .ox-utility-link:hover {
    color: var(--ox-fg);
  }

  .ox-jd {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ox-jd-main {
    position: relative;
    z-index: 2;
    flex: 1;
    padding: 48px 0 80px;
  }

  .ox-jd-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 48px;
    align-items: start;
    max-width: 1100px;
  }

  .ox-jd-head {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-jd-dept {
    display: block;
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
    margin-bottom: 12px;
  }

  .ox-jd-title {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .ox-jd-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 20px;
    margin-bottom: 20px;
    font-size: 14px;
    color: var(--ox-muted);
  }

  .ox-jd-loc {
    color: var(--ox-fg);
    font-weight: 500;
  }

  .ox-jd-body section {
    margin-bottom: 36px;
  }

  .ox-jd-body h2 {
    margin: 0 0 14px;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ox-jd-body p {
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.75;
    color: var(--ox-muted);
  }

  .ox-jd-body ul {
    margin: 0 0 12px;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ox-jd-body li {
    position: relative;
    padding-left: 16px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-jd-body li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.45;
  }

  .ox-jd-body .ox-jd-eeo {
    padding-top: 24px;
    border-top: 1px solid var(--ox-border);
    margin-bottom: 0;
  }

  .ox-jd-body .ox-jd-eeo p {
    font-size: 13px;
    line-height: 1.65;
    color: rgba(94, 83, 74, 0.85);
  }

  .ox-jd-apply-card {
    position: sticky;
    top: 104px;
    padding: 28px;
    border: 1px solid var(--ox-border);
    background: #fff;
  }

  .ox-jd-apply-card h2 {
    margin: 0 0 10px;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ox-jd-apply-card p {
    margin: 0 0 20px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ox-muted);
  }

  .ox-utility-footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--ox-border);
    padding: 24px 0;
  }

  .ox-utility-footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 13px;
    color: var(--ox-muted);
  }

  .ox-utility-footer-inner nav {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .ox-utility-footer-inner a:hover {
    color: var(--ox-fg);
  }

  @media (max-width: 900px) {
    .ox-jd-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ox-jd-apply-card {
      position: static;
    }
  }

  @media (min-width: 1024px) {
    body.ox {
      --ox-pad: 48px;
    }
  }
</style>