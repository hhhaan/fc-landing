<script>
  const WF_CHROME: Record<number, { step: string; eyebrow: string; title: string }> = {
    0: { step: "Step I", eyebrow: "Machines", title: "Pair sensors and controllers" },
    1: { step: "Step II", eyebrow: "Active roast", title: "Ride the curve with live readings" },
    2: { step: "Step III", eyebrow: "History", title: "Archive sessions and promote winners" },
  };

  function initWorkflowPanel() {
    const panel = document.querySelector<HTMLElement>("[data-workflow-panel]");
    if (!panel || panel.dataset.ready === "true") return;
    panel.dataset.ready = "true";

    const views = panel.querySelectorAll<HTMLElement>("[data-step-view]");
    const steps = document.querySelectorAll<HTMLElement>(".ox-step[data-step]");
    const machineCards = panel.querySelectorAll<HTMLButtonElement>("[data-machine-index]");
    const machinePanels = panel.querySelectorAll<HTMLElement>("[data-machine-panel]");

    const chromeEyebrow = panel.querySelector<HTMLElement>("[data-wf-eyebrow]");
    const chromeTitle = panel.querySelector<HTMLElement>("[data-wf-title]");
    const chromeStep = panel.querySelector<HTMLElement>("[data-wf-step]");

    const readingBt = panel.querySelector<HTMLElement>("[data-reading-bt]");
    const readingEt = panel.querySelector<HTMLElement>("[data-reading-et]");
    const readingRor = panel.querySelector<HTMLElement>("[data-reading-ror]");
    const readingPhase = panel.querySelector<HTMLElement>("[data-reading-phase]");
    const readingTime = panel.querySelector<HTMLElement>("[data-reading-time]");

    function setMachine(index: number) {
      machineCards.forEach((card) => {
        card.classList.toggle("is-selected", Number(card.dataset.machineIndex) === index);
      });
      machinePanels.forEach((detail) => {
        detail.classList.toggle("is-active", Number(detail.dataset.machinePanel) === index);
      });
    }

    machineCards.forEach((card) => {
      card.addEventListener("click", () => {
        setMachine(Number(card.dataset.machineIndex ?? 0));
      });
    });

    panel.addEventListener("ox-roast-metrics", ((e: CustomEvent) => {
      const { bt, et, ror, phase, phaseColor, time } = e.detail;
      if (readingBt) readingBt.textContent = bt;
      if (readingEt) readingEt.textContent = et;
      if (readingRor) readingRor.textContent = ror;
      if (readingTime && time) readingTime.textContent = time;
      if (readingPhase) {
        readingPhase.textContent = phase;
        readingPhase.className = "fc-wf-side-phase";
        if (phaseColor) readingPhase.style.color = phaseColor;
      }
    }) as EventListener);

    function setStep(step: number) {
      const chrome = WF_CHROME[step] ?? WF_CHROME[0];
      if (chromeEyebrow) chromeEyebrow.textContent = chrome.eyebrow;
      if (chromeTitle) chromeTitle.textContent = chrome.title;
      if (chromeStep) chromeStep.textContent = chrome.step;

      views.forEach((view) => {
        const active = Number(view.dataset.stepView) === step;
        view.classList.toggle("is-active", active);
        view.hidden = !active;
        view.setAttribute("aria-hidden", String(!active));
      });

      if (step === 1) {
        requestAnimationFrame(() => {
          panel.querySelector<HTMLElement>(".ox-roast-chart")?.dispatchEvent(
            new CustomEvent("ox-roast-chart-pause", { detail: { paused: false } }),
          );
        });
      } else {
        panel.querySelector<HTMLElement>(".ox-roast-chart")?.dispatchEvent(
          new CustomEvent("ox-roast-chart-pause", { detail: { paused: true } }),
        );
      }
    }

    steps.forEach((btn) => {
      btn.addEventListener("click", () => {
        setStep(Number(btn.dataset.step ?? 0));
      });
    });

    setMachine(0);
    setStep(0);
  }

  initWorkflowPanel();
  document.addEventListener("astro:page-load", initWorkflowPanel);
</script>