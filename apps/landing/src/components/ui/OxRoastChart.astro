---
interface Props {
  theme?: "dark" | "light";
  animate?: boolean;
  loopEnd?: number;
  startTime?: number;
  windowSec?: number;
  embedded?: boolean;
}

const {
  theme = "dark",
  animate = true,
  loopEnd = 582,
  startTime = 400,
  windowSec = 300,
  embedded = false,
} = Astro.props;
---

<div
  class:list={["ox-roast-chart", embedded && "ox-roast-chart-embedded"]}
  data-theme={theme}
  data-animate={animate ? "true" : "false"}
  data-loop-end={loopEnd}
  data-start-time={startTime}
  data-window-sec={windowSec}
  data-embedded={embedded ? "true" : "false"}
  aria-hidden="true"
>
  {!embedded && (
  <div class="ox-roast-chart-head">
    <div class="ox-roast-chart-meta">
      <span class="ox-roast-chart-batch">Ethiopia Guji · Washed · #2847</span>
      <span class="ox-roast-chart-weight">12.4 kg</span>
    </div>
    <div class="ox-roast-chart-status">
      <span class="ox-roast-chart-live" data-live-dot></span>
      <span data-status-label>Live roast</span>
    </div>
  </div>
  )}

  <div class="ox-roast-chart-canvas-wrap">
    <canvas class="ox-roast-chart-canvas"></canvas>
  </div>

  {!embedded && (
  <div class="ox-roast-chart-legend">
    <span><i class="ox-roast-swatch ox-roast-swatch-bt"></i>BT</span>
    <span><i class="ox-roast-swatch ox-roast-swatch-et"></i>ET</span>
    <span><i class="ox-roast-swatch ox-roast-swatch-ref"></i>Target</span>
    <span><i class="ox-roast-swatch ox-roast-swatch-ror"></i>RoR</span>
  </div>
  )}

  <div class="ox-roast-chart-metrics" class:list={embedded && "ox-roast-chart-metrics-sr"}>
    <b data-metric-bt hidden>—</b>
    <b data-metric-et hidden>—</b>
    <b data-metric-ror hidden>—</b>
    <b data-metric-time hidden>00:00</b>
    <b data-metric-phase hidden>Development</b>
  </div>
</div>

<style>
  .ox-roast-chart {
    --rc-bg: rgba(0, 0, 0, 0.32);
    --rc-border: rgba(250, 250, 249, 0.1);
    --rc-text: #fafaf9;
    --rc-muted: rgba(250, 250, 249, 0.45);
    --rc-grid: rgba(250, 250, 249, 0.07);
    --rc-metric-bg: rgba(8, 5, 3, 0.45);
    border: 1px solid var(--rc-border);
    background: var(--rc-bg);
  }

  .ox-roast-chart[data-theme="light"] {
    --rc-bg: #fff;
    --rc-border: rgba(8, 5, 3, 0.08);
    --rc-text: #080503;
    --rc-muted: rgba(94, 83, 74, 0.85);
    --rc-grid: rgba(8, 5, 3, 0.06);
    --rc-metric-bg: #fafaf9;
  }

  .ox-roast-chart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--rc-border);
  }

  .ox-roast-chart-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .ox-roast-chart-batch {
    font-size: 12px;
    font-weight: 500;
    color: var(--rc-text);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ox-roast-chart-weight {
    font-family: var(--ox-mono);
    font-size: 10px;
    color: var(--rc-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ox-roast-chart-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ox-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--rc-muted);
    flex-shrink: 0;
  }

  .ox-roast-chart-live {
    width: 6px;
    height: 6px;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.55);
    animation: ox-roast-pulse 2s ease-out infinite;
  }

  @keyframes ox-roast-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.55);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
    }
  }

  .ox-roast-chart-canvas-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 220px;
  }

  .ox-roast-chart-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ox-roast-chart-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    padding: 10px 16px;
    border-top: 1px solid var(--rc-border);
    border-bottom: 1px solid var(--rc-border);
    font-family: var(--ox-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--rc-muted);
  }

  .ox-roast-chart-legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .ox-roast-swatch {
    display: inline-block;
    width: 14px;
    height: 2px;
  }

  .ox-roast-swatch-bt {
    background: #4be08c;
    height: 3px;
  }

  .ox-roast-chart[data-theme="light"] .ox-roast-swatch-bt {
    background: #22a85a;
  }

  .ox-roast-swatch-et {
    background: #beacf8;
  }

  .ox-roast-chart[data-theme="light"] .ox-roast-swatch-et {
    background: #4a85c5;
  }

  .ox-roast-swatch-ref {
    background: repeating-linear-gradient(
      90deg,
      rgba(75, 224, 140, 0.75) 0 4px,
      transparent 4px 7px
    );
    height: 2px;
  }

  .ox-roast-swatch-ror {
    background: #ffff54;
  }

  .ox-roast-chart-embedded {
    border: 0;
    background: transparent;
  }

  .ox-roast-chart-embedded .ox-roast-chart-canvas-wrap {
    min-height: 240px;
    aspect-ratio: auto;
    height: 280px;
  }

  .ox-roast-chart-embedded[data-theme="light"] {
    --rc-border: #e5e5e5;
  }

  .ox-roast-chart-metrics-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .ox-roast-chart-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--rc-border);
    border-top: 1px solid var(--rc-border);
  }

  .ox-roast-chart-metrics > div {
    background: var(--rc-metric-bg);
    padding: 12px 8px;
    text-align: center;
  }

  .ox-roast-chart-metrics label {
    display: block;
    font-family: var(--ox-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--rc-muted);
    margin-bottom: 4px;
  }

  .ox-roast-chart-metrics b {
    font-family: var(--ox-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--rc-text);
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .ox-roast-chart-live {
      animation: none;
    }
  }
</style>

<script>
  import {
    ROAST_EVENTS,
    ROAST_PHASES_DARK,
    ROAST_PHASES_LIGHT,
    ROAST_TOTAL_SEC,
    ROR_Y_MAX,
    ROR_Y_MIN,
    TEMP_Y_MAX_C,
    TEMP_Y_MIN_C,
    generateRoastProfile,
    formatRoastTime,
    formatTemp,
    formatRor,
    type RoastPoint,
  } from "../../lib/roastChartData";

  type Theme = "dark" | "light";

  const EVENT_COLORS = {
    dark: {
      charge: "#fb923c",
      tp: "#81fba5",
      yellow: "#ffff54",
      fc: "#44bffc",
    },
    light: {
      charge: "#ea580c",
      tp: "#059669",
      yellow: "#d97706",
      fc: "#2563eb",
    },
  } as const;

  const PALETTE = {
    dark: {
      bg: "#181d21",
      grid: "rgba(255, 255, 255, 0.1)",
      gridStrong: "rgba(255, 255, 255, 0.12)",
      text: "#888888",
      textStrong: "#bbbbbb",
      bt: "#4be08c",
      et: "#beacf8",
      ref: "rgba(75, 224, 140, 0.65)",
      ror: "#ffff54",
      rorFill: "rgba(255, 255, 84, 0.12)",
      cursor: "rgba(255, 255, 255, 0.45)",
      cursorGlow: "rgba(129, 251, 165, 0.2)",
      event: "rgba(255, 255, 255, 0.08)",
      eventLabel: "#bbbbbb",
      phaseFill: 0.18,
      phases: ROAST_PHASES_DARK,
    },
    light: {
      bg: "#ffffff",
      grid: "rgba(0, 0, 0, 0.08)",
      gridStrong: "rgba(0, 0, 0, 0.1)",
      text: "#666666",
      textStrong: "#444444",
      bt: "#22a85a",
      et: "#4a85c5",
      ref: "rgba(40, 180, 130, 0.65)",
      ror: "#f1c21b",
      rorFill: "rgba(241, 194, 27, 0.15)",
      cursor: "rgba(0, 0, 0, 0.45)",
      cursorGlow: "rgba(34, 168, 90, 0.15)",
      event: "rgba(0, 0, 0, 0.07)",
      eventLabel: "#555555",
      phaseFill: 0.22,
      phases: ROAST_PHASES_LIGHT,
    },
  } as const;

  class RoastChartRenderer {
    private root: HTMLElement;
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private theme: Theme;
    private palette: (typeof PALETTE)[Theme];
    private data: RoastPoint[];
    private loopEnd: number;
    private animate: boolean;
    private running = false;
    private playheadTime = 0;
    private raf = 0;
    private lastTs = 0;
    private pauseUntil = 0;
    private pulsePhase = 0;
    private dpr = 1;
    private width = 0;
    private height = 0;
    private margin = { top: 22, right: 44, bottom: 30, left: 44 };
    private rorSplit = 0.28;
    private tempMin = TEMP_Y_MIN_C;
    private tempMax = TEMP_Y_MAX_C;
    private rorMin = ROR_Y_MIN;
    private rorMax = ROR_Y_MAX;
    private timeStart = 0;
    private timeEnd = ROAST_TOTAL_SEC;
    private windowSec = ROAST_TOTAL_SEC;
    private startTime = 0;
    private useSlidingWindow = false;
    private resizeObserver?: ResizeObserver;

    constructor(root: HTMLElement) {
      this.root = root;
      const canvas = root.querySelector<HTMLCanvasElement>(".ox-roast-chart-canvas");
      if (!canvas) throw new Error("Roast chart canvas missing");
      const ctx = canvas.getContext("2d");
      if (!ctx) throw new Error("2d context unavailable");
      this.canvas = canvas;
      this.ctx = ctx;
      this.theme = (root.dataset.theme as Theme) || "dark";
      this.palette = PALETTE[this.theme];
      this.data = generateRoastProfile();
      this.loopEnd = Number(root.dataset.loopEnd || 582);
      this.startTime = Number(root.dataset.startTime || 0);
      this.windowSec = Number(root.dataset.windowSec || ROAST_TOTAL_SEC);
      this.useSlidingWindow = this.windowSec < ROAST_TOTAL_SEC - 1;
      this.playheadTime = this.startTime;
      this.animate = root.dataset.animate !== "false";
      this.setup();
    }

    private setup() {
      this.resize();
      this.resizeObserver = new ResizeObserver(() => this.resize());
      this.resizeObserver.observe(this.root);
      window.addEventListener("resize", this.onResize, { passive: true });

      this.root.addEventListener("ox-roast-chart-pause", ((e: CustomEvent<{ paused: boolean }>) => {
        if (e.detail.paused) this.pause();
        else this.resume();
      }) as EventListener);

      this.updateTimeWindow(this.playheadTime);
      if (this.animate && this.isVisible() && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        this.resume();
      } else {
        this.playheadTime = this.loopEnd;
        this.updateTimeWindow(this.playheadTime);
        this.render();
        this.updateMetrics(this.sampleAtTime(this.playheadTime), false);
      }
    }

    private isVisible() {
      const view = this.root.closest<HTMLElement>("[data-step-view]");
      return !view?.hidden;
    }

    pause() {
      this.running = false;
      cancelAnimationFrame(this.raf);
      this.raf = 0;
    }

    resume() {
      if (!this.isVisible()) return;
      if (!this.animate || this.running) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      this.resize();
      this.running = true;
      this.lastTs = performance.now();
      this.raf = requestAnimationFrame(this.tick);
    }

    private onResize = () => this.resize();

    private resize() {
      const wrap = this.root.querySelector<HTMLElement>(".ox-roast-chart-canvas-wrap");
      if (!wrap) return;
      const rect = wrap.getBoundingClientRect();
      this.dpr = Math.min(window.devicePixelRatio || 1, 2);
      this.width = Math.max(1, Math.floor(rect.width));
      this.height = Math.max(1, Math.floor(rect.height));
      this.canvas.width = Math.floor(this.width * this.dpr);
      this.canvas.height = Math.floor(this.height * this.dpr);
      this.canvas.style.width = `${this.width}px`;
      this.canvas.style.height = `${this.height}px`;
      this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
      this.render();
    }

    private plot() {
      const rorH = Math.floor((this.height - this.margin.top - this.margin.bottom) * this.rorSplit);
      const mainH = this.height - this.margin.top - this.margin.bottom - rorH - 8;
      const x0 = this.margin.left;
      const x1 = this.width - this.margin.right;
      const mainY0 = this.margin.top;
      const mainY1 = mainY0 + mainH;
      const rorY0 = mainY1 + 8;
      const rorY1 = rorY0 + rorH;
      return { x0, x1, mainY0, mainY1, rorY0, rorY1, mainH, rorH };
    }

    private xAt(t: number, x0: number, x1: number) {
      const span = Math.max(1, this.timeEnd - this.timeStart);
      return x0 + ((t - this.timeStart) / span) * (x1 - x0);
    }

    private yTemp(v: number, y0: number, y1: number) {
      const p = (v - this.tempMin) / (this.tempMax - this.tempMin);
      return y1 - p * (y1 - y0);
    }

    private yRor(v: number, y0: number, y1: number) {
      const p = (v - this.rorMin) / (this.rorMax - this.rorMin);
      return y1 - p * (y1 - y0);
    }

    private updateTimeWindow(currentT: number) {
      if (!this.useSlidingWindow) {
        this.timeStart = 0;
        this.timeEnd = ROAST_TOTAL_SEC;
        return;
      }

      this.timeStart = Math.max(0, currentT - this.windowSec * 0.88);
      this.timeEnd = this.timeStart + this.windowSec;
      if (this.timeEnd > ROAST_TOTAL_SEC) {
        this.timeEnd = ROAST_TOTAL_SEC;
        this.timeStart = Math.max(0, this.timeEnd - this.windowSec);
      }
    }

    private sampleAtTime(t: number): RoastPoint {
      const clamped = Math.max(0, Math.min(ROAST_TOTAL_SEC, t));
      let lo = 0;
      let hi = this.data.length - 1;
      while (lo < hi) {
        const mid = Math.floor((lo + hi) / 2);
        if (this.data[mid].t < clamped) lo = mid + 1;
        else hi = mid;
      }
      const i = Math.max(0, lo - 1);
      const a = this.data[i];
      const b = this.data[Math.min(i + 1, this.data.length - 1)];
      if (b.t <= a.t) return { ...a, t: clamped };
      const f = (clamped - a.t) / (b.t - a.t);
      const lerp = (x: number, y: number) => x + (y - x) * f;
      return {
        t: clamped,
        bt: lerp(a.bt, b.bt),
        et: lerp(a.et, b.et),
        ror: lerp(a.ror, b.ror),
        refBt: lerp(a.refBt, b.refBt),
        refEt: lerp(a.refEt, b.refEt),
      };
    }

    private sensorJitter(t: number) {
      const wobble = (seed: number, amp: number) =>
        Math.sin(t * 2.7 + seed) * amp + Math.sin(t * 5.3 + seed * 1.7) * amp * 0.35;
      return {
        bt: wobble(0.4, 0.12),
        et: wobble(1.8, 0.1),
        ror: wobble(2.6, 0.06),
      };
    }

    private pointsUntil(until: number) {
      const from = Math.max(this.timeStart, 0);
      const to = until;
      if (to < from) return [] as RoastPoint[];

      const points: RoastPoint[] = [];
      const startIdx = this.indexAtTime(from);
      const endIdx = this.indexAtTime(to);

      if (this.data[startIdx].t < from) points.push(this.sampleAtTime(from));
      for (let i = startIdx; i <= endIdx; i++) {
        const p = this.data[i];
        if (p.t >= from && p.t <= to) points.push(p);
      }
      const tail = this.sampleAtTime(to);
      if (!points.length || points[points.length - 1].t < to - 1e-6) points.push(tail);
      return points;
    }

    private indexAtTime(t: number) {
      let lo = 0;
      let hi = this.data.length - 1;
      while (lo < hi) {
        const mid = Math.floor((lo + hi + 1) / 2);
        if (this.data[mid].t <= t) lo = mid;
        else hi = mid - 1;
      }
      return lo;
    }

    private drawGrid(x0: number, x1: number, y0: number, y1: number, ticks: number[], mapY: (v: number) => number, suffix: string) {
      const { ctx, palette } = this;
      ctx.save();
      ctx.strokeStyle = palette.grid;
      ctx.lineWidth = 1;
      ctx.fillStyle = palette.text;
      ctx.font = '500 10px "JetBrains Mono", ui-monospace, monospace';
      ctx.textAlign = "right";
      ctx.textBaseline = "middle";

      for (const v of ticks) {
        const y = mapY(v);
        ctx.beginPath();
        ctx.moveTo(x0, y + 0.5);
        ctx.lineTo(x1, y + 0.5);
        ctx.stroke();
        ctx.fillText(`${v}${suffix}`, x0 - 8, y);
      }
      ctx.restore();
    }

    private timeAxisTicks() {
      const ticks: number[] = [];
      const first = Math.ceil(this.timeStart / 60) * 60;
      for (let t = first; t <= this.timeEnd; t += 60) ticks.push(t);
      if (!ticks.length || ticks[0] > this.timeStart) ticks.unshift(Math.round(this.timeStart));
      return ticks;
    }

    private drawTimeAxis(x0: number, x1: number, y: number) {
      const { ctx, palette } = this;
      const ticks = this.timeAxisTicks();
      ctx.save();
      ctx.strokeStyle = palette.gridStrong;
      ctx.fillStyle = palette.text;
      ctx.font = '500 10px "JetBrains Mono", ui-monospace, monospace';
      ctx.textAlign = "center";
      ctx.textBaseline = "top";
      ctx.beginPath();
      ctx.moveTo(x0, y + 0.5);
      ctx.lineTo(x1, y + 0.5);
      ctx.stroke();

      for (const t of ticks) {
        const x = this.xAt(t, x0, x1);
        ctx.beginPath();
        ctx.moveTo(x + 0.5, y - 4);
        ctx.lineTo(x + 0.5, y + 4);
        ctx.stroke();
        ctx.fillText(formatRoastTime(t), x, y + 6);
      }
      ctx.restore();
    }

    private drawPhases(x0: number, x1: number, y0: number, y1: number) {
      const { ctx } = this;
      for (const phase of this.palette.phases) {
        if (phase.end < this.timeStart || phase.start > this.timeEnd) continue;
        const xA = this.xAt(Math.max(phase.start, this.timeStart), x0, x1);
        const xB = this.xAt(Math.min(phase.end, this.timeEnd), x0, x1);
        ctx.fillStyle = `rgba(${phase.color}, ${this.palette.phaseFill})`;
        ctx.fillRect(xA, y0, xB - xA, y1 - y0);
        ctx.fillStyle = `rgba(${phase.color}, 0.55)`;
        ctx.font = '500 9px "JetBrains Mono", ui-monospace, monospace';
        ctx.textAlign = "center";
        ctx.textBaseline = "top";
        if (xB - xA > 54) {
          ctx.fillText(phase.label.toUpperCase(), (xA + xB) / 2, y0 + 6);
        }
      }
    }

    private drawEvents(x0: number, x1: number, y0: number, y1: number, until: number) {
      const { ctx, palette } = this;
      ctx.save();
      ctx.setLineDash([3, 4]);
      ctx.strokeStyle = palette.event;
      ctx.fillStyle = palette.eventLabel;
      ctx.font = '500 9px "JetBrains Mono", ui-monospace, monospace';
      ctx.textAlign = "left";
      ctx.textBaseline = "top";

      const eventColors = EVENT_COLORS[this.theme];
      for (const ev of ROAST_EVENTS) {
        if (ev.time > until || ev.time < this.timeStart || ev.time > this.timeEnd) continue;
        const x = this.xAt(ev.time, x0, x1);
        ctx.strokeStyle = eventColors[ev.id as keyof typeof eventColors] ?? palette.event;
        ctx.beginPath();
        ctx.moveTo(x + 0.5, y0);
        ctx.lineTo(x + 0.5, y1);
        ctx.stroke();
        ctx.strokeStyle = palette.event;
        ctx.fillStyle = eventColors[ev.id as keyof typeof eventColors] ?? palette.eventLabel;
        ctx.fillText(ev.label, x + 4, y0 + 4);
      }
      ctx.restore();
    }

    private drawSeries(
      until: number,
      key: "bt" | "et" | "refBt" | "refEt" | "ror",
      color: string,
      width: number,
      x0: number,
      x1: number,
      y0: number,
      y1: number,
      mapY: (v: number) => number,
      dashed = false,
    ) {
      const { ctx } = this;
      const slice = this.pointsUntil(until);
      if (slice.length < 2) return;

      ctx.save();
      ctx.strokeStyle = color;
      ctx.lineWidth = width;
      ctx.lineJoin = "round";
      ctx.lineCap = "round";
      if (dashed) ctx.setLineDash([5, 4]);

      ctx.beginPath();
      slice.forEach((p, i) => {
        const x = this.xAt(p.t, x0, x1);
        const y = mapY(p[key]);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
      ctx.restore();
    }

    private drawRorFill(until: number, x0: number, x1: number, y0: number, y1: number, mapY: (v: number) => number) {
      const { ctx, palette } = this;
      const slice = this.pointsUntil(until);
      if (slice.length < 2) return;

      const zeroY = mapY(0);
      ctx.save();
      ctx.beginPath();
      slice.forEach((p, i) => {
        const x = this.xAt(p.t, x0, x1);
        const y = mapY(p.ror);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      const last = slice[slice.length - 1];
      const first = slice[0];
      ctx.lineTo(this.xAt(last.t, x0, x1), zeroY);
      ctx.lineTo(this.xAt(first.t, x0, x1), zeroY);
      ctx.closePath();
      ctx.fillStyle = palette.rorFill;
      ctx.fill();
      ctx.restore();
    }

    private drawCursor(point: RoastPoint, x0: number, x1: number, mainY0: number, mainY1: number, rorY0: number, rorY1: number) {
      const { ctx, palette } = this;
      const x = this.xAt(point.t, x0, x1);
      const yBt = this.yTemp(point.bt, mainY0, mainY1);
      const pulse = 0.55 + 0.45 * Math.sin(this.pulsePhase);

      ctx.save();
      ctx.strokeStyle = palette.cursorGlow;
      ctx.lineWidth = 6 + pulse * 3;
      ctx.beginPath();
      ctx.moveTo(x + 0.5, mainY0);
      ctx.lineTo(x + 0.5, rorY1);
      ctx.stroke();

      ctx.strokeStyle = palette.cursor;
      ctx.lineWidth = 1;
      ctx.setLineDash([2, 3]);
      ctx.beginPath();
      ctx.moveTo(x + 0.5, mainY0);
      ctx.lineTo(x + 0.5, rorY1);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.fillStyle = palette.cursorGlow;
      ctx.beginPath();
      ctx.arc(x, yBt, 5 + pulse * 4, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = palette.bt;
      ctx.beginPath();
      ctx.arc(x, yBt, 3.5, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = palette.textStrong;
      ctx.font = '600 8px "JetBrains Mono", ui-monospace, monospace';
      ctx.textAlign = "center";
      ctx.textBaseline = "bottom";
      ctx.fillText("NOW", x, mainY0 - 4);
      ctx.restore();
    }

    private render() {
      const { ctx, palette } = this;
      const current = this.sampleAtTime(this.playheadTime);
      const until = current.t;
      const plot = this.plot();

      ctx.clearRect(0, 0, this.width, this.height);
      ctx.fillStyle = palette.bg;
      ctx.fillRect(0, 0, this.width, this.height);

      const mapTemp = (v: number) => this.yTemp(v, plot.mainY0, plot.mainY1);
      const mapRor = (v: number) => this.yRor(v, plot.rorY0, plot.rorY1);

      this.drawPhases(plot.x0, plot.x1, plot.mainY0, plot.mainY1);
      this.drawGrid(plot.x0, plot.x1, plot.mainY0, plot.mainY1, [50, 100, 150, 200, 250], mapTemp, "°");
      this.drawGrid(plot.x0, plot.x1, plot.rorY0, plot.rorY1, [-5, 0, 10, 20], mapRor, "");

      ctx.save();
      ctx.strokeStyle = palette.grid;
      ctx.lineWidth = 1;
      const zeroY = mapRor(0);
      ctx.beginPath();
      ctx.moveTo(plot.x0, zeroY + 0.5);
      ctx.lineTo(plot.x1, zeroY + 0.5);
      ctx.stroke();

      ctx.strokeStyle = palette.gridStrong;
      ctx.strokeRect(plot.x0 + 0.5, plot.mainY0 + 0.5, plot.x1 - plot.x0 - 1, plot.mainY1 - plot.mainY0 - 1);
      ctx.strokeRect(plot.x0 + 0.5, plot.rorY0 + 0.5, plot.x1 - plot.x0 - 1, plot.rorY1 - plot.rorY0 - 1);
      ctx.restore();

      this.drawSeries(until, "refBt", palette.ref, 1.5, plot.x0, plot.x1, plot.mainY0, plot.mainY1, mapTemp, true);
      this.drawSeries(until, "refEt", palette.ref, 1, plot.x0, plot.x1, plot.mainY0, plot.mainY1, mapTemp, true);
      this.drawRorFill(until, plot.x0, plot.x1, plot.rorY0, plot.rorY1, mapRor);
      this.drawSeries(until, "et", palette.et, 1.5, plot.x0, plot.x1, plot.mainY0, plot.mainY1, mapTemp);
      this.drawSeries(until, "bt", palette.bt, 2.25, plot.x0, plot.x1, plot.mainY0, plot.mainY1, mapTemp);
      this.drawSeries(until, "ror", palette.ror, 1.75, plot.x0, plot.x1, plot.rorY0, plot.rorY1, mapRor);

      this.drawEvents(plot.x0, plot.x1, plot.mainY0, plot.rorY1, until);
      this.drawTimeAxis(plot.x0, plot.x1, plot.rorY1 + 2);
      if (this.animate && this.running) this.drawCursor(current, plot.x0, plot.x1, plot.mainY0, plot.mainY1, plot.rorY0, plot.rorY1);

      ctx.save();
      ctx.fillStyle = palette.textStrong;
      ctx.font = '500 9px "JetBrains Mono", ui-monospace, monospace';
      ctx.textAlign = "left";
      ctx.textBaseline = "bottom";
      ctx.fillText("°C", plot.x0, plot.mainY0 - 6);
      ctx.textAlign = "right";
      ctx.fillText("°/m", plot.x1, plot.rorY0 - 4);
      ctx.restore();

      this.updateMetrics(current, this.animate && this.running);
    }

    private phaseName(t: number) {
      if (t < 88) return "Ready";
      if (t < 252) return "Drying";
      if (t < 572) return "Maillard";
      return "Development";
    }

    private phaseColor(name: string) {
      const map =
        this.theme === "light"
          ? {
              Ready: "#22a85a",
              Drying: "#d4a017",
              Maillard: "#1976d2",
              Development: "#5c4fd4",
            }
          : {
              Ready: "#81fba5",
              Drying: "#ffff54",
              Maillard: "#44bffc",
              Development: "#756afc",
            };
      return map[name as keyof typeof map] ?? map.Development;
    }

    private updateMetrics(point: RoastPoint, live = true) {
      const bt = this.root.querySelector("[data-metric-bt]");
      const et = this.root.querySelector("[data-metric-et]");
      const ror = this.root.querySelector("[data-metric-ror]");
      const time = this.root.querySelector("[data-metric-time]");
      const phase = this.root.querySelector("[data-metric-phase]");
      const phaseName = this.phaseName(point.t);
      const jitter = live ? this.sensorJitter(point.t) : { bt: 0, et: 0, ror: 0 };
      const btVal = point.bt + jitter.bt;
      const etVal = point.et + jitter.et;
      const rorVal = point.ror + jitter.ror;
      if (bt) bt.textContent = formatTemp(btVal);
      if (et) et.textContent = formatTemp(etVal);
      if (ror) ror.textContent = formatRor(rorVal);
      if (time) time.textContent = formatRoastTime(point.t);
      if (phase) phase.textContent = phaseName;
      this.root.dispatchEvent(
        new CustomEvent("ox-roast-metrics", {
          detail: {
            bt: formatTemp(btVal),
            et: formatTemp(etVal),
            ror: formatRor(rorVal),
            time: formatRoastTime(point.t),
            phase: phaseName,
            phaseColor: this.phaseColor(phaseName),
          },
        }),
      );
    }

    private tick = (ts: number) => {
      const paused = this.pauseUntil > 0 && ts < this.pauseUntil;

      if (!paused) {
        if (this.pauseUntil > 0 && ts >= this.pauseUntil) {
          this.playheadTime = this.startTime;
          this.pauseUntil = 0;
          this.lastTs = ts;
        }

        const dt = Math.min(48, ts - this.lastTs);
        this.lastTs = ts;
        this.playheadTime = Math.min(this.loopEnd, this.playheadTime + dt / 1000);

        if (this.playheadTime >= this.loopEnd) {
          this.playheadTime = this.loopEnd;
          this.pauseUntil = ts + 2000;
        }

        this.updateTimeWindow(this.playheadTime);
      }

      this.pulsePhase += 0.14;
      this.render();
      this.raf = requestAnimationFrame(this.tick);
    };

    destroy() {
      this.pause();
      this.resizeObserver?.disconnect();
      window.removeEventListener("resize", this.onResize);
    }
  }

  const charts: RoastChartRenderer[] = [];

  function initCharts() {
    document.querySelectorAll<HTMLElement>(".ox-roast-chart").forEach((root) => {
      if (root.dataset.ready === "true") return;
      root.dataset.ready = "true";
      charts.push(new RoastChartRenderer(root));
    });
  }

  initCharts();
  document.addEventListener("astro:page-load", initCharts);
</script>