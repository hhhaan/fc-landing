---
import "../styles/global.css";
import { requireLogin } from "../lib/auth";
import { createClient } from "../lib/supabase";

const userOrRedirect = await requireLogin(Astro, Astro.request.url);
if (userOrRedirect instanceof Response) return userOrRedirect;
const user = userOrRedirect;

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const { data: subscription, error: subError } = await supabase
  .from("subscriptions")
  .select("status, recurring_interval, current_period_end, trial_end")
  .eq("user_id", user.id)
  .in("status", ["active", "trialing", "past_due"])
  .order("created_at", { ascending: false })
  .limit(1)
  .maybeSingle();
if (subError) console.error("[account] subscription fetch error", subError.message);

const isPro = !!subscription;

const showWelcome = Astro.url.searchParams.get("welcome") === "1";

function formatDate(iso: string | null): string {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

const now = new Date();
const trialEnd = subscription?.trial_end ? new Date(subscription.trial_end) : null;
const isTrialActive = trialEnd && trialEnd > now;
const billingInterval = subscription?.recurring_interval === "year" ? "Yearly" : "Monthly";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account — First Crack</title>
  </head>
  <body>

    <!-- NAV -->
    <header class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="nav-logo-text">First Crack</span>
        </a>
        <div class="nav-actions">
          <span class="nav-email">{user.email}</span>
          <form action="/auth/signout" method="POST" class="inline">
            <button type="submit" class="btn btn-ghost btn-compact">Sign out</button>
          </form>
        </div>
      </div>
    </header>

    <main class="page-main">
      <div class="page-container">

        {showWelcome && (
          <div class="welcome-banner" role="alert">
            <span class="welcome-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </span>
            <div>
              <p class="welcome-heading">Welcome to Pro!</p>
              <p class="welcome-body">Your 14-day free trial has started. Download the app to get started.</p>
            </div>
          </div>
        )}

        <div class="account-card">

          <!-- EMAIL SECTION -->
          <div class="account-section">
            <span class="section-label">EMAIL</span>
            <span class="section-value">{user.email}</span>
          </div>

          <div class="card-divider"></div>

          <!-- PLAN SECTION -->
          <div class="account-section">
            <span class="section-label">PLAN</span>
            <div class="plan-row">
              {isPro ? (
                <span class="badge-pro">PRO</span>
              ) : (
                <span class="badge-free">FREE</span>
              )}
              {isPro ? (
                <div class="plan-details">
                  <span class="plan-interval">{billingInterval}</span>
                  {isTrialActive && (
                    <span class="plan-detail-row">
                      <span class="detail-label">Trial ends</span>
                      <span class="detail-value">{formatDate(subscription?.trial_end ?? null)}</span>
                    </span>
                  )}
                  <span class="plan-detail-row">
                    <span class="detail-label">Next billing date</span>
                    <span class="detail-value">{formatDate(subscription?.current_period_end ?? null)}</span>
                  </span>
                </div>
              ) : (
                <a href="/#pricing" class="upgrade-link">Upgrade to Pro →</a>
              )}
            </div>
          </div>

        </div>

        <div class="download-cta">
          <a href="/download" class="btn btn-primary btn-comfort">Download First Crack</a>
        </div>

      </div>
    </main>

  </body>
</html>

<style>
  /* =============================================
     NAV
     ============================================= */
  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 var(--space-24);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-fg);
  }
  .nav-logo-text {
    font-family: var(--font-display);
    font-size: var(--text-nav);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-12);
  }
  .nav-email {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  /* =============================================
     PAGE LAYOUT
     ============================================= */
  .page-main {
    background: var(--color-bg-secondary);
    min-height: calc(100vh - 56px);
    padding-block: var(--space-48);
  }
  .page-container {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  /* =============================================
     WELCOME BANNER
     ============================================= */
  .welcome-banner {
    --banner-bg: #f0fdf4;
    --banner-border: #86efac;
    --banner-icon-bg: #dcfce7;
    --banner-icon-color: #16a34a;
    --banner-title-color: #15803d;
    --banner-body-color: #166534;
    display: flex;
    align-items: flex-start;
    gap: var(--space-12);
    background: var(--banner-bg);
    border: 1px solid var(--banner-border);
    border-radius: var(--radius-card);
    padding: var(--space-16) var(--space-20);
  }
  .welcome-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: var(--banner-icon-bg);
    border-radius: var(--radius-pill);
    color: var(--banner-icon-color);
    margin-top: 1px;
  }
  .welcome-heading {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--banner-title-color);
    margin-bottom: var(--space-4);
  }
  .welcome-body {
    font-size: var(--text-sm);
    color: var(--banner-body-color);
    line-height: 1.5;
  }

  /* =============================================
     ACCOUNT CARD
     ============================================= */
  .account-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-28);
    display: flex;
    flex-direction: column;
  }
  .account-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-block: var(--space-20);
  }
  .account-section:first-child {
    padding-top: 0;
  }
  .account-section:last-child {
    padding-bottom: 0;
  }
  .card-divider {
    height: 1px;
    background: var(--color-border);
  }
  .section-label {
    font-size: var(--text-micro);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-fg-muted);
  }
  .section-value {
    font-size: var(--text-base);
    color: var(--color-fg);
  }

  /* =============================================
     PLAN SECTION
     ============================================= */
  .plan-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-12);
  }
  .badge-pro {
    display: inline-block;
    font-size: var(--text-micro);
    font-weight: 700;
    letter-spacing: 0.08em;
    background: var(--color-dark);
    color: var(--color-mint);
    border-radius: var(--radius-subtle);
    padding: 3px var(--space-8);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .badge-free {
    display: inline-block;
    font-size: var(--text-micro);
    font-weight: 700;
    letter-spacing: 0.08em;
    background: var(--color-bg-secondary);
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-subtle);
    padding: 3px var(--space-8);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .plan-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .plan-interval {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-fg);
  }
  .plan-detail-row {
    display: flex;
    gap: var(--space-8);
    font-size: var(--text-sm);
  }
  .detail-label {
    color: var(--color-fg-muted);
  }
  .detail-value {
    color: var(--color-fg-secondary);
    font-weight: 500;
  }
  .upgrade-link {
    font-size: var(--text-base);
    color: var(--color-fg);
    font-weight: 500;
    text-decoration: none;
    margin-top: 2px;
    transition: color var(--motion-fast) ease;
  }
  .upgrade-link:hover {
    color: var(--color-fg-secondary);
  }

  /* =============================================
     DOWNLOAD CTA
     ============================================= */
  .download-cta {
    display: flex;
    justify-content: center;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 600px) {
    .nav-email {
      display: none;
    }
    .page-main {
      padding-block: var(--space-32);
    }
    .account-card {
      padding: var(--space-20);
    }
  }
</style>
