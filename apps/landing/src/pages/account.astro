---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
import { requireLogin } from "../lib/auth";
import { createClient } from "../lib/supabase";

const userOrRedirect = await requireLogin(
  Astro,
  `${Astro.url.pathname}${Astro.url.search}`,
);
if (userOrRedirect instanceof Response) return userOrRedirect;
const user = userOrRedirect;

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const { data: subscription, error: subError } = await supabase
  .from("subscriptions")
  .select("status, recurring_interval, current_period_end, trial_end, cancel_at_period_end")
  .eq("user_id", user.id)
  .in("status", ["active", "trialing", "past_due"])
  .order("created_at", { ascending: false })
  .limit(1)
  .maybeSingle();
if (subError) console.error("[account] subscription fetch error", subError.message);

const isPro = !!subscription;
const showWelcome = Astro.url.searchParams.get("welcome") === "1";
const billingStatus = Astro.url.searchParams.get("billing");
const year = new Date().getFullYear();

function formatDate(iso: string | null | undefined): string {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const now = new Date();
const trialEnd = subscription?.trial_end ? new Date(subscription.trial_end) : null;
const isTrialActive = !!(trialEnd && trialEnd > now);
const isPastDue = subscription?.status === "past_due";
const billingInterval =
  subscription?.recurring_interval === "year" ? "Yearly" : "Monthly";

const rawProvider =
  user.app_metadata?.provider ?? user.identities?.[0]?.provider ?? "email";
const signInMethod = rawProvider === "google" ? "Google" : "Email & password";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Manage your First Crack account — plan, billing, and desktop app access."
    />
    <title>Account — First Crack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-ac noise-overlay">
      <div class="ox-grid-bg" aria-hidden="true"></div>

      <header class="ox-auth-header">
        <nav class="ox-auth-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>
          <div class="ox-auth-nav-end">
            <span class="ox-auth-email">{user.email}</span>
            <form action="/auth/signout" method="POST" class="ox-ac-signout">
              <button type="submit" class="ox-btn ox-btn-outline ox-btn-sm">
                Sign out
              </button>
            </form>
          </div>
        </nav>
      </header>

      <div class="ox-ac-main">
        <div class="ox-shell ox-ac-inner">
          <div class="ox-ac-head">
            <div class="ox-eyebrow">
              <span class="ox-line"></span>
              Account
            </div>
            <h1 class="ox-ac-title">Your workspace</h1>
            <p class="ox-ac-lead">
              Plan, billing, and desktop access for your roastery — all tied to
              this sign-in.
            </p>
          </div>

          {
            showWelcome && (
              <div class="ox-ac-banner ox-ac-banner-success" role="status">
                <p class="ox-ac-banner-title">Welcome to Pro</p>
                <p class="ox-ac-banner-body">
                  Your trial has started. Download the desktop app and sign in
                  with the same account to sync profiles and batches.
                </p>
              </div>
            )
          }

          {
            billingStatus === "unavailable" && (
              <div class="ox-ac-banner ox-ac-banner-warn" role="status">
                <p class="ox-ac-banner-title">Billing portal unavailable</p>
                <p class="ox-ac-banner-body">
                  No billing profile yet. If you subscribed recently, try again in
                  a few minutes or email{" "}
                  <a href="mailto:hello@firstcrackiscoming.com">
                    hello@firstcrackiscoming.com
                  </a>
                  .
                </p>
              </div>
            )
          }

          {
            billingStatus === "error" && (
              <div class="ox-ac-banner ox-ac-banner-warn" role="alert">
                <p class="ox-ac-banner-title">Could not open billing portal</p>
                <p class="ox-ac-banner-body">
                  Please try again or email{" "}
                  <a href="mailto:hello@firstcrackiscoming.com">
                    hello@firstcrackiscoming.com
                  </a>
                  .
                </p>
              </div>
            )
          }

          {
            isPastDue && (
              <div class="ox-ac-banner ox-ac-banner-warn" role="alert">
                <p class="ox-ac-banner-title">Payment issue</p>
                <p class="ox-ac-banner-body">
                  We could not process your last payment. Email{" "}
                  <a href="mailto:hello@firstcrackiscoming.com">
                    hello@firstcrackiscoming.com
                  </a>{" "}
                  to restore Pro access.
                </p>
              </div>
            )
          }

          <div class="ox-ac-layout">
            <div class="ox-ac-stack">
              <article class="ox-ac-card">
                <header class="ox-ac-card-head">
                  <span class="ox-ac-tag">Plan</span>
                  <h2>Subscription</h2>
                </header>

                <div class="ox-ac-plan">
                  <span class:list={["ox-ac-badge", isPro ? "is-pro" : "is-free"]}>
                    {isPro ? "Pro" : "Free"}
                  </span>
                  <div class="ox-ac-plan-body">
                    {
                      isPro ? (
                        <>
                          <p class="ox-ac-plan-name">{billingInterval} billing</p>
                          {isTrialActive && (
                            <dl class="ox-ac-meta">
                              <div>
                                <dt>Trial ends</dt>
                                <dd>{formatDate(subscription?.trial_end)}</dd>
                              </div>
                            </dl>
                          )}
                          <dl class="ox-ac-meta">
                            <div>
                              <dt>Next billing date</dt>
                              <dd>
                                {formatDate(subscription?.current_period_end)}
                              </dd>
                            </div>
                          </dl>
                          {subscription?.cancel_at_period_end && (
                            <p class="ox-ac-plan-cancel">
                              Cancels at end of current period.
                            </p>
                          )}
                          <div class="ox-ac-card-actions">
                            <a
                              href="/manage-billing"
                              class="ox-btn ox-btn-outline ox-btn-sm"
                            >
                              Manage billing
                            </a>
                            <a
                              href="/compare-plans"
                              class="ox-btn ox-btn-outline ox-btn-sm"
                            >
                              Compare plans
                            </a>
                          </div>
                        </>
                      ) : (
                        <>
                          <p class="ox-ac-plan-name">
                            20 batches on the floor — upgrade when you need cloud
                            sync and unlimited archives.
                          </p>
                          <div class="ox-ac-card-actions">
                            <a
                              href="/compare-plans"
                              class="ox-btn ox-btn-solid ox-btn-sm"
                            >
                              Start 14-day trial
                            </a>
                            <a href="/compare-plans" class="ox-btn ox-btn-outline ox-btn-sm">
                              Compare plans
                            </a>
                          </div>
                        </>
                      )
                    }
                  </div>
                </div>
              </article>

              <article class="ox-ac-card">
                <header class="ox-ac-card-head">
                  <span class="ox-ac-tag">Profile</span>
                  <h2>Sign-in</h2>
                </header>
                <dl class="ox-ac-meta ox-ac-meta-block">
                  <div>
                    <dt>Email</dt>
                    <dd>{user.email}</dd>
                  </div>
                  <div>
                    <dt>Method</dt>
                    <dd>{signInMethod}</dd>
                  </div>
                  <div>
                    <dt>Member since</dt>
                    <dd>{formatDate(user.created_at)}</dd>
                  </div>
                </dl>
              </article>

              <article class="ox-ac-card">
                <header class="ox-ac-card-head">
                  <span class="ox-ac-tag">Desktop</span>
                  <h2>First Crack app</h2>
                </header>
                <p class="ox-ac-card-copy">
                  Roasting runs in the native macOS and Windows app. Use this
                  account to sign in on the roast floor — profiles and batches
                  sync when you are on Pro.
                </p>
                <div class="ox-ac-card-actions">
                  <a href="/download" class="ox-btn ox-btn-solid ox-btn-sm">
                    Download app
                  </a>
                </div>
              </article>
            </div>

            <aside class="ox-ac-aside">
              <div class="ox-ac-panel">
                <h3 class="ox-ac-panel-title">Getting started</h3>
                <ol class="ox-ac-steps">
                  <li>
                    <span class="ox-ac-step-n">1</span>
                    <span>Download the desktop app for your platform.</span>
                  </li>
                  <li>
                    <span class="ox-ac-step-n">2</span>
                    <span>Sign in with <strong>{user.email}</strong>.</span>
                  </li>
                  <li>
                    <span class="ox-ac-step-n">3</span>
                    <span>Connect your roaster and run your first batch.</span>
                  </li>
                </ol>
              </div>

              <div class="ox-ac-panel">
                <h3 class="ox-ac-panel-title">Help</h3>
                <nav class="ox-ac-links" aria-label="Account help">
                  <a href="mailto:hello@firstcrackiscoming.com">Contact support</a>
                  <a href="/privacy">Privacy policy</a>
                  <a href="/terms">Terms of service</a>
                </nav>
              </div>
            </aside>
          </div>
        </div>
      </div>

      <footer class="ox-ac-footer">
        <div class="ox-shell ox-ac-footer-inner">
          <span>© {year} First Crack</span>
          <nav aria-label="Footer">
            <a href="/">Home</a>
            <a href="/download">Download</a>
            <a href="mailto:hello@firstcrackiscoming.com">Contact</a>
          </nav>
        </div>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  body.ox {
    --ox-bg: #fafaf9;
    --ox-fg: #080503;
    --ox-muted: #5e534a;
    --ox-muted-bg: #ecebe7;
    --ox-border: rgba(8, 5, 3, 0.06);
    --ox-border-strong: rgba(8, 5, 3, 0.12);
    --ox-sans: "Instrument Sans", system-ui, -apple-system, sans-serif;
    --ox-mono: "JetBrains Mono", ui-monospace, monospace;
    --ox-max: 1400px;
    --ox-pad: 24px;

    margin: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  body.ox *,
  body.ox *::before,
  body.ox *::after {
    box-sizing: border-box;
  }

  body.ox a {
    color: inherit;
    text-decoration: none;
  }

  body.ox button {
    font-family: inherit;
    cursor: pointer;
  }

  .ox-shell {
    max-width: var(--ox-max);
    margin-inline: auto;
    padding-inline: var(--ox-pad);
  }

  .ox-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 0;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .ox-btn-sm {
    height: 32px;
    padding: 0 20px;
    font-size: 13px;
  }

  body.ox a.ox-btn-solid,
  body.ox .ox-btn-solid {
    background: var(--ox-fg);
    color: #fff;
    border-color: var(--ox-fg);
  }

  body.ox a.ox-btn-solid:hover,
  body.ox .ox-btn-solid:hover {
    opacity: 0.9;
  }

  .ox-btn-outline {
    background: transparent;
    color: var(--ox-fg);
    border-color: var(--ox-border-strong);
  }

  .ox-btn-outline:hover {
    background: rgba(8, 5, 3, 0.03);
    border-color: rgba(8, 5, 3, 0.28);
  }

  .ox-brand-name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ox-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--ox-mono);
    font-size: 13px;
    color: var(--ox-muted);
    margin-bottom: 20px;
  }

  .ox-line {
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(8, 5, 3, 0.3);
    flex-shrink: 0;
  }

  .noise-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ox-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    background-image:
      linear-gradient(var(--ox-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ox-border) 1px, transparent 1px);
    background-size: 12.5% 12.5%;
  }

  .ox-auth-header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--ox-border);
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(16px);
  }

  .ox-auth-nav {
    max-width: var(--ox-max);
    margin: 0 auto;
    padding: 0 var(--ox-pad);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .ox-auth-nav-end {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ox-auth-email {
    display: none;
    font-size: 13px;
    color: var(--ox-muted);
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ox-ac-signout {
    margin: 0;
  }

  @media (min-width: 640px) {
    .ox-auth-email {
      display: inline;
    }
  }

  .ox-ac {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ox-ac-main {
    position: relative;
    z-index: 2;
    flex: 1;
    padding: 48px 0 64px;
  }

  .ox-ac-head {
    max-width: 36rem;
    margin-bottom: 40px;
  }

  .ox-ac-title {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .ox-ac-lead {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-ac-banner {
    margin-bottom: 24px;
    padding: 16px 20px;
    border: 1px solid var(--ox-border-strong);
    background: #fff;
  }

  .ox-ac-banner-success {
    border-color: rgba(2, 122, 72, 0.28);
    background: rgba(2, 122, 72, 0.06);
  }

  .ox-ac-banner-warn {
    border-color: rgba(180, 35, 24, 0.28);
    background: rgba(180, 35, 24, 0.05);
  }

  .ox-ac-banner-title {
    margin: 0 0 6px;
    font-size: 15px;
    font-weight: 600;
  }

  .ox-ac-banner-body {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--ox-muted);
  }

  .ox-ac-banner-body a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ox-ac-layout {
    display: grid;
    gap: 24px;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .ox-ac-layout {
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 32px;
    }
  }

  .ox-ac-stack {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ox-ac-card {
    padding: 28px 24px;
    border: 1px solid var(--ox-border);
    background: #fff;
  }

  @media (min-width: 640px) {
    .ox-ac-card {
      padding: 32px 28px;
    }
  }

  .ox-ac-card-head {
    margin-bottom: 20px;
  }

  .ox-ac-tag {
    display: block;
    margin-bottom: 10px;
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-ac-card-head h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ox-ac-card-copy {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ox-muted);
  }

  .ox-ac-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ox-ac-plan {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .ox-ac-badge {
    flex-shrink: 0;
    margin-top: 2px;
    padding: 4px 10px;
    font-family: var(--ox-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ox-ac-badge.is-pro {
    background: var(--ox-fg);
    color: #fff;
  }

  .ox-ac-badge.is-free {
    border: 1px solid var(--ox-border-strong);
    color: var(--ox-muted);
    background: var(--ox-muted-bg);
  }

  .ox-ac-plan-body {
    flex: 1;
    min-width: 0;
  }

  .ox-ac-plan-name {
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ox-muted);
  }

  .ox-ac-plan-cancel {
    margin: 0 0 12px;
    font-size: 13px;
    color: var(--ox-muted);
  }

  .ox-ac-meta {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ox-ac-meta-block {
    gap: 16px;
  }

  .ox-ac-meta div {
    display: grid;
    gap: 4px;
  }

  .ox-ac-meta dt {
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-ac-meta dd {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    word-break: break-word;
  }

  .ox-ac-aside {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ox-ac-panel {
    padding: 24px;
    border: 1px solid var(--ox-border);
    background: #fff;
  }

  .ox-ac-panel-title {
    margin: 0 0 16px;
    font-size: 13px;
    font-family: var(--ox-mono);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-ac-steps {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ox-ac-steps li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(8, 5, 3, 0.82);
  }

  .ox-ac-step-n {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--ox-mono);
    font-size: 11px;
    background: var(--ox-muted-bg);
    color: var(--ox-muted);
  }

  .ox-ac-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ox-ac-links a {
    font-size: 14px;
    color: rgba(8, 5, 3, 0.75);
    transition: color 0.2s ease;
  }

  .ox-ac-links a:hover {
    color: var(--ox-fg);
  }

  .ox-ac-footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--ox-border);
    padding: 24px 0;
  }

  .ox-ac-footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 13px;
    color: var(--ox-muted);
  }

  .ox-ac-footer-inner nav {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .ox-ac-footer-inner a:hover {
    color: var(--ox-fg);
  }

  @media (min-width: 1024px) {
    body.ox {
      --ox-pad: 48px;
    }
  }
</style>