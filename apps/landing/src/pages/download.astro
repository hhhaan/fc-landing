---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
import OxNavAuth from "../components/ui/OxNavAuth.astro";
import { getViewer } from "../lib/authState";
import { resolveTrialCta } from "../lib/trialCta";

const user = await getViewer(Astro);
const trialCta = await resolveTrialCta(Astro);
const year = new Date().getFullYear();

const DOWNLOAD_LINKS = {
  macos: {
    arm: "https://pub-32f64eaa15504eeba9203bcbbced439d.r2.dev/releases/latest/First-Crack-arm64.dmg",
    intel: "https://pub-32f64eaa15504eeba9203bcbbced439d.r2.dev/releases/latest/First-Crack-x64.dmg",
  },
  windows:
    "https://pub-32f64eaa15504eeba9203bcbbced439d.r2.dev/releases/latest/First-Crack-Windows.msi",
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Download First Crack for macOS and Windows — desktop roasting software for specialty coffee roasteries."
    />
    <title>Download — First Crack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-dl noise-overlay">
      <div class="ox-grid-bg" aria-hidden="true"></div>

      <header class="ox-auth-header">
        <nav class="ox-auth-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>
          <div class="ox-auth-nav-end">
            <OxNavAuth user={user} variant="auth" />
          </div>
        </nav>
      </header>

      <div class="ox-dl-main">
        <div class="ox-shell ox-dl-inner">
          <div class="ox-dl-head">
            <div class="ox-eyebrow">
              <span class="ox-line"></span>
              Desktop app
            </div>
            <h1 class="ox-dl-title">Download First Crack</h1>
            <p class="ox-dl-lead">
              Native macOS and Windows installers — live BT/ET/RoR on the roast floor,
              with cloud sync when you are back at the desk.
            </p>
          </div>

          <div class="ox-dl-grid">
            <article class="ox-dl-card" id="download-macos">
              <span class="ox-dl-badge" id="badge-macos" hidden>Recommended</span>
              <div class="ox-dl-card-top">
                <span class="ox-dl-tag">Platform</span>
                <h2>macOS</h2>
                <p>Apple Silicon and Intel. macOS 12.0 or later.</p>
              </div>
              <div class="ox-dl-actions">
                <a
                  href={DOWNLOAD_LINKS.macos.arm}
                  class="ox-btn ox-btn-solid ox-btn-block"
                >
                  Apple Silicon (.dmg)
                </a>
                <a
                  href={DOWNLOAD_LINKS.macos.intel}
                  class="ox-btn ox-btn-outline ox-btn-block"
                >
                  Intel Mac (.dmg)
                </a>
                <p class="ox-dl-note">Latest stable build</p>
              </div>
            </article>

            <article class="ox-dl-card" id="download-windows">
              <span class="ox-dl-badge" id="badge-windows" hidden>Recommended</span>
              <div class="ox-dl-card-top">
                <span class="ox-dl-tag">Platform</span>
                <h2>Windows</h2>
                <p>Windows 10 and 11. 64-bit x86.</p>
              </div>
              <div class="ox-dl-actions">
                <a
                  href={DOWNLOAD_LINKS.windows}
                  class="ox-btn ox-btn-solid ox-btn-block"
                >
                  Download (.msi)
                </a>
                <p class="ox-dl-note">Latest stable build</p>
              </div>
            </article>
          </div>

          <p class="ox-dl-fine">
            {
              trialCta.href === "/download" ? (
                <>
                  Already on Pro? Sign in on the desktop app with the same
                  account.
                </>
              ) : (
                <>
                  New here?{" "}
                  <a href={trialCta.href}>{trialCta.label}</a>
                  — 20 batches, no credit card.
                </>
              )
            }
          </p>
        </div>
      </div>

      <footer class="ox-dl-footer">
        <div class="ox-shell ox-dl-footer-inner">
          <span>© {year} First Crack</span>
          <nav aria-label="Footer">
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
            <a href="mailto:contact@firstcrackiscoming.com">Contact</a>
          </nav>
        </div>
      </footer>
    </main>

    <script>
      function detectOS() {
        const platform = window.navigator.platform.toLowerCase();
        const userAgent = window.navigator.userAgent.toLowerCase();

        let os: string | null = null;

        if (platform.includes("mac") || userAgent.includes("mac")) {
          os = "macos";
        } else if (platform.includes("win") || userAgent.includes("win")) {
          os = "windows";
        }

        if (os) {
          const card = document.getElementById(`download-${os}`);
          const badge = document.getElementById(`badge-${os}`);
          card?.classList.add("is-recommended");
          if (badge) badge.hidden = false;
        }
      }

      detectOS();
    </script>
  </body>
</html>

<style is:global>
  body.ox {
    --ox-bg: #fafaf9;
    --ox-fg: #080503;
    --ox-muted: #5e534a;
    --ox-muted-bg: #ecebe7;
    --ox-border: rgba(8, 5, 3, 0.06);
    --ox-border-strong: rgba(8, 5, 3, 0.12);
    --ox-sans: "Instrument Sans", system-ui, -apple-system, sans-serif;
    --ox-mono: "JetBrains Mono", ui-monospace, monospace;
    --ox-max: 1400px;
    --ox-pad: 24px;

    margin: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.ox *,
  body.ox *::before,
  body.ox *::after {
    box-sizing: border-box;
  }

  body.ox a {
    color: inherit;
    text-decoration: none;
  }

  .ox-shell {
    max-width: var(--ox-max);
    margin-inline: auto;
    padding-inline: var(--ox-pad);
  }

  .ox-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 0;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      opacity 0.2s ease;
    white-space: nowrap;
  }

  .ox-btn-sm {
    height: 32px;
    padding: 0 20px;
    font-size: 13px;
  }

  .ox-btn-block {
    width: 100%;
    height: 48px;
    font-size: 15px;
  }

  body.ox a.ox-btn-solid,
  body.ox .ox-btn-solid {
    background: var(--ox-fg);
    color: #fff;
    border-color: var(--ox-fg);
  }

  body.ox a.ox-btn-solid:hover,
  body.ox .ox-btn-solid:hover {
    opacity: 0.9;
  }

  .ox-btn-outline {
    background: transparent;
    color: var(--ox-fg);
    border-color: var(--ox-border-strong);
  }

  .ox-btn-outline:hover {
    background: rgba(8, 5, 3, 0.03);
    border-color: rgba(8, 5, 3, 0.28);
  }

  .ox-brand-name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ox-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--ox-mono);
    font-size: 13px;
    color: var(--ox-muted);
    margin-bottom: 20px;
  }

  .ox-line {
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(8, 5, 3, 0.3);
    flex-shrink: 0;
  }

  .noise-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ox-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    background-image:
      linear-gradient(var(--ox-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ox-border) 1px, transparent 1px);
    background-size: 12.5% 12.5%;
  }

  .ox-auth-header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--ox-border);
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(16px);
  }

  .ox-auth-nav {
    max-width: var(--ox-max);
    margin: 0 auto;
    padding: 0 var(--ox-pad);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .ox-auth-nav-end {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ox-nav-signin {
    display: none;
    font-size: 14px;
    color: rgba(8, 5, 3, 0.7);
    transition: color 0.25s ease;
  }

  .ox-nav-signin:hover {
    color: var(--ox-fg);
  }

  .ox-auth-email {
    display: none;
    font-size: 12px;
    color: var(--ox-muted);
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .ox-nav-signin,
    .ox-auth-email {
      display: inline;
    }
  }

  .ox-dl {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ox-dl-main {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    padding: 48px 0 64px;
  }

  .ox-dl-inner {
    width: 100%;
  }

  .ox-dl-head {
    max-width: 36rem;
    margin-bottom: 48px;
  }

  .ox-dl-title {
    margin: 0 0 16px;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .ox-dl-lead {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-dl-grid {
    display: grid;
    gap: 16px;
    max-width: 880px;
  }

  @media (min-width: 768px) {
    .ox-dl-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  .ox-dl-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 32px 28px;
    border: 1px solid var(--ox-border);
    background: #fff;
    transition: border-color 0.2s ease;
  }

  .ox-dl-card.is-recommended {
    border-color: var(--ox-fg);
  }

  .ox-dl-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    font-family: var(--ox-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--ox-fg);
    color: #fff;
    padding: 4px 10px;
  }

  .ox-dl-tag {
    display: block;
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ox-muted);
    margin-bottom: 12px;
  }

  .ox-dl-card-top h2 {
    margin: 0 0 8px;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  .ox-dl-card-top p {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ox-muted);
  }

  .ox-dl-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: auto;
  }

  .ox-dl-note {
    margin: 4px 0 0;
    text-align: center;
    font-family: var(--ox-mono);
    font-size: 11px;
    color: var(--ox-muted);
  }

  .ox-dl-fine {
    margin: 32px 0 0;
    font-size: 14px;
    color: var(--ox-muted);
  }

  .ox-dl-fine a {
    color: var(--ox-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ox-dl-fine a:hover {
    opacity: 0.75;
  }

  .ox-dl-footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--ox-border);
    padding: 24px 0;
  }

  .ox-dl-footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 13px;
    color: var(--ox-muted);
  }

  .ox-dl-footer-inner nav {
    display: flex;
    gap: 20px;
  }

  .ox-dl-footer-inner a:hover {
    color: var(--ox-fg);
  }

  @media (min-width: 1024px) {
    body.ox {
      --ox-pad: 48px;
    }
  }
</style>