---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
import { createClient } from "../lib/supabase";
import { safeRedirectPath } from "../lib/safeRedirect";

const supabaseServer = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const next = safeRedirectPath(Astro.url.searchParams.get("next"));

const { data: { user } } = await supabaseServer.auth.getUser();

if (user) {
  return Astro.redirect(next);
}
const signupHref =
  next !== "/"
    ? `/signup?next=${encodeURIComponent(next)}`
    : "/signup";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Sign in to First Crack — roast profiling and production software for specialty coffee roasteries."
    />
    <title>Sign in — First Crack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-auth noise-overlay">
      <div class="ox-grid-bg" aria-hidden="true"></div>

      <header class="ox-auth-header">
        <nav class="ox-auth-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>
          <div class="ox-auth-nav-end">
            <span class="ox-auth-hint">No account?</span>
            <a href={signupHref} class="ox-btn ox-btn-solid ox-btn-sm">
              Start trial
            </a>
          </div>
        </nav>
      </header>

      <div class="ox-auth-main">
        <div class="ox-auth-card">
          <div class="ox-auth-head">
            <div class="ox-eyebrow">
              <span class="ox-line"></span>
              Account
            </div>
            <h1 class="ox-auth-title">Sign in</h1>
            <p class="ox-auth-lead">
              Desktop roasting software for the floor — pick up where you left off.
            </p>
          </div>

          <button id="google-btn" class="ox-btn ox-btn-outline ox-btn-block ox-google-btn" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"></path>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"></path>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"></path>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"></path>
            </svg>
            Continue with Google
          </button>

          <div class="ox-auth-divider" aria-hidden="true">
            <span>or</span>
          </div>

          <form id="login-form" class="ox-auth-form">
            <div class="ox-field">
              <label for="email">Email</label>
              <input
                id="email"
                type="email"
                name="email"
                class="ox-input"
                placeholder="you@roastery.com"
                autocomplete="email"
                required
              />
            </div>

            <div class="ox-field">
              <label for="password">Password</label>
              <input
                id="password"
                type="password"
                name="password"
                class="ox-input"
                placeholder="Your password"
                autocomplete="current-password"
                required
              />
            </div>

            <p id="error-msg" class="ox-auth-error" hidden></p>

            <button type="submit" id="submit-btn" class="ox-btn ox-btn-solid ox-btn-block">
              Sign in
            </button>
          </form>

          <p class="ox-auth-foot">
            New here?
            <a href={signupHref}>Create an account</a>
          </p>
        </div>
      </div>
    </main>

    <script>
      import { createBrowserClient } from "@supabase/ssr";
      import { safeRedirectPath, webAuthCallbackUrl } from "../lib/safeRedirect";

      const supabase = createBrowserClient(
        import.meta.env.PUBLIC_SUPABASE_URL!,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY!,
      );

      const urlParams = new URLSearchParams(window.location.search);
      const nextUrl = safeRedirectPath(urlParams.get("next"));
      // Prefer tab origin so redirectTo matches the domain the user is on;
      // must be listed in Supabase Redirect URLs (Site URL must stay HTTPS).
      const redirectTo = webAuthCallbackUrl(window.location.origin, nextUrl);

      document.getElementById("google-btn")?.addEventListener("click", async () => {
        clearMessages();
        const { data, error } = await supabase.auth.signInWithOAuth({
          provider: "google",
          options: {
            redirectTo,
          },
        });

        if (error) {
          showError("Google sign-in failed: " + error.message);
          return;
        }

        if (data?.url) window.location.href = data.url;
      });

      document.getElementById("login-form")?.addEventListener("submit", async (e) => {
        e.preventDefault();
        clearMessages();

        const email = (document.getElementById("email") as HTMLInputElement).value;
        const password = (document.getElementById("password") as HTMLInputElement).value;
        const btn = document.getElementById("submit-btn") as HTMLButtonElement;

        btn.disabled = true;
        btn.textContent = "Signing in…";

        const { error } = await supabase.auth.signInWithPassword({ email, password });

        btn.disabled = false;
        btn.textContent = "Sign in";

        if (error) {
          showError(error.message);
        } else {
          window.location.href = nextUrl;
        }
      });

      function showError(msg: string) {
        const el = document.getElementById("error-msg")!;
        el.textContent = msg;
        el.hidden = false;
      }

      function clearMessages() {
        const el = document.getElementById("error-msg")!;
        el.textContent = "";
        el.hidden = true;
      }
    </script>
  </body>
</html>

<style is:global>
  body.ox {
    --ox-bg: #fafaf9;
    --ox-fg: #080503;
    --ox-muted: #5e534a;
    --ox-muted-bg: #ecebe7;
    --ox-border: rgba(8, 5, 3, 0.06);
    --ox-border-strong: rgba(8, 5, 3, 0.12);
    --ox-sans: "Instrument Sans", system-ui, -apple-system, sans-serif;
    --ox-mono: "JetBrains Mono", ui-monospace, monospace;
    --ox-max: 1400px;
    --ox-pad: 24px;

    margin: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.ox *,
  body.ox *::before,
  body.ox *::after {
    box-sizing: border-box;
  }

  body.ox a {
    color: inherit;
    text-decoration: none;
  }

  body.ox button {
    font-family: inherit;
    cursor: pointer;
  }

  .ox-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 0;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      opacity 0.2s ease;
    white-space: nowrap;
  }

  .ox-btn-sm {
    height: 32px;
    padding: 0 20px;
    font-size: 13px;
  }

  .ox-btn-block {
    width: 100%;
    height: 48px;
    font-size: 15px;
  }

  body.ox a.ox-btn-solid,
  body.ox .ox-btn-solid {
    background: var(--ox-fg);
    color: #fff;
    border-color: var(--ox-fg);
  }

  body.ox a.ox-btn-solid:hover,
  body.ox .ox-btn-solid:hover {
    opacity: 0.9;
  }

  .ox-btn-outline {
    background: transparent;
    color: var(--ox-fg);
    border-color: var(--ox-border-strong);
  }

  .ox-btn-outline:hover {
    background: rgba(8, 5, 3, 0.03);
    border-color: rgba(8, 5, 3, 0.28);
  }

  .ox-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .ox-brand-name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ox-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--ox-mono);
    font-size: 13px;
    color: var(--ox-muted);
    margin-bottom: 20px;
  }

  .ox-line {
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(8, 5, 3, 0.3);
    flex-shrink: 0;
  }

  .noise-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ox-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    background-image:
      linear-gradient(var(--ox-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ox-border) 1px, transparent 1px);
    background-size: 12.5% 12.5%;
  }

  .ox-auth {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ox-auth-header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--ox-border);
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(16px);
  }

  .ox-auth-nav {
    max-width: var(--ox-max);
    margin: 0 auto;
    padding: 0 var(--ox-pad);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .ox-auth-nav-end {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ox-auth-hint {
    display: none;
    font-size: 14px;
    color: var(--ox-muted);
  }

  @media (min-width: 640px) {
    .ox-auth-hint {
      display: inline;
    }
  }

  .ox-auth-main {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px var(--ox-pad) 64px;
  }

  .ox-auth-card {
    width: 100%;
    max-width: 420px;
    padding: 40px 32px;
    border: 1px solid var(--ox-border);
    background: #fff;
  }

  @media (min-width: 640px) {
    .ox-auth-card {
      padding: 48px 40px;
    }
  }

  .ox-auth-head {
    margin-bottom: 32px;
  }

  .ox-auth-title {
    margin: 0 0 12px;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .ox-auth-lead {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ox-muted);
  }

  .ox-google-btn {
    margin-bottom: 24px;
  }

  .ox-auth-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-auth-divider::before,
  .ox-auth-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--ox-border);
  }

  .ox-auth-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ox-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ox-field label {
    font-size: 13px;
    font-weight: 500;
    color: rgba(8, 5, 3, 0.75);
  }

  .ox-input {
    width: 100%;
    height: 48px;
    padding: 0 14px;
    border: 1px solid var(--ox-border-strong);
    border-radius: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 15px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .ox-input::placeholder {
    color: rgba(94, 83, 74, 0.55);
  }

  .ox-input:focus {
    outline: none;
    border-color: var(--ox-fg);
    background: #fff;
  }

  .ox-auth-error {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: #b42318;
    text-align: center;
  }

  .ox-auth-foot {
    margin: 28px 0 0;
    text-align: center;
    font-size: 14px;
    color: var(--ox-muted);
  }

  .ox-auth-foot a {
    color: var(--ox-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ox-auth-foot a:hover {
    opacity: 0.75;
  }

  @media (min-width: 1024px) {
    body.ox {
      --ox-pad: 48px;
    }
  }
</style>