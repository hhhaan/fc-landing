---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";

const year = new Date().getFullYear();

const jobs = [
  {
    href: "/careers/full-stack-engineer",
    title: "Full-Stack Engineer",
    dept: "Engineering",
    deptKey: "engineering",
    loc: "Seoul (Hybrid) · Remote Asia",
    locKey: "seoul hybrid remote asia",
    type: "Full-time",
  },
  {
    href: "/careers/forward-deployed-engineer",
    title: "Forward Deployed Engineer",
    dept: "Engineering · FDE",
    deptKey: "engineering fde",
    loc: "Seoul + APAC travel",
    locKey: "seoul travel apac",
    type: "Full-time",
  },
  {
    href: "/careers/product-designer",
    title: "Product Designer",
    dept: "Design",
    deptKey: "design",
    loc: "Seoul (Hybrid)",
    locKey: "seoul hybrid",
    type: "Full-time",
  },
  {
    href: "/careers/sales-lead",
    title: "Sales Lead, Korea & Japan",
    dept: "Go-to-Market",
    deptKey: "gtm sales",
    loc: "Seoul / Remote (KR·JP)",
    locKey: "seoul remote korea japan",
    type: "Full-time",
  },
] as const;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Careers at First Crack — join the team building roasting software for specialty coffee."
    />
    <title>Careers — First Crack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-careers noise-overlay">
      <div class="ox-grid-bg" aria-hidden="true"></div>

      <header class="ox-auth-header">
        <nav class="ox-auth-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>
          <div class="ox-auth-nav-end">
            <a href="/" class="ox-utility-link">Home</a>
            <a href="/about" class="ox-utility-link">About</a>
            <a href="/careers" class="ox-utility-link is-active">Careers</a>
          </div>
        </nav>
      </header>

      <section class="ox-careers-hero">
        <div class="ox-shell ox-careers-hero-inner">
          <div class="ox-eyebrow">
            <span class="ox-line"></span>
            Careers
          </div>
          <h1 class="ox-careers-title">Build the future of coffee roasting</h1>
          <p class="ox-careers-lead">
            We're a small team based in Seoul, shipping desktop software that specialty roasters rely on every production day. Hybrid in-office weeks, remote-friendly across Asia, and weekly releases to the roast floor.
          </p>
          <dl class="ox-careers-facts">
            <div>
              <dt>HQ</dt>
              <dd>Seoul, Korea</dd>
            </div>
            <div>
              <dt>Work model</dt>
              <dd>Hybrid · Remote Asia</dd>
            </div>
            <div>
              <dt>Open roles</dt>
              <dd>{jobs.length}</dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="ox-careers-jobs">
        <div class="ox-shell">
          <div class="ox-careers-filters">
            <div class="ox-field ox-field-inline">
              <label for="filter-dept">Team</label>
              <select id="filter-dept" class="ox-select">
                <option value="">All teams</option>
                <option value="engineering">Engineering</option>
                <option value="fde">FDE</option>
                <option value="design">Design</option>
                <option value="gtm">Go-to-Market</option>
              </select>
            </div>
            <div class="ox-field ox-field-inline">
              <label for="filter-loc">Location</label>
              <select id="filter-loc" class="ox-select">
                <option value="">All locations</option>
                <option value="seoul">Seoul</option>
                <option value="hybrid">Hybrid</option>
                <option value="remote">Remote</option>
                <option value="travel">Travel</option>
              </select>
            </div>
            <div class="ox-field ox-field-inline ox-field-grow">
              <label for="filter-search">Search</label>
              <input type="text" id="filter-search" class="ox-input" placeholder="Search roles…" />
            </div>
          </div>

          <div class="ox-jobs-head" aria-hidden="true">
            <div class="ox-jobs-col ox-jobs-col-title">Position</div>
            <div class="ox-jobs-col ox-jobs-col-dept">Team</div>
            <div class="ox-jobs-col ox-jobs-col-loc">Location</div>
            <div class="ox-jobs-col ox-jobs-col-type">Type</div>
          </div>

          <div class="ox-jobs-list" id="job-list">
            {
              jobs.map((job) => (
                <a
                  href={job.href}
                  class="ox-jobs-row"
                  data-dept={job.deptKey}
                  data-loc={job.locKey}
                >
                  <div class="ox-jobs-col ox-jobs-col-title">{job.title}</div>
                  <div class="ox-jobs-col ox-jobs-col-dept">{job.dept}</div>
                  <div class="ox-jobs-col ox-jobs-col-loc">{job.loc}</div>
                  <div class="ox-jobs-col ox-jobs-col-type">{job.type}</div>
                </a>
              ))
            }
          </div>

          <p class="ox-jobs-count" id="jobs-count">Showing {jobs.length} of {jobs.length} roles</p>
        </div>
      </section>

      <section class="ox-careers-benefits">
        <div class="ox-shell">
          <div class="ox-careers-benefits-head">
            <h2 class="ox-h2">Benefits &amp; perks</h2>
            <p class="ox-careers-benefits-lead">
              Standard package for full-time roles in Korea, plus remote-friendly equivalents for Asia-based teammates.
            </p>
          </div>
          <div class="ox-benefits-grid">
            <article class="ox-benefit-card">
              <h3>Compensation</h3>
              <ul>
                <li>Market-rate salary by level and location (reviewed annually)</li>
                <li>Meaningful equity (stock options) for every full-time hire</li>
                <li>13th-month bonus eligibility after first year</li>
              </ul>
            </article>
            <article class="ox-benefit-card">
              <h3>Health &amp; time off</h3>
              <ul>
                <li>Four major social insurances (Korea-based employees)</li>
                <li>Private health insurance for employee + spouse/partner</li>
                <li>15+ days paid leave + public holidays; flexible sick days</li>
              </ul>
            </article>
            <article class="ox-benefit-card">
              <h3>Work setup</h3>
              <ul>
                <li>MacBook Pro + monitor of choice on day one</li>
                <li>Hybrid: 2–3 days/week in Seoul HQ when local</li>
              </ul>
            </article>
            <article class="ox-benefit-card">
              <h3>Growth &amp; craft</h3>
              <ul>
                <li>AI tooling credits (Cursor, Claude, etc.) covered</li>
                <li>Onboarding roast workshop + ongoing green-coffee allowance</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section class="ox-careers-why">
        <div class="ox-shell ox-careers-why-inner">
          <h2 class="ox-h2">How we work</h2>
          <div class="ox-why-grid">
            <article class="ox-why-card">
              <h3>Core overlap, not core hours</h3>
              <p>Async by default. We protect a daily KST overlap for design/eng syncs; the rest of the day is yours to deep-work.</p>
            </article>
            <article class="ox-why-card">
              <h3>Ship every week</h3>
              <p>No six-month roadmaps locked in stone. Features go from PR to production floor in days — with real roaster feedback.</p>
            </article>
            <article class="ox-why-card">
              <h3>Craft is the product</h3>
              <p>Every hire spends time on a roaster. You build tools for a craft you've stood next to, not only read about.</p>
            </article>
            <article class="ox-why-card">
              <h3>Small team, high ownership</h3>
              <p>~8 people. You own surfaces end-to-end — no ticket factory, no four-layer approval chains.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="ox-careers-cta">
        <div class="ox-shell ox-careers-cta-inner">
          <h2 class="ox-h2 ox-h2-on-dark">Don't see your role?</h2>
          <p class="ox-careers-cta-lead">
            We hire for people, not only open reqs. Send a short note and resume — if there's a fit, we'll open a conversation.
          </p>
          <a href="mailto:careers@firstcrackiscoming.com" class="ox-btn ox-btn-solid ox-btn-lg ox-btn-inverted">
            Email careers@
          </a>
        </div>
      </section>

      <footer class="ox-utility-footer">
        <div class="ox-shell ox-utility-footer-inner">
          <span>© {year} First Crack</span>
          <nav aria-label="Footer">
            <a href="/about">About</a>
            <a href="/careers">Careers</a>
            <a href="/privacy">Privacy</a>
            <a href="mailto:contact@firstcrackiscoming.com">Contact</a>
          </nav>
        </div>
      </footer>
    </main>

    <script>
      const dept = document.getElementById("filter-dept") as HTMLSelectElement;
      const loc = document.getElementById("filter-loc") as HTMLSelectElement;
      const search = document.getElementById("filter-search") as HTMLInputElement;
      const rows = document.querySelectorAll(".ox-jobs-row") as NodeListOf<HTMLElement>;
      const count = document.getElementById("jobs-count")!;

      function filter() {
        const d = dept.value;
        const l = loc.value;
        const q = search.value.toLowerCase();
        let visible = 0;
        rows.forEach((row) => {
          const rd = row.dataset.dept || "";
          const rl = row.dataset.loc || "";
          const title = row.querySelector(".ox-jobs-col-title")?.textContent?.toLowerCase() || "";
          const deptText = row.querySelector(".ox-jobs-col-dept")?.textContent?.toLowerCase() || "";
          const locText = row.querySelector(".ox-jobs-col-loc")?.textContent?.toLowerCase() || "";
          const show =
            (!d || rd.includes(d)) &&
            (!l || rl.includes(l)) &&
            (!q || title.includes(q) || deptText.includes(q) || locText.includes(q));
          row.style.display = show ? "" : "none";
          if (show) visible++;
        });
        count.textContent = `Showing ${visible} of ${rows.length} roles`;
      }

      dept.addEventListener("change", filter);
      loc.addEventListener("change", filter);
      search.addEventListener("input", filter);
    </script>
  </body>
</html>

<style is:global>
  body.ox {
    --ox-bg: #fafaf9;
    --ox-fg: #080503;
    --ox-muted: #5e534a;
    --ox-muted-bg: #ecebe7;
    --ox-border: rgba(8, 5, 3, 0.06);
    --ox-border-strong: rgba(8, 5, 3, 0.12);
    --ox-sans: "Instrument Sans", system-ui, -apple-system, sans-serif;
    --ox-mono: "JetBrains Mono", ui-monospace, monospace;
    --ox-max: 1400px;
    --ox-pad: 24px;

    margin: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.ox *,
  body.ox *::before,
  body.ox *::after {
    box-sizing: border-box;
  }

  body.ox a {
    color: inherit;
    text-decoration: none;
  }

  body.ox button {
    font-family: inherit;
    cursor: pointer;
  }

  .ox-shell {
    max-width: var(--ox-max);
    margin-inline: auto;
    padding-inline: var(--ox-pad);
  }

  .ox-brand-name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ox-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--ox-mono);
    font-size: 13px;
    color: var(--ox-muted);
    margin-bottom: 20px;
  }

  .ox-line {
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(8, 5, 3, 0.3);
    flex-shrink: 0;
  }

  .ox-h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin: 0 0 40px;
  }

  .ox-h2-on-dark {
    color: var(--ox-bg);
  }

  .ox-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 0;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .ox-btn-lg {
    height: 48px;
    padding: 0 28px;
    font-size: 15px;
  }

  body.ox a.ox-btn-solid,
  body.ox .ox-btn-solid {
    background: var(--ox-fg);
    color: #fff;
    border-color: var(--ox-fg);
  }

  body.ox a.ox-btn-solid:hover,
  body.ox .ox-btn-solid:hover {
    opacity: 0.9;
  }

  .ox-btn-inverted {
    background: var(--ox-bg) !important;
    color: var(--ox-fg) !important;
    border-color: var(--ox-bg) !important;
  }

  .noise-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ox-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    background-image:
      linear-gradient(var(--ox-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ox-border) 1px, transparent 1px);
    background-size: 12.5% 12.5%;
  }

  .ox-auth-header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--ox-border);
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(16px);
  }

  .ox-auth-nav {
    max-width: var(--ox-max);
    margin: 0 auto;
    padding: 0 var(--ox-pad);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .ox-auth-nav-end {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ox-utility-link {
    font-size: 14px;
    color: rgba(8, 5, 3, 0.7);
    transition: color 0.2s ease;
  }

  .ox-utility-link:hover,
  .ox-utility-link.is-active {
    color: var(--ox-fg);
  }

  .ox-utility-link.is-active {
    font-weight: 500;
  }

  .ox-careers {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ox-careers-hero {
    position: relative;
    z-index: 2;
    padding: 56px 0 40px;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-careers-hero-inner {
    max-width: 42rem;
  }

  .ox-careers-title {
    margin: 0 0 16px;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .ox-careers-lead {
    margin: 0 0 28px;
    font-size: 17px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-careers-facts {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin: 0;
    padding-top: 24px;
    border-top: 1px solid var(--ox-border);
  }

  .ox-careers-facts dt {
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
    margin-bottom: 6px;
  }

  .ox-careers-facts dd {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .ox-careers-jobs {
    position: relative;
    z-index: 2;
    padding: 40px 0 64px;
  }

  .ox-careers-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ox-field-inline {
    min-width: 160px;
  }

  .ox-field-grow {
    flex: 1;
    min-width: 200px;
  }

  .ox-field label {
    font-family: var(--ox-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-input,
  .ox-select {
    height: 44px;
    padding: 0 14px;
    border: 1px solid var(--ox-border-strong);
    border-radius: 0;
    background: #fff;
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 14px;
    transition: border-color 0.2s ease;
  }

  .ox-select {
    padding-right: 36px;
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 5L6 8L9 5' stroke='%235e534a' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
  }

  .ox-input:focus,
  .ox-select:focus {
    outline: none;
    border-color: var(--ox-fg);
  }

  .ox-input::placeholder {
    color: rgba(94, 83, 74, 0.55);
  }

  .ox-jobs-head {
    display: grid;
    grid-template-columns: 2fr 1fr 1.4fr 0.7fr;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-jobs-head .ox-jobs-col {
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-jobs-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1.4fr 0.7fr;
    gap: 16px;
    padding: 18px 0;
    border-bottom: 1px solid var(--ox-border);
    transition: background 0.15s ease;
  }

  .ox-jobs-row:hover {
    background: rgba(8, 5, 3, 0.02);
  }

  .ox-jobs-col-title {
    font-weight: 600;
    font-size: 15px;
  }

  .ox-jobs-col-dept {
    font-size: 14px;
    color: var(--ox-muted);
  }

  .ox-jobs-col-loc {
    font-size: 14px;
    color: rgba(94, 83, 74, 0.85);
  }

  .ox-jobs-col-type {
    font-size: 13px;
    color: var(--ox-muted);
  }

  .ox-jobs-count {
    margin: 16px 0 0;
    font-family: var(--ox-mono);
    font-size: 12px;
    color: var(--ox-muted);
  }

  .ox-careers-benefits {
    position: relative;
    z-index: 2;
    padding: 80px 0;
    border-top: 1px solid var(--ox-border);
    background: #fff;
  }

  .ox-careers-benefits-head {
    max-width: 36rem;
    margin-bottom: 8px;
  }

  .ox-careers-benefits-head .ox-h2 {
    margin-bottom: 12px;
  }

  .ox-careers-benefits-lead {
    margin: 0 0 40px;
    font-size: 16px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .ox-benefit-card {
    padding: 28px;
    border: 1px solid var(--ox-border);
    background: var(--ox-bg);
  }

  .ox-benefit-card h3 {
    margin: 0 0 16px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .ox-benefit-card ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ox-benefit-card li {
    position: relative;
    padding-left: 16px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ox-muted);
  }

  .ox-benefit-card li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.45;
  }

  .ox-careers-why {
    position: relative;
    z-index: 2;
    padding: 80px 0;
    border-top: 1px solid var(--ox-border);
  }

  .ox-why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .ox-why-card {
    padding: 28px;
    border: 1px solid var(--ox-border);
    background: #fff;
  }

  .ox-why-card h3 {
    margin: 0 0 8px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .ox-why-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-careers-cta {
    position: relative;
    z-index: 2;
    padding: 80px 0;
    background: var(--ox-fg);
    color: var(--ox-bg);
  }

  .ox-careers-cta-inner {
    max-width: 36rem;
  }

  .ox-careers-cta-lead {
    margin: 0 0 28px;
    font-size: 17px;
    line-height: 1.65;
    color: rgba(250, 250, 249, 0.55);
  }

  .ox-utility-footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--ox-border);
    padding: 24px 0;
  }

  .ox-utility-footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
