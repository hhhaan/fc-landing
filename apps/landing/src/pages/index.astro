---
import "../styles/global.css";
import { createClient } from "../lib/supabase";

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const { data: { user } } = await supabase.auth.getUser();
const isLoggedIn = !!user;
const userEmail = user?.email;
---

<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="First Crack — 로스터를 위한 스마트 로스팅 플랫폼. 프로파일 관리부터 품질 분석까지." />
    <title>First Crack — 로스팅 SaaS</title>
  </head>
  <body>

    <!-- ============================================================
         NAV
         ============================================================ -->
    <header class="nav">
      <div class="nav-inner">
        <!-- Logo -->
        <a href="/" class="nav-logo">
          <span class="nav-logo-text">First Crack</span>
        </a>

        <!-- Center links -->
        <nav class="nav-links" aria-label="주요 메뉴">
          <a href="#product" class="nav-link">Product</a>
          <a href="#pricing" class="nav-link">Pricing</a>
          <a href="#docs" class="nav-link">Docs</a>
          <a href="#about" class="nav-link">About</a>
          <a href="#machines" class="nav-link">Machines</a>
          <a href="/download" class="nav-link">Download</a>
        </nav>

        <!-- Right CTAs -->
        <div class="nav-actions">
          {isLoggedIn ? (
            <!-- 로그인 상태 -->
            <div class="flex items-center gap-4">
              <span class="text-sm text-fg-secondary hidden md:inline">
                {userEmail}
              </span>
              <a href="/dashboard" class="btn btn-nav-signup">Dashboard</a>
              <form action="/auth/signout" method="POST" class="inline">
                <button type="submit" class="btn btn-nav-signup">
                  Log out
                </button>
              </form>
            </div>
          ) : (
            <div class="flex items-center gap-3">
              <a href="/login" class="btn btn-nav-ghost">Log in</a>
              <a href="/signup" class="btn btn-nav-signup">Sign up</a>
            </div>
          )}
        </div>
        <!-- Mobile hamburger -->
        <button class="nav-hamburger" aria-label="메뉴 열기" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <main>

      <!-- ============================================================
           HERO
           ============================================================ -->
      <section class="hero" id="hero">
        <div class="container hero-inner">
          <!-- Eyebrow tag -->
          <div class="hero-eyebrow">
            <span class="badge">Roasting Intelligence</span>
          </div>

          <!-- Headline -->
          <h1 class="text-display-hero hero-headline">
            원두의 잠재력을<br />데이터로 꺼내다
          </h1>

          <!-- Subtitle -->
          <p class="text-body-lg hero-subtitle">
            First Crack은 로스터가 더 일관되고, 더 빠르고, 더 맛있게<br class="br-desktop" />
            로스팅할 수 있도록 설계된 스마트 로스팅 플랫폼입니다.
          </p>

          <!-- CTA buttons -->
          <div class="hero-actions">
            <a href="/signup" class="btn btn-primary">무료로 시작하기</a>
            <a href="#demo" class="btn btn-warm">
              데모 보기
            </a>
          </div>

          <!-- Social proof -->
          <p class="hero-social-proof text-caption">
            이미 <strong>1,200+</strong> 로스터가 사용 중
          </p>
        </div>

        <!-- Hero visual placeholder -->
        <div class="hero-visual-wrap">
          <div class="container">
            <div class="hero-visual">
              <div class="hero-visual-inner">
                <!-- Roast curve mock -->
                <div class="roast-chart">
                  <div class="roast-chart-header">
                    <span class="text-micro" style="color: var(--color-fg-muted);">ROAST PROFILE — Ethiopia Yirgacheffe</span>
                    <span class="badge badge-live">Live</span>
                  </div>
                  <div class="roast-curve">
                    <svg viewBox="0 0 600 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <!-- Grid lines -->
                      <line x1="0" y1="40"  x2="600" y2="40"  stroke="#e5e5e5" stroke-width="0.5"/>
                      <line x1="0" y1="80"  x2="600" y2="80"  stroke="#e5e5e5" stroke-width="0.5"/>
                      <line x1="0" y1="120" x2="600" y2="120" stroke="#e5e5e5" stroke-width="0.5"/>
                      <!-- Bean temp curve -->
                      <path d="M0,150 C60,148 120,130 180,100 C240,70 300,42 380,22 C440,8 520,4 600,2"
                            stroke="#000000" stroke-width="2" stroke-linecap="round"/>
                      <!-- ROR curve -->
                      <path d="M0,145 C60,120 120,90 170,60 C210,38 260,50 320,55 C380,60 460,62 600,65"
                            stroke="#777169" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="4 3"/>
                      <!-- First crack marker -->
                      <line x1="390" y1="0" x2="390" y2="160" stroke="#4e4e4e" stroke-width="1" stroke-dasharray="3 3"/>
                      <text x="394" y="14" font-size="9" fill="#4e4e4e" font-family="system-ui">1st Crack</text>
                    </svg>
                  </div>
                  <div class="roast-stats">
                    <div class="roast-stat">
                      <span class="roast-stat-label">BT</span>
                      <span class="roast-stat-value">212°C</span>
                    </div>
                    <div class="roast-stat">
                      <span class="roast-stat-label">ROR</span>
                      <span class="roast-stat-value">8.4 °/min</span>
                    </div>
                    <div class="roast-stat">
                      <span class="roast-stat-label">Dev %</span>
                      <span class="roast-stat-value">21.3%</span>
                    </div>
                    <div class="roast-stat">
                      <span class="roast-stat-label">Loss</span>
                      <span class="roast-stat-value">14.2%</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================================
           LOGOS (social proof)
           ============================================================ -->
      <section class="logos-section">
        <div class="container">
          <p class="logos-label text-caption">전국 로스터리가 신뢰합니다</p>
          <div class="logos-row">
            <span class="logo-item">Momos Coffee</span>
            <span class="logo-divider"></span>
            <span class="logo-item">Fritz Coffee</span>
            <span class="logo-divider"></span>
            <span class="logo-item">Namusairo</span>
            <span class="logo-divider"></span>
            <span class="logo-item">Terarosa</span>
            <span class="logo-divider"></span>
            <span class="logo-item">Coffee Libre</span>
          </div>
        </div>
      </section>

      <!-- ============================================================
           FEATURES
           ============================================================ -->
      <section class="features-section" id="product">
        <div class="container">
          <div class="section-header">
            <h2 class="text-display-section">로스팅을 과학으로</h2>
            <p class="text-body-lg section-subtitle">
              데이터 기반 인사이트로 매 배치를 완벽하게 재현합니다.
            </p>
          </div>

          <div class="features-grid">

            <!-- Feature 1 -->
            <div class="feature-card card">
              <div class="feature-card-inner">
                <div class="feature-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                </div>
                <h3 class="text-display-card feature-title">실시간 로스트 프로파일</h3>
                <p class="text-body feature-desc">
                  Bean Temp, ET, ROR을 초 단위로 추적합니다. 과거 프로파일과 오버레이하여 편차를 즉시 파악하세요.
                </p>
              </div>
            </div>

            <!-- Feature 2 -->
            <div class="feature-card card">
              <div class="feature-card-inner">
                <div class="feature-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <h3 class="text-display-card feature-title">프로파일 라이브러리</h3>
                <p class="text-body feature-desc">
                  생두별, 로스터별, 시즌별로 프로파일을 정리합니다. 팀 전체가 같은 레시피로 로스팅하세요.
                </p>
              </div>
            </div>

            <!-- Feature 3 -->
            <div class="feature-card card">
              <div class="feature-card-inner">
                <div class="feature-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 8v4l3 3"/>
                  </svg>
                </div>
                <h3 class="text-display-card feature-title">품질 분석 리포트</h3>
                <p class="text-body feature-desc">
                  배치마다 자동으로 생성되는 품질 리포트. Weight loss, Agtron, 커핑 점수를 한눈에 확인합니다.
                </p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ============================================================
           FEATURE HIGHLIGHT (alternating)
           ============================================================ -->
      <section class="highlight-section" id="demo">
        <div class="container highlight-inner">
          <div class="highlight-text">
            <span class="badge" style="margin-bottom: var(--space-20);">프로파일 관리</span>
            <h2 class="text-display-section highlight-headline">
              배치가 끝나는 순간,<br />분석이 시작됩니다
            </h2>
            <p class="text-body-lg highlight-desc">
              로스팅이 완료되면 First Crack이 자동으로 데이터를 수집하고 이전 배치와 비교합니다. 무엇이 달랐는지, 무엇이 더 나았는지 즉시 알 수 있습니다.
            </p>
            <ul class="highlight-list">
              <li class="highlight-list-item">
                <span class="highlight-check">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="2 7 5.5 10.5 12 3"/>
                  </svg>
                </span>
                <span class="text-body">배치 간 자동 편차 감지</span>
              </li>
              <li class="highlight-list-item">
                <span class="highlight-check">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="2 7 5.5 10.5 12 3"/>
                  </svg>
                </span>
                <span class="text-body">First Crack 포인트 자동 감지</span>
              </li>
              <li class="highlight-list-item">
                <span class="highlight-check">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="2 7 5.5 10.5 12 3"/>
                  </svg>
                </span>
                <span class="text-body">커핑 노트와 프로파일 연결</span>
              </li>
            </ul>
            <div style="margin-top: var(--space-32);">
              <a href="/signup" class="btn btn-primary">지금 시작하기</a>
            </div>
          </div>

          <div class="highlight-visual">
            <div class="highlight-card card-lg">
              <div class="highlight-card-header">
                <span class="text-micro" style="color: var(--color-fg-muted);">BATCH COMPARISON</span>
              </div>
              <div class="batch-rows">
                <div class="batch-row batch-row-active">
                  <div class="batch-info">
                    <span class="text-body-medium">Ethiopia Yirgacheffe</span>
                    <span class="text-caption">오늘 14:23 · 배치 #47</span>
                  </div>
                  <div class="batch-score">
                    <span class="score-num">87.5</span>
                    <span class="score-label text-micro">pts</span>
                  </div>
                </div>
                <div class="batch-row">
                  <div class="batch-info">
                    <span class="text-body-medium">Ethiopia Yirgacheffe</span>
                    <span class="text-caption">어제 11:05 · 배치 #46</span>
                  </div>
                  <div class="batch-score">
                    <span class="score-num" style="color: var(--color-fg-muted);">85.0</span>
                    <span class="score-label text-micro" style="color: var(--color-fg-muted);">pts</span>
                  </div>
                </div>
                <div class="batch-row">
                  <div class="batch-info">
                    <span class="text-body-medium">Guatemala Huehuetenango</span>
                    <span class="text-caption">3일 전 · 배치 #45</span>
                  </div>
                  <div class="batch-score">
                    <span class="score-num" style="color: var(--color-fg-muted);">83.0</span>
                    <span class="score-label text-micro" style="color: var(--color-fg-muted);">pts</span>
                  </div>
                </div>
              </div>
              <div class="batch-delta">
                <span class="text-caption" style="color: var(--color-fg-muted);">전 배치 대비</span>
                <span class="delta-up text-body-medium">+2.5pts</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================================
           PRICING
           ============================================================ -->
      <section class="pricing-section" id="pricing">
        <div class="container">
          <div class="section-header">
            <h2 class="text-display-section">간단한 요금제</h2>
            <p class="text-body-lg section-subtitle">
              로스터리 규모에 맞게 선택하세요.
            </p>
          </div>

          <!-- Billing toggle -->
          <div class="pricing-toggle-wrap">
            <div class="pricing-toggle" role="group" aria-label="결제 주기 선택">
              <button class="toggle-btn toggle-btn-active" id="btn-monthly" aria-pressed="true">Monthly</button>
              <button class="toggle-btn" id="btn-yearly" aria-pressed="false">
                Yearly
                <span class="toggle-save-badge">20% 절약</span>
              </button>
            </div>
          </div>

          <div class="pricing-grid">

            <!-- Starter -->
            <div class="pricing-card card">
              <div class="pricing-card-inner">
                <div class="pricing-tier text-micro">STARTER</div>
                <div class="pricing-amount">
                  <span class="price-num">무료</span>
                </div>
                <p class="text-body pricing-desc">개인 로스터, 취미 로스터에게 적합합니다.</p>
                <ul class="pricing-features">
                  <li class="pricing-feature">월 20배치</li>
                  <li class="pricing-feature">기본 프로파일 저장</li>
                  <li class="pricing-feature">1인 사용</li>
                </ul>
                <a href="/signup" class="btn btn-secondary" style="width: 100%; justify-content: center;">시작하기</a>
              </div>
            </div>

            <!-- Pro 카드 -->
            <div class="pricing-card pricing-card-featured card">
              <div class="pricing-card-inner">
                <div class="pricing-tier text-micro">PRO</div>
                <div class="pricing-amount">
                  <span class="price-num" id="pro-price" data-monthly="$29" data-yearly="$24">$29</span>
                  <span class="price-period text-caption" id="pro-period" data-monthly="/월" data-yearly="/월">/월</span>
                </div>
                <p class="price-yearly-note text-micro" id="pro-yearly-note" hidden>연 $290 청구</p>
                <p class="text-body pricing-desc">소규모 로스터리, 카페 전용 로스터에게.</p>
                <ul class="pricing-features">
                  <li class="pricing-feature">무제한 배치</li>
                  <li class="pricing-feature">고급 분석 및 리포트</li>
                  <li class="pricing-feature">팀 3인까지</li>
                  <li class="pricing-feature">커핑 노트 연동</li>
                </ul>
                
                <!-- 여기 버튼 수정 -->
                <a 
                  id="pro-start-btn"
                  href="/start-pro?plan=monthly" 
                  class="btn btn-primary" 
                  style="width: 100%; justify-content: center;">
                  14일 무료 체험
                </a>
              </div>
            </div>

            <!-- Business -->
            <div class="pricing-card card">
              <div class="pricing-card-inner">
                <div class="pricing-tier text-micro">BUSINESS</div>
                <div class="pricing-amount">
                  <span class="price-num" id="enterprise-price" data-monthly="$59" data-yearly="$49">$59</span>
                  <span class="price-period text-caption" id="enterprise-period" data-monthly="/월" data-yearly="/월">/월</span>
                </div>
                <p class="price-yearly-note text-micro" id="enterprise-yearly-note" hidden>연 $590 청구</p>
                <p class="text-body pricing-desc">대형 로스터리, 멀티 로케이션 운영에.</p>
                <ul class="pricing-features">
                  <li class="pricing-feature">무제한 배치 & 팀</li>
                  <li class="pricing-feature">전용 온보딩</li>
                  <li class="pricing-feature">개인용 납품 판매 채널 제공 수수료 x</li>
                  <li class="pricing-feature">월간 생산 보고서 제공</li>
                </ul>
                <a
                  id="enterprise-start-btn"
                  href="/start-pro?plan=enterprise-monthly"
                  class="btn btn-secondary"
                  style="width: 100%; justify-content: center;">
                  시작하기
                </a>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ============================================================
           CTA BLOCK (warm stone)
           ============================================================ -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-block">
            <h2 class="text-display-section cta-headline">
              첫 번째 크랙, 지금 시작하세요
            </h2>
            <p class="text-body-lg cta-desc">
              무료로 시작하고, 로스팅이 어떻게 달라지는지 경험하세요.
            </p>
            <div class="cta-actions">
              <a href="/signup" class="btn btn-primary">무료로 시작하기</a>
              <a href="/contact" class="btn btn-warm">세일즈팀 문의</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- ============================================================
         FOOTER
         ============================================================ -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="nav-logo-mark" style="color: var(--color-fg-muted);">FC</span>
          <span class="text-caption" style="color: var(--color-fg-muted);">First Crack © 2025</span>
        </div>
        <nav class="footer-links" aria-label="푸터 메뉴">
          <a href="/privacy" class="footer-link text-caption">Privacy</a>
          <a href="/terms" class="footer-link text-caption">Terms</a>
          <a href="/docs" class="footer-link text-caption">Docs</a>
          <a href="mailto:hello@firstcrack.io" class="footer-link text-caption">Contact</a>
        </nav>
      </div>
    </footer>

    <script>
      const btnMonthly = document.getElementById('btn-monthly')!;
      const btnYearly = document.getElementById('btn-yearly')!;
      const proPrice = document.getElementById('pro-price')!;
      const proPeriod = document.getElementById('pro-period')!;
      const proYearlyNote = document.getElementById('pro-yearly-note')!;
      const proStartBtn = document.getElementById('pro-start-btn') as HTMLAnchorElement | null;
      const enterprisePrice = document.getElementById('enterprise-price')!;
      const enterprisePeriod = document.getElementById('enterprise-period')!;
      const enterpriseYearlyNote = document.getElementById('enterprise-yearly-note')!;
      const enterpriseStartBtn = document.getElementById('enterprise-start-btn') as HTMLAnchorElement | null;

      function setBilling(isYearly: boolean) {
        btnMonthly.classList.toggle('toggle-btn-active', !isYearly);
        btnYearly.classList.toggle('toggle-btn-active', isYearly);
        btnMonthly.setAttribute('aria-pressed', String(!isYearly));
        btnYearly.setAttribute('aria-pressed', String(isYearly));

        proPrice.textContent = isYearly ? (proPrice.dataset.yearly ?? '') : (proPrice.dataset.monthly ?? '');
        proPeriod.textContent = isYearly ? (proPeriod.dataset.yearly ?? '') : (proPeriod.dataset.monthly ?? '');
        proYearlyNote.hidden = !isYearly;
        if (proStartBtn) proStartBtn.href = isYearly ? "/start-pro?plan=yearly" : "/start-pro?plan=monthly";

        enterprisePrice.textContent = isYearly ? (enterprisePrice.dataset.yearly ?? '') : (enterprisePrice.dataset.monthly ?? '');
        enterprisePeriod.textContent = isYearly ? (enterprisePeriod.dataset.yearly ?? '') : (enterprisePeriod.dataset.monthly ?? '');
        enterpriseYearlyNote.hidden = !isYearly;
        if (enterpriseStartBtn) enterpriseStartBtn.href = isYearly ? "/start-pro?plan=enterprise-yearly" : "/start-pro?plan=enterprise-monthly";
      }

      btnMonthly.addEventListener('click', () => setBilling(false));
      btnYearly.addEventListener('click', () => setBilling(true));

      setBilling(false);
    </script>
  </body>
</html>

<style>
  /* =====================================================
     PAGE-LEVEL STYLES
     ===================================================== */

  /* --- Nav overrides --- */
  .nav {
    background-color: var(--color-bg);
    color: var(--color-fg);
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    text-decoration: none;
    color: var(--color-fg);
  }
  .nav-logo-mark {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 300;
    letter-spacing: 0.05em;
  }
  .nav-logo-text {
    font-family: var(--font-body);
    font-size: var(--text-nav);
