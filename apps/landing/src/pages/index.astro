---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
import OxNavAuth from "../components/ui/OxNavAuth.astro";
import OxNavAuthMobile from "../components/ui/OxNavAuthMobile.astro";
import OxWorkflowPanel from "../components/ui/OxWorkflowPanel.astro";
import { getViewer } from "../lib/authState";
import { resolveTrialCta } from "../lib/trialCta";

const user = await getViewer(Astro);
const isLoggedIn = !!user;
const trialCta = await resolveTrialCta(Astro);
const year = new Date().getFullYear();

const capabilities = [
  {
    n: "01",
    title: "Commercial-grade records",
    body: "Customers pay for a reproducible roast record. Log BT/ET/RoR and keep every session searchable.",
  },
  {
    n: "02",
    title: "Machine-first, not cloud-first",
    body: "Modbus, Phidget, and Artisan-ready paths. Run on the floor when the network is flaky.",
  },
  {
    n: "03",
    title: "Ops beyond the curve",
    body: "Day plan, green inventory, and production reports — one system from charge to bag.",
  },
  {
    n: "04",
    title: "Clear pricing",
    body: "Pro at $49/mo (200 batches). Pro+ for unlimited + commerce. Enterprise when you need a team and FDE.",
  },
];

const steps = [
  {
    n: "I",
    title: "Connect your machine",
    body: "Pair sensors and controllers. Modbus, Phidget, and Artisan-ready setups are first-class.",
  },
  {
    n: "II",
    title: "Roast with a reference",
    body: "Load a profile, mark events, and ride the curve with live readings on the floor.",
  },
  {
    n: "III",
    title: "Archive and improve",
    body: "Weights, phases, and notes save automatically. Promote winners for the next shift.",
  },
];

const hardware = [
  { tag: "Protocol", name: "Modbus", desc: "Industrial PLC / controller links" },
  { tag: "Sensors", name: "Phidget", desc: "Thermocouple & probe interfaces" },
  { tag: "Ecosystem", name: "Artisan-ready", desc: "Familiar machine configurations" },
  { tag: "Platform", name: "Desktop-native", desc: "macOS & Windows installers" },
];

const marqueeItems = [
  "Live BT / ET / RoR",
  "Profile library",
  "Batch history",
  "Modbus",
  "Phidget",
  "Artisan-ready",
  "Roast planner",
  "Inventory",
  "Production reports",
  "Team sync",
  "macOS",
  "Windows",
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="First Crack — roast profiling and production software for specialty coffee roasteries. Desktop-native. $49/mo Pro." />
    <title>First Crack — Roasting software for specialty coffee</title>
    <link rel="alternate" hreflang="ko" href="/kr" />
    <link rel="alternate" hreflang="en-US" href="/us" />
    <link rel="alternate" hreflang="ja" href="/jp" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-main noise-overlay">
      <!-- ── Header ───────────────────────────────────────── -->
      <header class="ox-header" id="ox-header">
        <div class="ox-scroll-progress" id="ox-scroll-progress" aria-hidden="true"></div>
        <nav class="ox-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>

          <div class="ox-nav-links">
            <a href="#features" class="ox-nav-link" data-section="features">Product</a>
            <a href="#how-it-works" class="ox-nav-link" data-section="how-it-works">How it works</a>
            <a href="#platform" class="ox-nav-link" data-section="platform">Platform</a>
            <a href="#pricing" class="ox-nav-link" data-section="pricing">Pricing</a>
          </div>

          <div class="ox-nav-end">
            <OxNavAuth user={user} variant="marketing" />
            <button
              type="button"
              class="ox-burger"
              aria-label="Toggle menu"
              aria-expanded="false"
              aria-controls="ox-mobile"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <line class="ox-burger-line" x1="4" y1="6" x2="20" y2="6"></line>
                <line class="ox-burger-line" x1="4" y1="12" x2="20" y2="12"></line>
                <line class="ox-burger-line" x1="4" y1="18" x2="20" y2="18"></line>
              </svg>
            </button>
          </div>
        </nav>

        <div id="ox-mobile" class="ox-mobile">
          <div class="ox-mobile-inner">
            <div class="ox-mobile-links">
              <a href="#features" class="ox-nav-link" data-section="features">Product</a>
              <a href="#how-it-works" class="ox-nav-link" data-section="how-it-works">How it works</a>
              <a href="#platform" class="ox-nav-link" data-section="platform">Platform</a>
              <a href="#pricing" class="ox-nav-link" data-section="pricing">Pricing</a>
              <a href="/download">Download app</a>
            </div>
            <div class="ox-mobile-cta">
              <OxNavAuthMobile user={user} />
            </div>
          </div>
        </div>
      </header>

      <!-- ── Hero ─────────────────────────────────────────── -->
      <section class="ox-hero ox-pane">
        <div class="ox-grid-bg" aria-hidden="true"></div>

        <div class="ox-shell ox-hero-inner">
          <div class="ox-hero-copy">
            <div class="ox-eyebrow reveal">
              <span class="ox-line"></span>
              Desktop roasting software
            </div>

            <h1 class="ox-hero-title reveal reveal-d1">
              <span class="block">Roast with data.</span>
              <span class="block ox-hero-title-muted">Reproduce every batch.</span>
            </h1>

            <p class="ox-hero-lead reveal reveal-d2">
              Live profiles, machine connectivity, and production tools — desktop software for the roast floor, not another browser tab.
            </p>

            <div class="ox-hero-trust reveal reveal-d2">
              <span><strong>$49</strong>/mo Pro</span>
              <span>14-day trial</span>
              <span>No credit card</span>
            </div>

            <div class="ox-hero-actions reveal reveal-d3">
              <a href={trialCta.href} class="ox-btn ox-btn-solid ox-btn-lg ox-hero-cta-primary">
                {trialCta.label}
              </a>
              <a href="/download" class="ox-btn ox-btn-outline ox-btn-lg">
                Download app
              </a>
            </div>

            <p class="ox-hero-fine reveal reveal-d3">
              macOS &amp; Windows · 20 batches included
            </p>
          </div>

          <div class="ox-hero-visual" aria-hidden="true">
            <div class="ox-hero-glow"></div>
            <canvas id="ox-hero-canvas"></canvas>
          </div>
        </div>

        <!-- Stats marquee -->
        <div class="ox-marquee" aria-hidden="true">
          <div class="ox-marquee-track">
            {
              [...marqueeItems, ...marqueeItems].map((item) => (
                <span class="ox-marquee-item">
                  <span class="ox-marquee-dot"></span>
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ── Capabilities ─────────────────────────────────── -->
      <section class="ox-section ox-pane" id="features">
        <div class="ox-shell">
          <div class="ox-section-head">
            <div class="ox-eyebrow reveal">
              <span class="ox-line"></span>
                            Product
            </div>
            <h2 class="ox-h2 reveal">
              Everything on the floor.
              <br />
              <span class="ox-muted">Nothing in the way.</span>
            </h2>
          </div>

          <div class="ox-cap-list">
            {
              capabilities.map((c, i) => (
                <article
                  class="ox-cap reveal"
                  style={`--d: ${i * 60}ms`}
                >
                  <div class="ox-cap-num">{c.n}</div>
                  <div class="ox-cap-body">
                    <h3 class="ox-cap-title">{c.title}</h3>
                    <p class="ox-cap-text">{c.body}</p>
                  </div>
                  <div
                    class="ox-cap-media"
                    role="img"
                    aria-label={`Screenshot placeholder — ${c.title}`}
                  >
                    <span class="ox-ph-label">Screenshot</span>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ── Process (inverted) ───────────────────────────── -->
      <section class="ox-process ox-pane" id="how-it-works">
        <div class="ox-shell">
          <div class="ox-section-head">
            <div class="ox-eyebrow ox-eyebrow-on-dark reveal">
              <span class="ox-line ox-line-on-dark"></span>
              Workflow
            </div>
            <h2 class="ox-h2 ox-h2-on-dark reveal">
              Three steps.
              <br />
              <span class="ox-on-dark-muted">Consistent coffee.</span>
            </h2>
          </div>

          <div class="ox-process-grid">
            <div class="ox-steps">
              {
                steps.map((s, i) => (
                  <button
                    type="button"
                    class:list={["ox-step", i === 0 && "is-active"]}
                    data-step={i}
                  >
                    <span class="ox-step-n">{s.n}</span>
                    <div>
                      <h3 class="ox-step-title">{s.title}</h3>
                      <p class="ox-step-body">{s.body}</p>
                    </div>
                  </button>
                ))
              }
            </div>

            <OxWorkflowPanel />
          </div>
        </div>
      </section>

      <!-- ── Platform ─────────────────────────────────────── -->
      <section class="ox-section ox-pane" id="platform">
        <div class="ox-shell ox-platform">
          <div class="ox-platform-copy">
            <div class="ox-eyebrow reveal">
              <span class="ox-line"></span>
              Platform
            </div>
            <h2 class="ox-h2 reveal">
              Built for the
              <br />
              roast floor.
            </h2>
            <p class="ox-lead reveal">
              A native desktop app with low-latency hardware links — and cloud
              sync when you’re back in the office. Connect the gear you already
              own.
            </p>
            <div class="ox-stats reveal">
              <div>
                <div class="ox-stat-num">macOS</div>
                <div class="ox-stat-label">&amp; Windows</div>
              </div>
              <div>
                <div class="ox-stat-num">Live</div>
                <div class="ox-stat-label">BT · ET · RoR</div>
              </div>
              <div>
                <div class="ox-stat-num">Cloud</div>
                <div class="ox-stat-label">sync included</div>
              </div>
            </div>
            <a href="/download" class="ox-btn ox-btn-solid ox-btn-lg reveal">
              Download desktop app
            </a>
          </div>

          <ul class="ox-hw-list reveal">
            {
              hardware.map((h) => (
                <li class="ox-hw-item">
                  <span class="ox-hw-tag">{h.tag}</span>
                  <strong>{h.name}</strong>
                  <p>{h.desc}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- ── Pricing ──────────────────────────────────────── -->
      <section class="ox-section ox-pricing ox-pane" id="pricing">
        <div class="ox-shell">
          <div class="ox-section-head ox-section-head-center">
            <div class="ox-eyebrow reveal" style="justify-content:center">
              <span class="ox-line"></span>
                            Pricing
            </div>
            <h2 class="ox-h2 reveal">
              Simple pricing
              <br />
              for serious roasters
            </h2>
            <p class="ox-lead ox-lead-center reveal">
              14-day trial (20 batches). Then Pro, Pro+, or talk to us for Enterprise.
            </p>
          </div>

          <div class="ox-bill reveal">
            <div class="ox-bill-toggle" role="group" aria-label="Billing period">
              <button type="button" class="is-active" id="btn-monthly" aria-pressed="true">
                                Monthly
              </button>
              <button type="button" id="btn-yearly" aria-pressed="false">
                Annual <em>Save ~20%</em>
              </button>
            </div>
          </div>

          <div class="ox-price-grid reveal">
            <article class="ox-price-card">
              <div class="ox-price-top">
                <span class="ox-price-n">01</span>
                <h3>Pro</h3>
                <p>Core floor ops — roast, inventory, schedule</p>
              </div>
              <div class="ox-price-amt">
                <span class="ox-price-num" id="pro-price" data-monthly="$49" data-yearly="$39">$49</span>
                <span class="ox-price-per" id="pro-period" data-monthly="/mo" data-yearly="/mo">/mo</span>
              </div>
              <p class="ox-price-note" id="pro-yearly-note" hidden>Billed $468 / year</p>
              <ul>
                <li>200 batches / billing month</li>
                <li>Live roast + history + profiles</li>
                <li>Beans, blends, day plan</li>
                <li>1 seat</li>
                <li>Desktop app (macOS &amp; Windows)</li>
              </ul>
              <a id="pro-start-btn" href="/start-pro?plan=pro-monthly" class="ox-btn ox-btn-outline ox-btn-block" data-href-monthly="/start-pro?plan=pro-monthly" data-href-yearly="/start-pro?plan=pro-yearly">
                Start 14-day trial
              </a>
            </article>

            <article class="ox-price-card is-featured">
              <div class="ox-price-badge">Most popular</div>
              <div class="ox-price-top">
                <span class="ox-price-n">02</span>
                <h3>Pro+</h3>
                <p>Unlimited batches + commerce integrations</p>
              </div>
              <div class="ox-price-amt">
                <span class="ox-price-num" id="proplus-price" data-monthly="$79" data-yearly="$63">$79</span>
                <span class="ox-price-per" id="proplus-period" data-monthly="/mo" data-yearly="/mo">/mo</span>
              </div>
              <p class="ox-price-note" id="proplus-yearly-note" hidden>Billed $756 / year</p>
              <ul>
                <li>Unlimited batches</li>
                <li>Everything in Pro</li>
                <li>Shopify &amp; commerce connectors</li>
                <li>Payment / store sync (roadmap GA)</li>
                <li>1 seat</li>
              </ul>
              <a id="proplus-start-btn" href="/start-pro?plan=pro-plus-monthly" class="ox-btn ox-btn-solid ox-btn-block" data-href-monthly="/start-pro?plan=pro-plus-monthly" data-href-yearly="/start-pro?plan=pro-plus-yearly">
                Start trial
              </a>
            </article>

            <article class="ox-price-card">
              <div class="ox-price-top">
                <span class="ox-price-n">03</span>
                <h3>Enterprise</h3>
                <p>Teams, custom work, dedicated engineer (FDE)</p>
              </div>
              <div class="ox-price-amt">
                <span class="ox-price-num">Contact</span>
              </div>
              <ul>
                <li>Unlimited batches + team seats</li>
                <li>Custom features &amp; FDE support</li>
                <li>From $300/mo + $19/seat</li>
                <li>Priority onboarding</li>
                <li>Contract &amp; invoice options</li>
              </ul>
              <a href="mailto:contact@firstcrackiscoming.com?subject=Enterprise%20inquiry" class="ox-btn ox-btn-outline ox-btn-block">
                Contact sales
              </a>
            </article>
          </div>
        </div>
      </section>

      <!-- ── Final CTA ────────────────────────────────────── -->
      <section class="ox-final">
        <div class="ox-shell ox-final-inner">
          <div>
            <h2 class="ox-h2 ox-final-title reveal">
              Ready when the
              <br />
              green coffee is.
            </h2>
            <p class="ox-lead reveal">
              Install First Crack, connect your machine, and put a reference profile under your next batch.
            </p>
            <div class="ox-hero-actions reveal">
              <a href={trialCta.href} class="ox-btn ox-btn-solid ox-btn-lg">
                {trialCta.label}
              </a>
              <a href="/download" class="ox-btn ox-btn-outline ox-btn-lg">
                Download
              </a>
            </div>
            <p class="ox-hero-fine reveal">No credit card required</p>
          </div>
        </div>
      </section>

      <!-- ── Footer ───────────────────────────────────────── -->
      <footer class="ox-footer">
        <div class="ox-shell">
          <div class="ox-footer-top">
            <div class="ox-footer-brand">
              <a href="/" class="ox-brand">
                <span class="ox-brand-name">First Crack</span>
              </a>
              <p>Roasting software for specialty coffee.</p>
            </div>
              <div class="ox-footer-cols">
              <div>
                <h4>Product</h4>
                <a href="#features">Features</a>
                <a href="#how-it-works">Workflow</a>
                <a href="#pricing">Pricing</a>
                <a href="/download">Download</a>
              </div>
              <div>
                <h4>Company</h4>
                <a href="/about">About</a>
                <a href="/careers">Careers</a>
                <a href="mailto:contact@firstcrackiscoming.com">Contact</a>
              </div>
              <div>
                <h4>Account</h4>
                {
                  isLoggedIn ? (
                    <>
                      <a href="/account">Account</a>
                      <form action="/auth/signout" method="POST" class="ox-footer-signout">
                        <button type="submit">Sign out</button>
                      </form>
                    </>
                  ) : (
                    <>
                      <a href="/login">Log in</a>
                      <a href="/signup">Sign up</a>
                    </>
                  )
                }
              </div>
              <div>
                <h4>Legal</h4>
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
              </div>
            </div>
          </div>
          <div class="ox-footer-bottom">
            <span>© {year} First Crack</span>
            <span>Built for the roast floor</span>
          </div>
        </div>
      </footer>
    </main>

    <script>
      // Header: scroll progress, compact, hide/show, section spy
      const header = document.getElementById("ox-header");
      const progress = document.getElementById("ox-scroll-progress");
      const navLinks = document.querySelectorAll<HTMLAnchorElement>(
        ".ox-nav-link[data-section]",
      );
      const sections = ["features", "how-it-works", "platform", "pricing"]
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      let lastScrollY = window.scrollY;
      const hideThreshold = 40;

      const setActiveSection = (id: string | null) => {
        navLinks.forEach((link) => {
          link.classList.toggle("is-active", link.dataset.section === id);
        });
      };

      const scrollToSection = (id: string) => {
        const section = document.getElementById(id);
        if (!section) return;

        closeMobile();
        document.body.classList.add("is-pane-nav");
        header?.classList.add("is-hidden");
        setActiveSection(id);

        const top = section.offsetTop;
        lastScrollY = window.scrollY;
        window.scrollTo({ top, behavior: "smooth" });
      };

      navLinks.forEach((link) => {
        link.addEventListener("click", (e) => {
          const id = link.dataset.section;
          if (!id) return;
          e.preventDefault();
          scrollToSection(id);
        });
      });

      const onScroll = () => {
        const y = window.scrollY;
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;

        header?.classList.toggle("is-scrolled", y > 20);
        header?.classList.toggle("is-compact", y > 80);

        if (progress && maxScroll > 0) {
          progress.style.transform = `scaleX(${Math.min(1, y / maxScroll)})`;
        }

        if (y <= hideThreshold) {
          document.body.classList.remove("is-pane-nav");
          header?.classList.remove("is-hidden");
        } else if (document.body.classList.contains("is-pane-nav")) {
          header?.classList.add("is-hidden");
        } else {
          header?.classList.toggle("is-hidden", y > lastScrollY);
        }

        lastScrollY = y;
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      if ("IntersectionObserver" in window && sections.length) {
        const visible = new Map<string, number>();
        const spy = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                visible.set(entry.target.id, entry.intersectionRatio);
              } else {
                visible.delete(entry.target.id);
              }
            });

            if (visible.size === 0) return;

            let bestId: string | null = null;
            let bestRatio = 0;
            visible.forEach((ratio, id) => {
              if (ratio > bestRatio) {
                bestRatio = ratio;
                bestId = id;
              }
            });
            setActiveSection(bestId);
          },
          { rootMargin: "-45% 0px -45% 0px", threshold: [0, 0.5, 1] },
        );
        sections.forEach((section) => spy.observe(section));
      }

      // Mobile menu
      const burger = document.querySelector(".ox-burger") as HTMLButtonElement | null;
      const mobile = document.getElementById("ox-mobile");

      const closeMobile = () => {
        burger?.setAttribute("aria-expanded", "false");
        mobile?.classList.remove("is-open");
        header?.classList.remove("is-menu-open");
        document.body.classList.remove("ox-menu-open");
      };

      const openMobile = () => {
        mobile?.classList.add("is-open");
        burger?.setAttribute("aria-expanded", "true");
        header?.classList.add("is-menu-open");
        header?.classList.remove("is-hidden");
        document.body.classList.add("ox-menu-open");
      };

      burger?.addEventListener("click", () => {
        const isOpen = burger.getAttribute("aria-expanded") === "true";
        if (isOpen) closeMobile();
        else openMobile();
      });

      mobile?.querySelectorAll("a:not([data-section])").forEach((a) => {
        a.addEventListener("click", closeMobile);
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && burger?.getAttribute("aria-expanded") === "true") {
          closeMobile();
        }
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 768 && burger?.getAttribute("aria-expanded") === "true") {
          closeMobile();
        }
      });

      // Process step highlight
      document.querySelectorAll(".ox-step").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".ox-step")
            .forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
        });
      });

      // Pricing toggle
      const btnMonthly = document.getElementById("btn-monthly");
      const btnYearly = document.getElementById("btn-yearly");

      function setBilling(isYearly: boolean) {
        if (!btnMonthly || !btnYearly) return;
        btnMonthly.classList.toggle("is-active", !isYearly);
        btnYearly.classList.toggle("is-active", isYearly);
        btnMonthly.setAttribute("aria-pressed", String(!isYearly));
        btnYearly.setAttribute("aria-pressed", String(isYearly));

        document.querySelectorAll(".ox-price-card").forEach((card) => {
          const num = card.querySelector<HTMLElement>(".ox-price-num");
          const per = card.querySelector<HTMLElement>(".ox-price-per");
          const note = card.querySelector<HTMLElement>(".ox-price-note");
          const cta = card.querySelector<HTMLAnchorElement>("a.ox-btn");
          if (num) {
            num.textContent = isYearly
              ? (num.dataset.yearly ?? num.dataset.monthly ?? "")
              : (num.dataset.monthly ?? "");
          }
          if (per) {
            per.textContent = isYearly
              ? (per.dataset.yearly ?? per.dataset.monthly ?? "")
              : (per.dataset.monthly ?? "");
          }
          if (note) note.hidden = !isYearly;
          if (cta) {
            cta.href = isYearly
              ? (cta.dataset.hrefYearly ?? cta.href)
              : (cta.dataset.hrefMonthly ?? cta.href);
          }
        });
      }
      btnMonthly?.addEventListener("click", () => setBilling(false));
      btnYearly?.addEventListener("click", () => setBilling(true));
      setBilling(false);

      // Reveal
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reduce && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -32px 0px" },
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("is-in"));
      }

      // ── Drum cylinder wireframe ───────────────────────────
      {
        const canvas = document.getElementById("ox-hero-canvas") as HTMLCanvasElement | null;
        if (canvas) {
          const ctx = canvas.getContext("2d");
          if (ctx) {
            const dpr = window.devicePixelRatio || 1;
            let W = 0;
            let H = 0;

            function resize() {
              const rect = canvas!.getBoundingClientRect();
              W = rect.width;
              H = rect.height;
              canvas!.width = W * dpr;
              canvas!.height = H * dpr;
              ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
            }
            resize();
            window.addEventListener("resize", resize);

            type Pt3 = { x: number; y: number; z: number };
            type Seg = { a: Pt3; b: Pt3; weight: number };

            const R = 1;
            const HALF_H = 0.72;
            const SEGS = 48;
            const RINGS = [-0.72, -0.24, 0.24, 0.72];
            const MERIDIANS = 8;

            function ringAt(y: number): Pt3[] {
              const pts: Pt3[] = [];
              for (let i = 0; i < SEGS; i++) {
                const t = (i / SEGS) * Math.PI * 2;
                pts.push({ x: Math.cos(t) * R, y, z: Math.sin(t) * R });
              }
              return pts;
            }

            const rings = RINGS.map(ringAt);
            const segments: Seg[] = [];

            for (const ring of rings) {
              for (let i = 0; i < SEGS; i++) {
                segments.push({ a: ring[i], b: ring[(i + 1) % SEGS], weight: 1 });
              }
            }

            for (let m = 0; m < MERIDIANS; m++) {
              const i = Math.floor((m / MERIDIANS) * SEGS);
              segments.push({ a: rings[0][i], b: rings[rings.length - 1][i], weight: 1.25 });
            }

            let angleY = 0.4;
            let angleX = 0.42;
            const speedY = 0.0018;

            function rotate(p: Pt3, ax: number, ay: number): Pt3 {
              let x = p.x * Math.cos(ay) - p.z * Math.sin(ay);
              let z = p.x * Math.sin(ay) + p.z * Math.cos(ay);
              const y = p.y * Math.cos(ax) - z * Math.sin(ax);
              z = p.y * Math.sin(ax) + z * Math.cos(ax);
              return { x, y, z };
            }

            function project(p: Pt3, cx: number, cy: number, scaleR: number) {
              const fov = 4;
              const scale = fov / (fov + p.z);
              return {
                sx: cx + p.x * scaleR * scale,
                sy: cy + p.y * scaleR * scale,
                z: p.z,
              };
            }

            function draw() {
              if (!visible) {
                raf = 0;
                return;
              }
              ctx!.clearRect(0, 0, W, H);

              const cx = W / 2;
              const cy = H * 0.48;
              const scaleR = Math.min(W, H) * 0.4;
              const drawn = segments.map((seg) => {
                const pa = project(rotate(seg.a, angleX, angleY), cx, cy, scaleR);
                const pb = project(rotate(seg.b, angleX, angleY), cx, cy, scaleR);
                return { pa, pb, weight: seg.weight, depth: (pa.z + pb.z) / 2 };
              });
              drawn.sort((a, b) => a.depth - b.depth);

              for (const seg of drawn) {
                const alpha = 0.14 + (seg.depth + 1.2) * 0.22;
                ctx!.strokeStyle = `rgba(8, 5, 3, ${Math.min(0.62, Math.max(0.1, alpha))})`;
                ctx!.lineWidth = seg.weight;
                ctx!.beginPath();
                ctx!.moveTo(seg.pa.sx, seg.pa.sy);
                ctx!.lineTo(seg.pb.sx, seg.pb.sy);
                ctx!.stroke();
              }

              if (!reduce) angleY += speedY;
              raf = requestAnimationFrame(draw);
            }

            let raf = 0;
            let visible = true;
            const heroObs = new IntersectionObserver(
              ([entry]) => {
                visible = entry.isIntersecting;
                if (visible && !raf) raf = requestAnimationFrame(draw);
              },
              { threshold: 0 },
            );
            heroObs.observe(canvas);

            if (!reduce) raf = requestAnimationFrame(draw);
            else draw();
          }
        }
      }
    </script>
