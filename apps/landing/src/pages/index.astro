---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
import { createClient } from "../lib/supabase";

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const {
  data: { user },
} = await supabase.auth.getUser();
const isLoggedIn = !!user;
const userEmail = user?.email;
const year = new Date().getFullYear();

const capabilities = [
  {
    n: "01",
    title: "Commercial-grade records",
    body: "Customers pay for a reproducible roast record. Log BT/ET/RoR and keep every session searchable.",
  },
  {
    n: "02",
    title: "Machine-first, not cloud-first",
    body: "Modbus, Phidget, and Artisan-ready paths. Run on the floor when the network is flaky.",
  },
  {
    n: "03",
    title: "Ops beyond the curve",
    body: "Day plan, green inventory, and production reports — one system from charge to bag.",
  },
  {
    n: "04",
    title: "Clear pricing",
    body: "Pro at $49/mo (200 batches). Pro+ for unlimited + commerce. Enterprise when you need a team and FDE.",
  },
];

const steps = [
  {
    n: "I",
    title: "Connect your machine",
    body: "Pair sensors and controllers. Modbus, Phidget, and Artisan-ready setups are first-class.",
  },
  {
    n: "II",
    title: "Roast with a reference",
    body: "Load a profile, mark events, and ride the curve with live readings on the floor.",
  },
  {
    n: "III",
    title: "Archive and improve",
    body: "Weights, phases, and notes save automatically. Promote winners for the next shift.",
  },
];

const hardware = [
  { tag: "Protocol", name: "Modbus", desc: "Industrial PLC / controller links" },
  { tag: "Sensors", name: "Phidget", desc: "Thermocouple & probe interfaces" },
  { tag: "Ecosystem", name: "Artisan-ready", desc: "Familiar machine configurations" },
  { tag: "Platform", name: "Desktop-native", desc: "macOS & Windows installers" },
];

const marqueeItems = [
  "Live BT / ET / RoR",
  "Profile library",
  "Batch history",
  "Modbus",
  "Phidget",
  "Artisan-ready",
  "Roast planner",
  "Inventory",
  "Production reports",
  "Team sync",
  "macOS",
  "Windows",
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="First Crack — roast profiling and production software for specialty coffee roasteries. Desktop-native. $49/mo Pro." />
    <title>First Crack — Roasting software for specialty coffee</title>
    <link rel="alternate" hreflang="ko" href="/kr" />
    <link rel="alternate" hreflang="en-US" href="/us" />
    <link rel="alternate" hreflang="ja" href="/jp" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-main noise-overlay">
      <!-- ── Header ───────────────────────────────────────── -->
      <header class="ox-header" id="ox-header">
        <nav class="ox-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>

          <div class="ox-nav-links">
            <a href="#features" class="ox-nav-link">Product</a>
            <a href="#how-it-works" class="ox-nav-link">How it works</a>
            <a href="#platform" class="ox-nav-link">Platform</a>
            <a href="#pricing" class="ox-nav-link">Pricing</a>
          </div>

          <div class="ox-nav-end">
            {
              isLoggedIn ? (
                <>
                  <span class="ox-nav-email">{userEmail}</span>
                  <a href="/account" class="ox-btn ox-btn-solid ox-btn-sm">
                    Account
                  </a>
                </>
              ) : (
                <>
                  <a href="/login" class="ox-nav-signin">Log in</a>
                  <a href="/signup" class="ox-btn ox-btn-solid ox-btn-sm">
                    Start trial
                  </a>
                </>
              )
            }
            <button
              type="button"
              class="ox-burger"
              aria-label="Toggle menu"
              aria-expanded="false"
              aria-controls="ox-mobile"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="4" y1="6" x2="20" y2="6"></line>
                <line x1="4" y1="12" x2="20" y2="12"></line>
                <line x1="4" y1="18" x2="20" y2="18"></line>
              </svg>
            </button>
          </div>
        </nav>

        <div id="ox-mobile" class="ox-mobile" hidden>
          <div class="ox-mobile-inner">
            <div class="ox-mobile-links">
              <a href="#features">Product</a>
              <a href="#how-it-works">How it works</a>
              <a href="#platform">Platform</a>
              <a href="#pricing">Pricing</a>
              <a href="/download">Download app</a>
            </div>
            <div class="ox-mobile-cta">
              {
                isLoggedIn ? (
                  <a href="/account" class="ox-btn ox-btn-solid ox-btn-lg">
                                        Account
                  </a>
                ) : (
                  <>
                    <a href="/login" class="ox-btn ox-btn-outline ox-btn-lg">
                      Log in
                    </a>
                    <a href="/signup" class="ox-btn ox-btn-solid ox-btn-lg">
                      Start trial
                    </a>
                  </>
                )
              }
            </div>
          </div>
        </div>
      </header>

      <!-- ── Hero ─────────────────────────────────────────── -->
      <section class="ox-hero">
        <div class="ox-grid-bg" aria-hidden="true"></div>
        <div class="ox-hero-glow" aria-hidden="true"></div>
        <canvas id="ox-globe" aria-hidden="true"></canvas>

        <div class="ox-shell ox-hero-inner">
          <div class="ox-eyebrow reveal">
            <span class="ox-line"></span>
                        Built for specialty roasteries
          </div>

          <h1 class="ox-hero-title reveal reveal-d1">
            <span class="block">Roast with data.</span>
            <span class="block ox-hero-title-muted">Reproduce every batch.</span>
          </h1>

          <p class="ox-hero-lead reveal reveal-d2">
                        Live profiles, machine connectivity, and production tools — desktop software for the roast floor, not another browser tab.
          </p>

          <div class="ox-hero-actions reveal reveal-d3">
            <a href="/signup" class="ox-btn ox-btn-solid ox-btn-lg">
                            Start 14-day trial
            </a>
            <a href="/download" class="ox-btn ox-btn-outline ox-btn-lg">
                            Download app
            </a>
          </div>

          <p class="ox-hero-fine reveal reveal-d3">
                        macOS &amp; Windows · 14 days + 20 batches · No credit card
          </p>
        </div>

        <!-- Stats marquee -->
        <div class="ox-marquee" aria-hidden="true">
          <div class="ox-marquee-track">
            {
              [...marqueeItems, ...marqueeItems].map((item) => (
                <span class="ox-marquee-item">
                  <span class="ox-marquee-dot"></span>
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ── Capabilities ─────────────────────────────────── -->
      <section class="ox-section" id="features">
        <div class="ox-shell">
          <div class="ox-section-head">
            <div class="ox-eyebrow reveal">
              <span class="ox-line"></span>
                            Product
            </div>
            <h2 class="ox-h2 reveal">
              Everything on the floor.
              <br />
              <span class="ox-muted">Nothing in the way.</span>
            </h2>
          </div>

          <div class="ox-cap-list">
            {
              capabilities.map((c, i) => (
                <article
                  class="ox-cap reveal"
                  style={`--d: ${i * 60}ms`}
                >
                  <div class="ox-cap-num">{c.n}</div>
                  <div class="ox-cap-body">
                    <h3 class="ox-cap-title">{c.title}</h3>
                    <p class="ox-cap-text">{c.body}</p>
                  </div>
                  <div
                    class="ox-cap-media"
                    role="img"
                    aria-label={`Screenshot placeholder — ${c.title}`}
                  >
                    <span class="ox-ph-label">Screenshot</span>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ── Process (inverted) ───────────────────────────── -->
      <section class="ox-process" id="how-it-works">
        <div class="ox-shell">
          <div class="ox-section-head">
            <div class="ox-eyebrow ox-eyebrow-on-dark reveal">
              <span class="ox-line ox-line-on-dark"></span>
              Workflow
            </div>
            <h2 class="ox-h2 ox-h2-on-dark reveal">
              Three steps.
              <br />
              <span class="ox-on-dark-muted">Consistent coffee.</span>
            </h2>
          </div>

          <div class="ox-process-grid">
            <div class="ox-steps">
              {
                steps.map((s, i) => (
                  <button
                    type="button"
                    class:list={["ox-step", i === 0 && "is-active"]}
                    data-step={i}
                  >
                    <span class="ox-step-n">{s.n}</span>
                    <div>
                      <h3 class="ox-step-title">{s.title}</h3>
                      <p class="ox-step-body">{s.body}</p>
                    </div>
                  </button>
                ))
              }
            </div>

            <div class="ox-code-panel reveal">
              <div class="ox-code-tabs">
                <span class="is-active">Active roast</span>
                <span>Profile</span>
                <span>History</span>
              </div>
              <div class="ox-code-body">
                <div class="ox-code-chart" aria-hidden="true">
                  <svg viewBox="0 0 480 200" fill="none">
                    <g stroke="rgba(250,250,249,0.08)" stroke-width="1">
                      <line x1="0" y1="40" x2="480" y2="40"></line>
                      <line x1="0" y1="80" x2="480" y2="80"></line>
                      <line x1="0" y1="120" x2="480" y2="120"></line>
                      <line x1="0" y1="160" x2="480" y2="160"></line>
                    </g>
                    <path
                      d="M0,170 C60,168 100,150 140,120 C190,80 240,50 300,40 C360,30 420,28 480,24"
                      stroke="#fafaf9"
                      stroke-width="2"
                      stroke-linecap="round"></path>
                    <path
                      d="M0,150 C70,130 120,100 170,80 C240,52 300,48 360,44 C420,40 450,38 480,36"
                      stroke="rgba(250,250,249,0.35)"
                      stroke-width="1.5"
                      stroke-linecap="round"></path>
                    <line
                      x1="310"
                      y1="16"
                      x2="310"
                      y2="190"
                      stroke="rgba(250,250,249,0.25)"
                      stroke-dasharray="3 4"></line>
                    <text
                      x="318"
                      y="28"
                      fill="rgba(250,250,249,0.55)"
                      font-size="10"
                      font-family="JetBrains Mono, monospace"
                      >1st Crack</text
                    >
                  </svg>
                </div>
                <div class="ox-code-metrics">
                  <div><label>BT</label><b>198.4°C</b></div>
                  <div><label>ET</label><b>214.1°C</b></div>
                  <div><label>RoR</label><b>7.2°/m</b></div>
                  <div><label>Time</label><b>09:42</b></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Platform ─────────────────────────────────────── -->
      <section class="ox-section" id="platform">
        <div class="ox-shell ox-platform">
          <div class="ox-platform-copy">
            <div class="ox-eyebrow reveal">
              <span class="ox-line"></span>
              Platform
            </div>
            <h2 class="ox-h2 reveal">
              Built for the
              <br />
              roast floor.
            </h2>
            <p class="ox-lead reveal">
              A native desktop app with low-latency hardware links — and cloud
              sync when you’re back in the office. Connect the gear you already
              own.
            </p>
            <div class="ox-stats reveal">
              <div>
                <div class="ox-stat-num">macOS</div>
                <div class="ox-stat-label">&amp; Windows</div>
              </div>
              <div>
                <div class="ox-stat-num">Live</div>
                <div class="ox-stat-label">BT · ET · RoR</div>
              </div>
              <div>
                <div class="ox-stat-num">Cloud</div>
                <div class="ox-stat-label">sync included</div>
              </div>
            </div>
            <a href="/download" class="ox-btn ox-btn-solid ox-btn-lg reveal">
              Download desktop app
            </a>
          </div>

          <ul class="ox-hw-list reveal">
            {
              hardware.map((h) => (
                <li class="ox-hw-item">
                  <span class="ox-hw-tag">{h.tag}</span>
                  <strong>{h.name}</strong>
                  <p>{h.desc}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- ── Pricing ──────────────────────────────────────── -->
      <section class="ox-section ox-pricing" id="pricing">
        <div class="ox-shell">
          <div class="ox-section-head ox-section-head-center">
            <div class="ox-eyebrow reveal" style="justify-content:center">
              <span class="ox-line"></span>
                            Pricing
            </div>
            <h2 class="ox-h2 reveal">
              Simple pricing
              <br />
              for serious roasters
            </h2>
            <p class="ox-lead ox-lead-center reveal">
              14-day trial (20 batches). Then Pro, Pro+, or talk to us for Enterprise.
            </p>
          </div>

          <div class="ox-bill reveal">
            <div class="ox-bill-toggle" role="group" aria-label="Billing period">
              <button type="button" class="is-active" id="btn-monthly" aria-pressed="true">
                                Monthly
              </button>
              <button type="button" id="btn-yearly" aria-pressed="false">
                Annual <em>Save ~20%</em>
              </button>
            </div>
          </div>

          <div class="ox-price-grid reveal">
            <article class="ox-price-card">
              <div class="ox-price-top">
                <span class="ox-price-n">01</span>
                <h3>Pro</h3>
                <p>Core floor ops — roast, inventory, schedule</p>
              </div>
              <div class="ox-price-amt">
                <span class="ox-price-num" id="pro-price" data-monthly="$49" data-yearly="$39">$49</span>
                <span class="ox-price-per" id="pro-period" data-monthly="/mo" data-yearly="/mo">/mo</span>
              </div>
              <p class="ox-price-note" id="pro-yearly-note" hidden>Billed $468 / year</p>
              <ul>
                <li>200 batches / billing month</li>
                <li>Live roast + history + profiles</li>
                <li>Beans, blends, day plan</li>
                <li>1 seat</li>
                <li>Desktop app (macOS &amp; Windows)</li>
              </ul>
              <a id="pro-start-btn" href="/start-pro?plan=monthly" class="ox-btn ox-btn-outline ox-btn-block" data-href-monthly="/start-pro?plan=monthly" data-href-yearly="/start-pro?plan=yearly">
                Start 14-day trial
              </a>
            </article>

            <article class="ox-price-card is-featured">
              <div class="ox-price-badge">Most popular</div>
              <div class="ox-price-top">
                <span class="ox-price-n">02</span>
                <h3>Pro+</h3>
                <p>Unlimited batches + commerce integrations</p>
              </div>
              <div class="ox-price-amt">
                <span class="ox-price-num" id="proplus-price" data-monthly="$79" data-yearly="$63">$79</span>
                <span class="ox-price-per" id="proplus-period" data-monthly="/mo" data-yearly="/mo">/mo</span>
              </div>
              <p class="ox-price-note" id="proplus-yearly-note" hidden>Billed $756 / year</p>
              <ul>
                <li>Unlimited batches</li>
                <li>Everything in Pro</li>
                <li>Shopify &amp; commerce connectors</li>
                <li>Payment / store sync (roadmap GA)</li>
                <li>1 seat</li>
              </ul>
              <a id="proplus-start-btn" href="/start-pro?plan=monthly" class="ox-btn ox-btn-solid ox-btn-block" data-href-monthly="/start-pro?plan=monthly" data-href-yearly="/start-pro?plan=yearly">
                Start trial
              </a>
            </article>

            <article class="ox-price-card">
              <div class="ox-price-top">
                <span class="ox-price-n">03</span>
                <h3>Enterprise</h3>
                <p>Teams, custom work, dedicated engineer (FDE)</p>
              </div>
              <div class="ox-price-amt">
                <span class="ox-price-num">Contact</span>
              </div>
              <ul>
                <li>Unlimited batches + team seats</li>
                <li>Custom features &amp; FDE support</li>
                <li>From $300/mo + $19/seat</li>
                <li>Priority onboarding</li>
                <li>Contract &amp; invoice options</li>
              </ul>
              <a href="mailto:sales@firstcrackiscoming.com?subject=Enterprise%20inquiry" class="ox-btn ox-btn-outline ox-btn-block">
                Contact sales
              </a>
            </article>
          </div>
        </div>
      </section>

      <!-- ── Final CTA ────────────────────────────────────── -->
      <section class="ox-final">
        <div class="ox-shell ox-final-inner">
          <div>
            <h2 class="ox-h2 ox-final-title reveal">
              Ready when the
              <br />
              green coffee is.
            </h2>
            <p class="ox-lead reveal">
              Install First Crack, connect your machine, and put a reference profile under your next batch.
            </p>
            <div class="ox-hero-actions reveal">
              <a href="/signup" class="ox-btn ox-btn-solid ox-btn-lg">
                Start free trial
              </a>
              <a href="/download" class="ox-btn ox-btn-outline ox-btn-lg">
                Download
              </a>
            </div>
            <p class="ox-hero-fine reveal">No credit card required</p>
          </div>
        </div>
      </section>

      <!-- ── Footer ───────────────────────────────────────── -->
      <footer class="ox-footer">
        <div class="ox-shell">
          <div class="ox-footer-top">
            <div class="ox-footer-brand">
              <a href="/" class="ox-brand">
                <span class="ox-brand-name">First Crack</span>
              </a>
              <p>Roasting software for specialty coffee.</p>
            </div>
              <div class="ox-footer-cols">
              <div>
                <h4>Product</h4>
                <a href="#features">Features</a>
                <a href="#how-it-works">Workflow</a>
                <a href="#pricing">Pricing</a>
                <a href="/download">Download</a>
              </div>
              <div>
                <h4>Company</h4>
                <a href="/about">About</a>
                <a href="/careers">Careers</a>
                <a href="mailto:hello@firstcrackiscoming.com">Contact</a>
              </div>
              <div>
                <h4>Account</h4>
                <a href="/login">Log in</a>
                <a href="/signup">Sign up</a>
                <a href="/account">Account</a>
              </div>
              <div>
                <h4>Legal</h4>
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
              </div>
            </div>
          </div>
          <div class="ox-footer-bottom">
            <span>© {year} First Crack</span>
            <span>Built for the roast floor</span>
          </div>
        </div>
      </footer>
    </main>

    <script>
      // Header scroll state
      const header = document.getElementById("ox-header");
      const onScroll = () => {
        header?.classList.toggle("is-scrolled", window.scrollY > 20);
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // Mobile menu
      const burger = document.querySelector(".ox-burger") as HTMLButtonElement | null;
      const mobile = document.getElementById("ox-mobile");
      burger?.addEventListener("click", () => {
        const open = burger.getAttribute("aria-expanded") === "true";
        burger.setAttribute("aria-expanded", String(!open));
        if (mobile) mobile.hidden = open;
        document.body.classList.toggle("ox-menu-open", !open);
      });
      mobile?.querySelectorAll("a").forEach((a) => {
        a.addEventListener("click", () => {
          burger?.setAttribute("aria-expanded", "false");
          if (mobile) mobile.hidden = true;
          document.body.classList.remove("ox-menu-open");
        });
      });

      // Process step highlight
      document.querySelectorAll(".ox-step").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".ox-step")
            .forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
        });
      });

      // Pricing toggle
      const btnMonthly = document.getElementById("btn-monthly");
      const btnYearly = document.getElementById("btn-yearly");

      function setBilling(isYearly: boolean) {
        if (!btnMonthly || !btnYearly) return;
        btnMonthly.classList.toggle("is-active", !isYearly);
        btnYearly.classList.toggle("is-active", isYearly);
        btnMonthly.setAttribute("aria-pressed", String(!isYearly));
        btnYearly.setAttribute("aria-pressed", String(isYearly));

        document.querySelectorAll(".ox-price-card").forEach((card) => {
          const num = card.querySelector<HTMLElement>(".ox-price-num");
          const per = card.querySelector<HTMLElement>(".ox-price-per");
          const note = card.querySelector<HTMLElement>(".ox-price-note");
          const cta = card.querySelector<HTMLAnchorElement>("a.ox-btn");
          if (num) {
            num.textContent = isYearly
              ? (num.dataset.yearly ?? num.dataset.monthly ?? "")
              : (num.dataset.monthly ?? "");
          }
          if (per) {
            per.textContent = isYearly
              ? (per.dataset.yearly ?? per.dataset.monthly ?? "")
              : (per.dataset.monthly ?? "");
          }
          if (note) note.hidden = !isYearly;
          if (cta) {
            cta.href = isYearly
              ? (cta.dataset.hrefYearly ?? cta.href)
              : (cta.dataset.hrefMonthly ?? cta.href);
          }
        });
      }
      btnMonthly?.addEventListener("click", () => setBilling(false));
      btnYearly?.addEventListener("click", () => setBilling(true));
      setBilling(false);

      // Reveal
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reduce && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -32px 0px" },
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("is-in"));
      }

      // ── Particle Globe ────────────────────────────────────
      {
        const canvas = document.getElementById("ox-globe") as HTMLCanvasElement | null;
        if (canvas) {
          const ctx = canvas.getContext("2d");
          if (ctx) {
            const dpr = window.devicePixelRatio || 1;
            let W = 0, H = 0;

            function resize() {
              const rect = canvas!.getBoundingClientRect();
              W = rect.width;
              H = rect.height;
              canvas!.width = W * dpr;
              canvas!.height = H * dpr;
              ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
            }
            resize();
            window.addEventListener("resize", resize);

            // Generate sphere points using fibonacci sphere for even distribution
            const N = 220; // ponytail: fixed count, increase if sparse
            const pts: { x: number; y: number; z: number; w: number; h: number; shade: number }[] = [];
            const golden = Math.PI * (3 - Math.sqrt(5));

            for (let i = 0; i < N; i++) {
              const y = 1 - (i / (N - 1)) * 2; // -1..1
              const r = Math.sqrt(1 - y * y);
              const theta = golden * i;
              const x = Math.cos(theta) * r;
              const z = Math.sin(theta) * r;
              // Vary rectangle size slightly for organic look
              const w = 2 + Math.random() * 4;
              const h = 3 + Math.random() * 8;
              // Random grayscale shade (0 = dark, 1 = light)
              const shade = 0.15 + Math.random() * 0.55;
              pts.push({ x, y, z, w, h, shade });
            }

            // Rotation state
            let angleX = 0;
            let angleY = 0;
            const speedX = 0.003;
            const speedY = 0.006;

            function rotate(p: { x: number; y: number; z: number }, ax: number, ay: number) {
              // Rotate around Y
              let x1 = p.x * Math.cos(ay) - p.z * Math.sin(ay);
              let z1 = p.x * Math.sin(ay) + p.z * Math.cos(ay);
              // Rotate around X
              let y2 = p.y * Math.cos(ax) - z1 * Math.sin(ax);
              let z2 = p.y * Math.sin(ax) + z1 * Math.cos(ax);
              return { x: x1, y: y2, z: z2 };
            }

            function draw() {
              if (!visible) { raf = 0; return; }
              ctx!.clearRect(0, 0, W, H);

              const cx = W / 2;
              const cy = H / 2;
              const radius = Math.min(W, H) * 0.38;
              const fov = 4;

              const projected = pts.map((p) => {
                const r = rotate(p, angleX, angleY);
                const scale = fov / (fov + r.z);
                return {
                  sx: cx + r.x * radius * scale,
                  sy: cy + r.y * radius * scale,
                  z: r.z,
                  scale,
                  w: p.w * scale,
                  h: p.h * scale,
                  shade: p.shade,
                };
              });
              projected.sort((a, b) => a.z - b.z);

              for (const p of projected) {
                const alpha = 0.25 + (p.z + 1) * 0.3;
                const c = Math.round(p.shade * 80);
                ctx!.fillStyle = `rgba(${c + 8}, ${c + 5}, ${c + 3}, ${alpha})`;
                ctx!.fillRect(p.sx - p.w / 2, p.sy - p.h / 2, p.w, p.h);
              }

              angleX += speedX;
              angleY += speedY;
              raf = requestAnimationFrame(draw);
            }

            let raf = 0;
            let visible = true;
            const heroObs = new IntersectionObserver(
              ([entry]) => {
                visible = entry.isIntersecting;
                if (visible && !raf) raf = requestAnimationFrame(draw);
              },
              { threshold: 0 },
            );
            heroObs.observe(canvas);

            if (!reduce) raf = requestAnimationFrame(draw);
            else { angleY = 0.5; draw(); }
          }
        }
      }
    </script>
  </body>
</html>

