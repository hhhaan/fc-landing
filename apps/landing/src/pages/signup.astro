---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
---

<html lang="ko" class="h-full">
<head>
  <meta charset="UTF-8" />
  <Favicon />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="First Crack — 회원가입" />
  <title>Sign up — First Crack</title>
</head>
<body class="flex items-center justify-center min-h-screen bg-bg-secondary p-5">

  <main class="flex flex-col items-center h-full w-90 justify-center py-16 md:py-24 mx-auto max-w-90">
    <div class="auth-card w-full">
      <div class="auth-header">
        <p class="brand-name">First Crack</p>
        <h1 class="font-bold text-xl text-center">Create an account</h1>
      </div>

      <!-- Google -->
      <div class="mb-4">
        <button id="google-btn" class="google-btn w-full border border-gray-200 rounded-lg py-0 px-12 h-11 flex items-center justify-center gap-3 text-sm font-medium hover:bg-gray-50 focus:outline-none text-fg-secondary transition-colors cursor-pointer" type="button">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span>Sign up with Google</span>
        </button>
      </div>
      <div class="divider"><span>or</span></div>

      <form id="signup-form" class="auth-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" type="email" class="input" required />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" type="password" class="input" minlength="8" required />
        </div>

        <div class="checkbox-group flex items-center gap-3">
          <input type="checkbox" id="terms" required />
          <label for="terms" class="text-caption">
            I agree to the <a href="/terms">Terms</a> and <a href="/privacy">Privacy Policy</a>.
          </label>
        </div>

        <div id="error-msg" class="hidden text-sm text-red-500 text-center"></div>
        <div id="success-msg" class="hidden text-sm text-green-600 text-center"></div>

        <button type="submit" id="submit-btn" class="btn btn-primary w-full">
          Sign up
        </button>
      </form>

      <div class="auth-footer">
        <p class="text-caption text-center">
          Already have an account? <a href="/login" class="text-primary hover:underline">Sign in</a>
        </p>
      </div>
    </div>
  </main>

  <script>
    import { createBrowserClient } from '@supabase/ssr';

    const supabase = createBrowserClient(
      import.meta.env.PUBLIC_SUPABASE_URL!,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY!
    );

    // URL에서 next 파라미터 미리 읽기
    const urlParams = new URLSearchParams(window.location.search);
    const nextUrl = urlParams.get('next') || '/';

    // Google Sign up
    document.getElementById('google-btn')?.addEventListener('click', async () => {
      const { error } = await supabase.auth.signInWithOAuth({
        provider: 'google',
        options: {
          // next 파라미터를 callback까지 전달
          redirectTo: `${window.location.origin}/auth/callback?next=${encodeURIComponent(nextUrl)}`,
        },
      });
      if (error) showError(error.message);
    });

    // Email Sign up
    document.getElementById('signup-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearMessages();

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;

      btn.disabled = true;
      btn.textContent = 'Creating account...';

      const { error } = await supabase.auth.signUp({
        email,
        password,
        options: {
          // 이메일 확인 후 돌아올 때 next 파라미터 전달
          emailRedirectTo: `${window.location.origin}/auth/callback?next=${encodeURIComponent(nextUrl)}`,
        },
      });

      btn.disabled = false;
      btn.textContent = 'Sign up';

      if (error) {
        showError(error.message);
      } else {
        showSuccess('확인 이메일을 보냈습니다. 메일함을 확인해주세요!');
      }
    });

    function showError(msg: string) {
      const el = document.getElementById('error-msg')!;
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function showSuccess(msg: string) {
      const el = document.getElementById('success-msg')!;
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function clearMessages() {
      document.getElementById('error-msg')!.classList.add('hidden');
      document.getElementById('success-msg')!.classList.add('hidden');
    }
  </script>
  <style>
      .auth-header {
        text-align: center;
        margin-bottom: var(--space-24);
      }

      .brand-name {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: var(--fg-secondary, #6b7280);
        margin-bottom: var(--space-16);
        text-transform: uppercase;
      }

      .auth-form {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }

      .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1rem 0 1.25rem;
        color: var(--fg-secondary, #9ca3af);
        font-size: 0.75rem;
      }

      .divider::before,
      .divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--color-border, #e5e7eb);
      }

      .auth-footer {
        text-align: center;
        padding-top: var(--space-24);
      }
      .google-btn:focus {
        border-color: transparent;
        box-shadow:
          0 0 0 2px var(--color-bg),
          0 0 0 4px var(--color-ring);
      }
    </style>
  </body>
</html>
