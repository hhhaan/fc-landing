---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="About First Crack — roasting software built for specialty coffee roasters." />
    <title>About — First Crack</title>
  </head>
  <body>

    <!-- NAV -->
    <header class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="nav-logo-text">First Crack</span>
        </a>
        <nav class="nav-links" aria-label="Main menu">
          <a href="/" class="nav-link">Home</a>
          <a href="/login" class="nav-link">Log in</a>
        </nav>
      </div>
    </header>

    <main class="about-page">
      <div class="container container-narrow">

        <section class="about-hero">
          <h1 class="about-title">We make tools for roasters</h1>
          <p class="about-lead">
            First Crack was built because roasting software should feel like an extension of the roast floor — not a spreadsheet with extra steps.
          </p>
        </section>

        <section class="about-section">
          <h2 class="about-h2">What we do</h2>
          <p>
            First Crack is a native desktop application for specialty coffee roasters.
            It connects directly to roasting machines via Modbus and Phidget, displays live temperature curves,
            and manages everything from batch history to production scheduling.
          </p>
          <p>
            We ship on macOS and Windows, with cloud sync for teams. Our users range from home roasters
            to multi-machine production floors — same software, tuned for each scale.
          </p>
        </section>

        <section class="about-section">
          <h2 class="about-h2">How we work</h2>
          <p>
            We're a small, remote team spread across time zones. We ship weekly, talk to users daily,
            and believe the best roasting software comes from understanding the craft itself.
            Every new team member gets a roasting workshop — because you can't build tools for
            something you haven't done.
          </p>
        </section>

        <section class="about-section">
          <h2 class="about-h2">Join us</h2>
          <p>
            We're always looking for people who care about craft. If that sounds like you, check out
            our <a href="/careers" class="about-link">open positions</a>.
          </p>
        </section>

      </div>
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="footer-logo">First Crack</span>
          <span class="footer-copy">© 2026</span>
        </div>
        <nav class="footer-links" aria-label="Footer menu">
          <a href="/about" class="footer-link">About</a>
          <a href="/careers" class="footer-link">Careers</a>
          <a href="mailto:hello@firstcrackiscoming.com" class="footer-link">Contact</a>
        </nav>
      </div>
    </footer>

  </body>
</html>

<style>
  .about-page {
    padding-block: var(--space-80);
    background: var(--color-bg);
    min-height: calc(100vh - 56px - 80px);
  }
  .about-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: var(--space-16);
    color: var(--color-fg);
  }
  .about-lead {
    font-size: var(--text-lg);
    line-height: 1.75;
    color: var(--color-fg-secondary);
    max-width: 36rem;
  }
  .about-hero {
    margin-bottom: var(--space-64);
  }
  .about-section {
    margin-bottom: var(--space-48);
  }
  .about-h2 {
    font-family: var(--font-display);
    font-size: var(--text-card);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-16);
    color: var(--color-fg);
  }
  .about-section p {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-fg-secondary);
    margin-bottom: var(--space-12);
  }
  .about-link {
    color: var(--color-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-mint);
    transition: opacity var(--motion-fast) ease;
  }
  .about-link:hover { opacity: 0.6; }

  /* ── Nav ── */
  .nav {
    background-color: var(--color-bg);
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-logo-text {
    font-family: var(--font-display);
    font-size: var(--text-nav);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-24);
    height: 56px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .nav .nav-link {
    color: var(--color-fg-secondary);
    padding: var(--space-8) var(--space-12);
    border-radius: 0;
    transition: color var(--motion-fast) ease;
    font-size: var(--text-nav);
    font-weight: 500;
    text-decoration: none;
  }
  .nav .nav-link:hover { color: var(--color-fg); }
  .nav-logo { text-decoration: none; color: var(--color-fg); }

  /* ── Footer ── */
  .site-footer {
    background: var(--color-dark);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: var(--space-32);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-12);
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-nav);
    font-weight: 700;
    color: #FFFFFF;
  }
  .footer-copy {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.4);
  }
  .footer-links { display: flex; gap: var(--space-24); }
  .footer-link {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.4);
    transition: color var(--motion-fast) ease;
    text-decoration: none;
  }
  .footer-link:hover { color: rgba(255,255,255,0.8); }

  @media (max-width: 1023px) {
    .about-title { font-size: 2rem; }
    .footer-inner { flex-direction: column; gap: var(--space-20); }
  }
</style>
