---
import "../styles/global.css";
import Favicon from "../components/ui/Favicon.astro";

const year = new Date().getFullYear();

const stats = [
  { label: "Team", value: "Remote-first" },
  { label: "Cadence", value: "Ship weekly" },
  { label: "Platforms", value: "macOS & Windows" },
  { label: "Trial", value: "14 days · 20 batches" },
];

const values = [
  {
    n: "01",
    title: "Floor-first",
    body: "Desktop-native, low-latency, offline-capable — built for the machine room, not a browser tab.",
  },
  {
    n: "02",
    title: "Reproducible",
    body: "Every batch logged, searchable, and comparable. Consistency is the product.",
  },
  {
    n: "03",
    title: "Ship weekly",
    body: "Small team, short loops. Features reach roasters in days, not quarters.",
  },
  {
    n: "04",
    title: "Craft matters",
    body: "Every hire learns to roast. You build tools for a craft you've practiced yourself.",
  },
];

const hardware = [
  { tag: "Protocol", name: "Modbus", desc: "Industrial PLC / controller links" },
  { tag: "Sensors", name: "Phidget", desc: "Thermocouple & probe interfaces" },
  { tag: "Ecosystem", name: "Artisan-ready", desc: "Familiar machine configurations" },
  { tag: "Platform", name: "Desktop-native", desc: "macOS & Windows installers" },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="About First Crack — roasting software built for specialty coffee roasteries."
    />
    <title>About — First Crack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="ox">
    <main class="ox-about noise-overlay">
      <div class="ox-grid-bg" aria-hidden="true"></div>

      <header class="ox-auth-header">
        <nav class="ox-auth-nav">
          <a href="/" class="ox-brand">
            <span class="ox-brand-name">First Crack</span>
          </a>
          <div class="ox-auth-nav-end">
            <a href="/" class="ox-utility-link">Home</a>
            <a href="/about" class="ox-utility-link is-active">About</a>
            <a href="/careers" class="ox-utility-link">Careers</a>
          </div>
        </nav>
      </header>

      <section class="ox-about-hero">
        <div class="ox-shell ox-about-hero-inner">
          <div class="ox-eyebrow reveal">
            <span class="ox-line"></span>
            Company
          </div>
          <h1 class="ox-about-title reveal reveal-d1">
            We make tools for roasters
          </h1>
          <p class="ox-about-lead reveal reveal-d2">
            First Crack was built because roasting software should feel like an extension of the roast floor — not a spreadsheet with extra steps.
          </p>
          <dl class="ox-about-stats reveal reveal-d3">
            {
              stats.map((s) => (
                <div class="ox-about-stat">
                  <dt>{s.label}</dt>
                  <dd>{s.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </section>

      <section class="ox-about-story">
        <div class="ox-shell ox-about-story-inner">
          <div class="ox-about-story-copy reveal">
            <h2 class="ox-h2">What we do</h2>
            <p>
              First Crack is a native desktop application for specialty coffee roasters.
              It connects directly to roasting machines via Modbus and Phidget, displays live temperature curves,
              and manages everything from batch history to production scheduling.
            </p>
            <p>
              We ship on macOS and Windows, with cloud sync for teams. Our users range from home roasters
              to multi-machine production floors — same software, tuned for each scale.
            </p>
          </div>
          <div class="ox-about-panel reveal reveal-d1" aria-hidden="true">
            <div class="ox-about-panel-head">
              <span class="ox-about-panel-tab is-active">Live roast</span>
              <span class="ox-about-panel-tab">Profile</span>
              <span class="ox-about-panel-tab">History</span>
            </div>
            <div class="ox-about-panel-body">
              <svg class="ox-about-chart" viewBox="0 0 480 200" fill="none">
                <g stroke="rgba(8, 5, 3, 0.06)" stroke-width="1">
                  <line x1="0" y1="40" x2="480" y2="40"></line>
                  <line x1="0" y1="80" x2="480" y2="80"></line>
                  <line x1="0" y1="120" x2="480" y2="120"></line>
                  <line x1="0" y1="160" x2="480" y2="160"></line>
                </g>
                <path
                  d="M0,170 C60,168 100,150 140,120 C190,80 240,50 300,40 C360,30 420,28 480,24"
                  stroke="#080503"
                  stroke-width="2"
                  stroke-linecap="round"></path>
                <path
                  d="M0,150 C70,130 120,100 170,80 C240,52 300,48 360,44 C420,40 450,38 480,36"
                  stroke="rgba(8, 5, 3, 0.25)"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
                <line
                  x1="310"
                  y1="16"
                  x2="310"
                  y2="190"
                  stroke="rgba(8, 5, 3, 0.15)"
                  stroke-dasharray="3 4"></line>
                <text
                  x="318"
                  y="28"
                  fill="rgba(94, 83, 74, 0.8)"
                  font-size="10"
                  font-family="JetBrains Mono, monospace">1st Crack</text>
              </svg>
              <div class="ox-about-metrics">
                <div>
                  <span class="ox-about-metric-label">BT</span>
                  <span class="ox-about-metric-val">204.2°C</span>
                </div>
                <div>
                  <span class="ox-about-metric-label">ET</span>
                  <span class="ox-about-metric-val">218.7°C</span>
                </div>
                <div>
                  <span class="ox-about-metric-label">RoR</span>
                  <span class="ox-about-metric-val">8.4°/m</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="ox-about-work">
        <div class="ox-shell ox-about-work-inner reveal">
          <div class="ox-eyebrow">
            <span class="ox-line"></span>
            How we work
          </div>
          <blockquote class="ox-about-quote">
            The best roasting software comes from understanding the craft itself — not from copying generic SaaS patterns.
          </blockquote>
          <p class="ox-about-work-body">
            We're a small, remote team spread across time zones. We ship weekly, talk to users daily,
            and believe software should earn its place on the roast floor.
            Every new team member gets a roasting workshop — because you can't build tools for
            something you haven't done.
          </p>
        </div>
      </section>

      <section class="ox-about-values-section">
        <div class="ox-shell">
          <h2 class="ox-h2 reveal">What we stand for</h2>
          <div class="ox-about-values">
            {
              values.map((v, i) => (
                <article
                  class="ox-about-value reveal"
                  style={`--d: ${i * 60}ms`}
                >
                  <span class="ox-about-value-tag">{v.n}</span>
                  <h3>{v.title}</h3>
                  <p>{v.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="ox-about-hw">
        <div class="ox-shell ox-about-hw-inner">
          <div class="ox-about-hw-head reveal">
            <h2 class="ox-h2">Built for real machines</h2>
            <p>Industrial protocols and desktop installers — not a web dashboard with a USB adapter.</p>
          </div>
          <ul class="ox-about-hw-list reveal reveal-d1">
            {
              hardware.map((h) => (
                <li class="ox-about-hw-item">
                  <span class="ox-about-hw-tag">{h.tag}</span>
                  <div>
                    <strong>{h.name}</strong>
                    <p>{h.desc}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="ox-about-product">
        <div class="ox-shell ox-about-product-inner reveal">
          <h2 class="ox-h2 ox-h2-on-dark">Try it on your floor</h2>
          <p class="ox-about-product-lead">
            Download the desktop app or start a trial — 14 days, 20 batches.
          </p>
          <div class="ox-about-product-actions">
            <a href="/download" class="ox-btn ox-btn-solid ox-btn-lg ox-btn-inverted">Download app</a>
            <a href="/signup" class="ox-btn ox-btn-outline ox-btn-lg ox-btn-on-dark">Start trial</a>
          </div>
        </div>
      </section>

      <section class="ox-about-cta">
        <div class="ox-shell ox-about-cta-inner reveal">
          <h2 class="ox-h2">Join the team</h2>
          <p class="ox-about-cta-lead">
            We're always looking for people who care about craft — engineers, designers, and roasters at heart.
          </p>
          <div class="ox-about-cta-actions">
            <a href="/careers" class="ox-btn ox-btn-solid ox-btn-lg">Open positions</a>
            <a href="mailto:contact@firstcrackiscoming.com" class="ox-btn ox-btn-outline ox-btn-lg">
              Get in touch
            </a>
          </div>
        </div>
      </section>

      <footer class="ox-utility-footer">
        <div class="ox-shell ox-utility-footer-inner">
          <span>© {year} First Crack</span>
          <nav aria-label="Footer">
            <a href="/about">About</a>
            <a href="/careers">Careers</a>
            <a href="/privacy">Privacy</a>
            <a href="mailto:contact@firstcrackiscoming.com">Contact</a>
          </nav>
        </div>
      </footer>
    </main>

    <script>
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!prefersReduced) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("is-in"));
      }
    </script>
  </body>
</html>

<style is:global>
  body.ox {
    --ox-bg: #fafaf9;
    --ox-fg: #080503;
    --ox-muted: #5e534a;
    --ox-muted-bg: #ecebe7;
    --ox-border: rgba(8, 5, 3, 0.06);
    --ox-border-strong: rgba(8, 5, 3, 0.12);
    --ox-sans: "Instrument Sans", system-ui, -apple-system, sans-serif;
    --ox-mono: "JetBrains Mono", ui-monospace, monospace;
    --ox-max: 1400px;
    --ox-pad: 24px;

    margin: 0;
    background: var(--ox-bg);
    color: var(--ox-fg);
    font-family: var(--ox-sans);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.ox *,
  body.ox *::before,
  body.ox *::after {
    box-sizing: border-box;
  }

  body.ox a {
    color: inherit;
    text-decoration: none;
  }

  .ox-shell {
    max-width: var(--ox-max);
    margin-inline: auto;
    padding-inline: var(--ox-pad);
  }

  .ox-brand-name {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ox-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--ox-mono);
    font-size: 13px;
    color: var(--ox-muted);
    margin-bottom: 20px;
  }

  .ox-line {
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(8, 5, 3, 0.3);
    flex-shrink: 0;
  }

  .ox-h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin: 0 0 24px;
  }

  .ox-h2-on-dark {
    color: var(--ox-bg);
    margin-bottom: 0;
  }

  .ox-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 0;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .ox-btn-lg {
    height: 48px;
    padding: 0 28px;
    font-size: 15px;
  }

  body.ox a.ox-btn-solid,
  body.ox .ox-btn-solid {
    background: var(--ox-fg);
    color: #fff;
    border-color: var(--ox-fg);
  }

  body.ox a.ox-btn-solid:hover,
  body.ox .ox-btn-solid:hover {
    opacity: 0.9;
  }

  .ox-btn-outline {
    background: transparent;
    color: var(--ox-fg);
    border-color: var(--ox-border-strong);
  }

  .ox-btn-outline:hover {
    background: rgba(8, 5, 3, 0.03);
    border-color: rgba(8, 5, 3, 0.28);
  }

  .ox-btn-inverted {
    background: var(--ox-bg) !important;
    color: var(--ox-fg) !important;
    border-color: var(--ox-bg) !important;
  }

  .ox-btn-on-dark {
    color: var(--ox-bg) !important;
    border-color: rgba(250, 250, 249, 0.35) !important;
  }

  .ox-btn-on-dark:hover {
    background: rgba(250, 250, 249, 0.08) !important;
    border-color: rgba(250, 250, 249, 0.5) !important;
  }

  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--d, 0ms);
  }

  .reveal-d1 { transition-delay: 80ms; }
  .reveal-d2 { transition-delay: 160ms; }
  .reveal-d3 { transition-delay: 240ms; }

  .reveal.is-in {
    opacity: 1;
    transform: none;
  }

  .noise-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ox-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    background-image:
      linear-gradient(var(--ox-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ox-border) 1px, transparent 1px);
    background-size: 12.5% 12.5%;
  }

  .ox-auth-header {
    position: relative;
    z-index: 2;
    border-bottom: 1px solid var(--ox-border);
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(16px);
  }

  .ox-auth-nav {
    max-width: var(--ox-max);
    margin: 0 auto;
    padding: 0 var(--ox-pad);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .ox-auth-nav-end {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ox-utility-link {
    font-size: 14px;
    color: rgba(8, 5, 3, 0.7);
    transition: color 0.2s ease;
  }

  .ox-utility-link:hover,
  .ox-utility-link.is-active {
    color: var(--ox-fg);
  }

  .ox-utility-link.is-active {
    font-weight: 500;
  }

  .ox-about {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ox-about-hero {
    position: relative;
    z-index: 2;
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-about-hero-inner {
    max-width: 48rem;
  }

  .ox-about-title {
    margin: 0 0 16px;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .ox-about-lead {
    margin: 0 0 32px;
    font-size: 17px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    margin: 0;
    padding: 0;
    border: 1px solid var(--ox-border);
    background: var(--ox-border);
  }

  .ox-about-stat {
    margin: 0;
    padding: 16px 20px;
    background: #fff;
  }

  .ox-about-stat dt {
    margin: 0 0 4px;
    font-family: var(--ox-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-about-stat dd {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .ox-about-story {
    position: relative;
    z-index: 2;
    padding: 72px 0;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-about-story-inner {
    display: grid;
    gap: 40px;
    align-items: start;
  }

  @media (min-width: 900px) {
    .ox-about-story-inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }

  .ox-about-story-copy p {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.75;
    color: var(--ox-muted);
  }

  .ox-about-story-copy p:last-child {
    margin-bottom: 0;
  }

  .ox-about-panel {
    border: 1px solid var(--ox-border-strong);
    background: #fff;
    overflow: hidden;
  }

  .ox-about-panel-head {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--ox-border);
    background: var(--ox-bg);
  }

  .ox-about-panel-tab {
    padding: 12px 16px;
    font-family: var(--ox-mono);
    font-size: 11px;
    color: var(--ox-muted);
    border-right: 1px solid var(--ox-border);
  }

  .ox-about-panel-tab.is-active {
    color: var(--ox-fg);
    background: #fff;
    margin-bottom: -1px;
    border-bottom: 1px solid #fff;
  }

  .ox-about-panel-body {
    padding: 20px;
  }

  .ox-about-chart {
    display: block;
    width: 100%;
    height: auto;
  }

  .ox-about-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--ox-border);
  }

  .ox-about-metrics > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ox-about-metric-label {
    font-family: var(--ox-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ox-muted);
  }

  .ox-about-metric-val {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ox-about-work {
    position: relative;
    z-index: 2;
    padding: 72px 0;
    border-bottom: 1px solid var(--ox-border);
    background: #fff;
  }

  .ox-about-work-inner {
    max-width: 40rem;
  }

  .ox-about-quote {
    margin: 0 0 20px;
    padding: 0;
    border: none;
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.35;
    color: var(--ox-fg);
  }

  .ox-about-work-body {
    margin: 0;
    font-size: 15px;
    line-height: 1.75;
    color: var(--ox-muted);
  }

  .ox-about-values-section {
    position: relative;
    z-index: 2;
    padding: 80px 0;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-about-values {
    display: grid;
    gap: 16px;
  }

  @media (min-width: 640px) {
    .ox-about-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 768px) {
    .ox-about-values {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ox-about-values {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .ox-about-value {
    padding: 24px;
    border: 1px solid var(--ox-border);
    background: var(--ox-bg);
  }

  .ox-about-value-tag {
    display: block;
    font-family: var(--ox-mono);
    font-size: 11px;
    color: var(--ox-muted);
    margin-bottom: 12px;
  }

  .ox-about-value h3 {
    margin: 0 0 8px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .ox-about-value p {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-about-hw {
    position: relative;
    z-index: 2;
    padding: 72px 0;
    border-bottom: 1px solid var(--ox-border);
  }

  .ox-about-hw-head p {
    margin: 0;
    max-width: 32rem;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ox-muted);
  }

  .ox-about-hw-list {
    list-style: none;
    margin: 40px 0 0;
    padding: 0;
    border-top: 1px solid var(--ox-border);
  }

  .ox-about-hw-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    align-items: start;
    padding: 20px 0;
    border-bottom: 1px solid var(--ox-border);
    transition: background 0.15s ease;
  }

  .ox-about-hw-item:hover {
    background: rgba(8, 5, 3, 0.02);
  }

  .ox-about-hw-tag {
    font-family: var(--ox-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
