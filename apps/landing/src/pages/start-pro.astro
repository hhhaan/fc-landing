---
import { requireLogin } from "../lib/auth";
import { normalizeCheckoutPlan, polarApiBase, polarPriceId } from "../lib/polarPlans";

const userOrRedirect = await requireLogin(Astro, Astro.request.url);
if (userOrRedirect instanceof Response) return userOrRedirect;
const user = userOrRedirect;

const plan = normalizeCheckoutPlan(Astro.url.searchParams.get("plan"));
const priceId = polarPriceId(plan, import.meta.env);

if (!priceId) {
  console.error(`[Polar] price ID not configured — plan: ${plan}, sandbox: ${import.meta.env.POLAR_SERVER === "sandbox"}`);
  return Astro.redirect("/compare-plans?error=checkout_failed");
}

const ip =
  Astro.request.headers.get("cf-connecting-ip") ||
  Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim();

const res = await fetch(`${polarApiBase(import.meta.env)}/v1/checkouts/`, {
  method: "POST",
  headers: {
    Authorization: `Bearer ${import.meta.env.POLAR_ACCESS_TOKEN}`,
    "Content-Type": "application/json",
  },
  body: JSON.stringify({
    product_price_id: priceId,
    customer_email: user.email,
    metadata: { user_id: user.id, plan },
    success_url: import.meta.env.POLAR_SUCCESS_URL,
    ...(ip ? { customer_ip_address: ip } : {}),
  }),
});

if (!res.ok) {
  console.error(`[Polar] checkout creation failed (${res.status}):`, await res.text());
  return Astro.redirect("/compare-plans?error=checkout_failed");
}

let checkout: { url: string };
try {
  checkout = await res.json();
} catch {
  console.error("[Polar] invalid JSON in checkout response");
  return Astro.redirect("/compare-plans?error=checkout_failed");
}

console.log(`[Polar] ${plan} checkout created for ${user.email}`);
return Astro.redirect(checkout.url);
---