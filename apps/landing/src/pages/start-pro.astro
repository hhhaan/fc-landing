---
import { requireLogin } from "../lib/auth";

const userOrRedirect = await requireLogin(Astro, Astro.request.url);
if (userOrRedirect instanceof Response) return userOrRedirect;
const user = userOrRedirect;

const rawPlan = Astro.url.searchParams.get("plan");
const VALID_PLANS = ["monthly", "yearly", "enterprise-monthly", "enterprise-yearly"] as const;
type Plan = typeof VALID_PLANS[number];
const plan: Plan = (VALID_PLANS as readonly string[]).includes(rawPlan ?? "")
  ? (rawPlan as Plan)
  : "monthly";

const isSandbox = import.meta.env.POLAR_SERVER === "sandbox";
const apiBase = isSandbox
  ? "https://sandbox-api.polar.sh"
  : "https://api.polar.sh";

const priceIds: Record<Plan, string | undefined> = {
  monthly:              isSandbox ? import.meta.env.POLAR_PRICE_MONTHLY_SBX              : import.meta.env.POLAR_PRICE_MONTHLY_PROD,
  yearly:               isSandbox ? import.meta.env.POLAR_PRICE_YEARLY_SBX               : import.meta.env.POLAR_PRICE_YEARLY_PROD,
  "enterprise-monthly": isSandbox ? import.meta.env.POLAR_PRICE_ENTERPRISE_MONTHLY_SBX   : import.meta.env.POLAR_PRICE_ENTERPRISE_MONTHLY_PROD,
  "enterprise-yearly":  isSandbox ? import.meta.env.POLAR_PRICE_ENTERPRISE_YEARLY_SBX    : import.meta.env.POLAR_PRICE_ENTERPRISE_YEARLY_PROD,
};

const priceId = priceIds[plan];

if (!priceId) {
  console.error(`[Polar] price ID not configured — plan: ${plan}, sandbox: ${isSandbox}`);
  return Astro.redirect("/?error=checkout_failed");
}

const ip =
  Astro.request.headers.get("cf-connecting-ip") ||
  Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim();

const res = await fetch(`${apiBase}/v1/checkouts/`, {
  method: "POST",
  headers: {
    Authorization: `Bearer ${import.meta.env.POLAR_ACCESS_TOKEN}`,
    "Content-Type": "application/json",
  },
  body: JSON.stringify({
    product_price_id: priceId,
    customer_email: user.email,
    metadata: { user_id: user.id, plan },
    success_url: import.meta.env.POLAR_SUCCESS_URL,
    ...(ip ? { customer_ip_address: ip } : {}),
  }),
});

if (!res.ok) {
  console.error(`[Polar] checkout creation failed (${res.status}):`, await res.text());
  return Astro.redirect("/?error=checkout_failed");
}

let checkout: { url: string };
try {
  checkout = await res.json();
} catch {
  console.error("[Polar] invalid JSON in checkout response");
  return Astro.redirect("/?error=checkout_failed");
}

console.log(`[Polar] ${plan} checkout created for ${user.email}`);
return Astro.redirect(checkout.url);
---
