---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Desktop Engineer — First Crack Careers"
  description="Desktop Engineer at First Crack — build the macOS and Windows roasting software."
  department="Engineering"
  roleTitle="Desktop Engineer"
  location="Remote — APAC / Americas"
  applySubject="Desktop%20Engineer%20Application"
  applyNote="Send your resume and a short note about what you've built and why you want to work on coffee software."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every day. Our application connects directly to roasting machines via Modbus and Phidget, displays live temperature curves (BT, ET, RoR), and manages everything from batch history to production scheduling. We're a small, remote-first team shipping on macOS and Windows with cloud sync for teams.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Build the macOS and Windows desktop app that roasters run on the production floor. You'll work on real-time sensor data visualization, chart rendering, machine communication protocols (Modbus, Phidget), and a native UI that feels at home in an industrial setting. We ship weekly and talk to users daily — your work goes from commit to roast floor in days, not quarters.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Build and maintain the cross-platform desktop application (macOS &amp; Windows)</li>
      <li>Implement real-time data acquisition from roasting machines via Modbus, Phidget, and Artisan-compatible interfaces</li>
      <li>Design and optimize chart rendering for live temperature curves (BT, ET, RoR)</li>
      <li>Architect offline-first data persistence with cloud sync</li>
      <li>Collaborate with roasters to understand their workflow and improve the UI</li>
      <li>Write clean, tested code and participate in code reviews</li>
    </ul>
  </section>

  <section>
    <h2>Desirable Skills, Knowledge, and Experience</h2>
    <ul>
      <li>3+ years building native desktop applications</li>
      <li>Experience with C++, Rust, or Swift</li>
      <li>Familiarity with real-time data visualization or charting libraries</li>
      <li>Comfortable working with hardware protocols (serial, Modbus, or similar)</li>
      <li>Strong attention to UI detail — the roast floor is not a place for janky interfaces</li>
      <li>Interest in specialty coffee is a plus (we'll teach you roasting either way)</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive salary based on experience and location. This role is eligible for equity participation.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Remote-first — work from wherever your coffee tastes best</li>
      <li>Competitive pay &amp; meaningful equity</li>
      <li>Take-what-you-need vacation (we actually mean it)</li>
      <li>Tooling budget + AI credits stipend</li>
      <li>Coffee budget — green, roasted, brewing gear</li>
      <li>Hands-on roasting workshop for every new hire</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>