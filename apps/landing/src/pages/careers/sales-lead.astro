---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Sales Lead — First Crack Careers"
  description="Sales Lead at First Crack — bring specialty roasteries onto the platform."
  department="Sales"
  roleTitle="Sales Lead"
  location="Remote — APAC"
  applySubject="Sales%20Lead%20Application"
  applyNote="Send your resume and tell us about a deal you're proud of closing."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every day. Our application connects directly to roasting machines, displays live temperature curves, and manages everything from batch history to production scheduling. We're a small, remote-first team shipping on macOS and Windows with cloud sync for teams.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Own the sales motion for First Crack across APAC. You'll find, pitch, and close specialty roasteries — from single-machine cafés to multi-location production floors. This is not a "demo and forget" role. You'll understand each roastery's workflow, show them how First Crack fits, and build relationships that last. You're the first sales hire, so you'll also define the playbook.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Build and manage a pipeline of specialty roasteries across APAC</li>
      <li>Run discovery calls, product demos, and on-site visits</li>
      <li>Close deals — from free trials to annual enterprise contracts</li>
      <li>Define the sales playbook, pricing strategy, and outreach motion</li>
      <li>Work with the product team to relay customer feedback and feature requests</li>
      <li>Represent First Crack at coffee industry events and trade shows</li>
    </ul>
  </section>

  <section>
    <h2>Desirable Skills, Knowledge, and Experience</h2>
    <ul>
      <li>3+ years in B2B SaaS sales, ideally selling to SMBs or mid-market</li>
      <li>Track record of closing deals and building pipeline from scratch</li>
      <li>Comfortable with technical products — you can demo software and handle objections</li>
      <li>Strong network in the specialty coffee industry is a significant plus</li>
      <li>Willingness to travel across APAC for on-site visits and events</li>
      <li>Self-starter who can build a sales motion without a large team behind them</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive base salary plus uncapped commission. This role is eligible for equity participation. OTE (on-target earnings) significantly above base.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Remote-first — work from wherever your coffee tastes best</li>
      <li>Competitive pay &amp; meaningful equity</li>
      <li>Take-what-you-need vacation (we actually mean it)</li>
      <li>Tooling budget + AI credits stipend</li>
      <li>Coffee budget — green, roasted, brewing gear</li>
      <li>Hands-on roasting workshop for every new hire</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>