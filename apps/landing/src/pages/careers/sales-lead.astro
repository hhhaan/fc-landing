---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Sales Lead, Korea & Japan — First Crack Careers"
  description="Sales Lead for Korea & Japan at First Crack — own specialty roastery pipeline and close production-floor deals."
  department="Go-to-Market"
  roleTitle="Sales Lead, Korea & Japan"
  location="Seoul / Remote (KR · JP)"
  employmentType="Full-time"
  applySubject="Sales%20Lead%20Korea%20Japan%20Application"
  applyNote="Send your resume and a short note about a B2B deal you're proud of — what the buyer cared about and how you closed."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every production day. Buyers range from single-machine cafés to multi-location production floors across Korea and Japan. We're hiring the first dedicated sales lead for those markets.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Own pipeline, demos, and closes for KR and JP. You'll run discovery, show the product on real roasting workflows, and build relationships that renew. This is not spray-and-pray SDR work — you'll help define pricing, playbook, and event presence for the region. Seoul-based preferred; remote within Korea or Japan OK with regular customer travel.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Build and manage a specialty-roastery pipeline across Korea and Japan</li>
      <li>Run discovery, product demos, trials, and on-site visits</li>
      <li>Close deals from single seats to multi-site annual contracts</li>
      <li>Shape the regional playbook, outreach motion, and packaging feedback</li>
      <li>Relay floor feedback to product and solutions</li>
      <li>Represent First Crack at SCA and regional trade shows</li>
    </ul>
  </section>

  <section>
    <h2>What we're looking for</h2>
    <ul>
      <li>3+ years B2B SaaS sales (SMB or mid-market), preferably tools sold to operators</li>
      <li>Track record of building pipeline and closing without a large overlay team</li>
      <li>Comfort demoing technical products and handling buyer objections</li>
      <li>Network in specialty coffee is a significant plus</li>
      <li>Willingness to travel for demos, installs, and events</li>
      <li>Korean and/or Japanese fluency required; English for internal collab</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive base + uncapped commission. OTE meaningfully above base when at plan. Stock options for all full-time hires. Details shared in first conversation.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Base + uncapped commission + equity</li>
      <li>Four major social insurances (Korea) or JP employment-equivalent package</li>
      <li>Private health insurance for you + partner</li>
      <li>15+ days PTO, public holidays, flexible sick leave</li>
      <li>MacBook Pro + phone stipend</li>
      <li>Customer travel, trade shows, and hospitality expenses covered</li>
      <li>Green-coffee &amp; gear allowance; hands-on roasting workshop onboarding</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>
