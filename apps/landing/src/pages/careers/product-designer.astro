---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Product Designer — First Crack Careers"
  description="Product Designer at First Crack — design the interface roasters use under production pressure. Seoul hybrid."
  department="Design"
  roleTitle="Product Designer"
  location="Seoul, Korea (Hybrid)"
  employmentType="Full-time"
  applySubject="Product%20Designer%20Application"
  applyNote="Send your resume and portfolio. Highlight work that had to stay clear under real-world constraints (tools, dashboards, industrial UI)."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every production day. From live roast curves to production dashboards, the product is used under time pressure on noisy floors — design quality is a reliability feature, not decoration. HQ is in Seoul.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Design the interface roasters stare at for hours. You'll own the design system, prototype new surfaces, and visit roasteries to watch real runs. Hybrid in Seoul so you can sit next to eng and, when needed, next to a drum. This is a "usable under pressure" role, not a marketing-site-only brief.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Own and evolve the First Crack design system across desktop and web</li>
      <li>Design features from research through high-fidelity prototypes</li>
      <li>Run user research — roastery visits, production observation, interviews</li>
      <li>Partner with engineers for implementation fidelity</li>
      <li>Design data-dense UIs that remain scannable mid-batch</li>
      <li>Advocate for accessibility and industrial usability</li>
    </ul>
  </section>

  <section>
    <h2>What we're looking for</h2>
    <ul>
      <li>3+ years product design, preferably on tools, dashboards, or technical products</li>
      <li>Portfolio with complex UI (data viz, multi-step workflows, dense layouts)</li>
      <li>Strong Figma craft and prototyping</li>
      <li>Experience owning or contributing to a design system</li>
      <li>Comfort talking to users directly — you'll spend time with roasters</li>
      <li>Based in Seoul or able to relocate; Korean not required, English working fluency is</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive salary for Seoul product design bands. Stock options for all full-time hires. Annual compensation review.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Equity (stock options) + annual salary review</li>
      <li>Four major social insurances + private health insurance (you + partner)</li>
      <li>15+ days PTO, public holidays, flexible sick leave</li>
      <li>MacBook Pro + monitor; ₩500,000 home-office stipend</li>
      <li>₩2,000,000 / year learning budget; AI tooling credits covered</li>
      <li>Green-coffee &amp; gear allowance; hands-on roasting workshop onboarding</li>
      <li>Hybrid: 2–3 days/week Seoul HQ</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>
