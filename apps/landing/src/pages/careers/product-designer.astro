---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Product Designer — First Crack Careers"
  description="Product Designer at First Crack — design the interface roasters stare at for hours."
  department="Design"
  roleTitle="Product Designer"
  location="Remote — APAC / EMEA"
  applySubject="Product%20Designer%20Application"
  applyNote="Send your resume and portfolio. Show us something you designed that had to work under real-world constraints."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every day. Our application connects directly to roasting machines, displays live temperature curves, and manages everything from batch history to production scheduling. We're a small, remote-first team shipping on macOS and Windows with cloud sync for teams.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Design the interface that roasters stare at for hours during a production run. From live roast curves to production dashboards, every pixel matters when someone is making split-second decisions with 50kg of green coffee on the line. You'll own the design system, prototype new features, and work directly with roasters to understand their workflow. This is not a "make it pretty" role — it's a "make it usable under pressure" role.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Own and evolve the First Crack design system across desktop and web</li>
      <li>Design new features from research through high-fidelity prototypes</li>
      <li>Conduct user research — visit roasteries, watch production runs, understand the floor</li>
      <li>Collaborate with engineers to ensure pixel-perfect implementation</li>
      <li>Design data-dense interfaces that remain clear under time pressure</li>
      <li>Advocate for accessibility and usability in an industrial context</li>
    </ul>
  </section>

  <section>
    <h2>Desirable Skills, Knowledge, and Experience</h2>
    <ul>
      <li>3+ years of product design experience, preferably with data-heavy or technical products</li>
      <li>Strong portfolio showing complex UI work (dashboards, data viz, tools)</li>
      <li>Proficiency in Figma and prototyping tools</li>
      <li>Experience with or strong interest in design systems</li>
      <li>Comfortable talking to users directly — you'll spend time with roasters</li>
      <li>No coffee experience required, but curiosity about the craft is essential</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive salary based on experience and location. This role is eligible for equity participation.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Remote-first — work from wherever your coffee tastes best</li>
      <li>Competitive pay &amp; meaningful equity</li>
      <li>Take-what-you-need vacation (we actually mean it)</li>
      <li>Tooling budget + AI credits stipend</li>
      <li>Coffee budget — green, roasted, brewing gear</li>
      <li>Hands-on roasting workshop for every new hire</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>