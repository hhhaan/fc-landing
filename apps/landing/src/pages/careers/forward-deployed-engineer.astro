---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Forward Deployed Engineer — First Crack Careers"
  description="Forward Deployed Engineer at First Crack — embed with roasteries across APAC, ship integrations, support deals."
  department="Engineering · FDE"
  roleTitle="Forward Deployed Engineer"
  location="Seoul, Korea + APAC travel"
  employmentType="Full-time"
  applySubject="Forward%20Deployed%20Engineer%20Application"
  applyNote="Send your resume and a short story about shipping something on-site with a customer or operator."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every production day. Larger multi-site roasteries need integrations, data migration, and on-floor setup that generic self-serve can't cover. That's this role — Solutions, sitting between Engineering and Go-to-Market.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Embed with priority roasteries: understand workflows, wire custom integrations, and ship the glue that makes First Crack stick. Part engineer, part field consultant. Expect 20–40% travel across Korea, Japan, and broader APAC; home base Seoul preferred.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Embed with enterprise and multi-site customers to map workflows and pain</li>
      <li>Build integrations, scripts, and tooling that fit their operation</li>
      <li>Feed product with concrete roadmap signals from the floor</li>
      <li>Support sales with technical demos, POCs, and on-site visits</li>
      <li>Write deployment docs, onboarding guides, and runbooks for large installs</li>
      <li>Be the internal voice of production-floor reality</li>
    </ul>
  </section>

  <section>
    <h2>What we're looking for</h2>
    <ul>
      <li>3+ years in engineering, solutions engineering, or technical consulting</li>
      <li>Can write production-quality code (Python, TypeScript, or similar) under time pressure</li>
      <li>Clear communicator with operators and technical buyers</li>
      <li>Willing to travel 20–40% across APAC (travel fully covered)</li>
      <li>Hardware, IoT, or industrial software experience is a plus</li>
      <li>Seoul-based or open to relocating; Korean and/or Japanese language is a strong plus</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive salary for Seoul solutions/eng bands, plus variable compensation tied to customer outcomes. Stock options for all full-time hires.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Equity (stock options) + outcome-linked variable pay</li>
      <li>Four major social insurances + private health insurance (you + partner)</li>
      <li>15+ days PTO; travel days and recovery time treated fairly</li>
      <li>MacBook Pro + monitor; ₩500,000 home-office stipend</li>
      <li>All business travel, lodging, and customer-site expenses covered</li>
      <li>₩2,000,000 / year learning budget; AI tooling credits covered</li>
      <li>Green-coffee &amp; gear allowance; hands-on roasting workshop onboarding</li>
      <li>Hybrid when not on the road: 2–3 days/week Seoul HQ</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>
