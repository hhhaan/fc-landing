---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Full-Stack Engineer — First Crack Careers"
  description="Full-Stack Engineer at First Crack — ship across Python, Rust, and React for specialty coffee roasting software."
  department="Engineering"
  roleTitle="Full-Stack Engineer"
  location="Seoul, Korea (Hybrid) · Remote Asia OK"
  employmentType="Full-time"
  applySubject="Full-Stack%20Engineer%20Application"
  applyNote="Send your resume and a short note about something you shipped end-to-end. Links to GitHub or production work welcome."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds software that specialty coffee roasters rely on every production day — desktop clients, cloud sync, team workspaces, and analytics. HQ is in Seoul; we ship weekly with a small engineering team that owns surfaces end-to-end.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>We're hiring a full-stack engineer who can move across the stack without waiting on a handoff. Primary languages and frameworks: <strong>Python</strong>, <strong>Rust</strong>, and <strong>React</strong>. You'll work on product surfaces that touch the roast floor, the cloud, and the web — APIs, real-time data paths, UI, and the glue between them.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Ship features end-to-end across backend services, desktop/native paths, and React UIs</li>
      <li>Build and maintain APIs, data models, and sync logic (Python and related services)</li>
      <li>Contribute to performance-sensitive and systems-adjacent code in Rust where it matters</li>
      <li>Own React surfaces for product UI, internal tools, and web experiences</li>
      <li>Collaborate with design and customers; take work from commit to production weekly</li>
      <li>Improve reliability, observability, and developer velocity for a small team</li>
    </ul>
  </section>

  <section>
    <h2>What we're looking for</h2>
    <ul>
      <li>3+ years building production software across backend and frontend</li>
      <li>Strong experience in at least two of: <strong>Python</strong>, <strong>Rust</strong>, <strong>React</strong> — willingness to grow in the third</li>
      <li>Comfortable owning features without a large platform team behind you</li>
      <li>Solid fundamentals: data modeling, APIs, testing, debugging under time pressure</li>
      <li>Interest in specialty coffee or industrial/operator tools is a plus</li>
      <li>Based in Seoul (hybrid 2–3 days/week) preferred; remote across Asia (UTC+7–+10) considered</li>
    </ul>
  </section>

  <section>
    <h2>Stack (illustrative)</h2>
    <ul>
      <li><strong>Python</strong> — services, tooling, data and automation</li>
      <li><strong>Rust</strong> — performance-critical and systems-adjacent work</li>
      <li><strong>React</strong> — product UI and web surfaces (TypeScript)</li>
      <li>Postgres, Cloudflare, and modern CI/CD around the edges</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive salary by level and location. Stock options for all full-time hires. Annual compensation review.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Equity (stock options) + annual salary review</li>
      <li>Four major social insurances (Korea) or location-equivalent coverage</li>
      <li>Private health insurance for you + partner</li>
      <li>15+ days PTO, public holidays, flexible sick leave</li>
      <li>MacBook Pro + monitor; ₩500,000 home-office stipend</li>
      <li>₩2,000,000 / year learning budget; AI tooling credits covered</li>
      <li>Green-coffee &amp; gear allowance; hands-on roasting workshop onboarding</li>
      <li>Hybrid: 2–3 days/week Seoul HQ when local</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>
