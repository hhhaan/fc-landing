---
import OxJobShell from "../../components/ui/OxJobShell.astro";

const eeo = `First Crack is proud to be an equal opportunity employer. We are committed to providing equal employment opportunity for all people and place great value in both diversity and inclusiveness. All qualified applicants will be considered for employment without regard to their, or any other person's, perceived or actual race, color, religion, sex, gender, gender identity, gender expression, sexual orientation, national origin, ancestry, citizenship, age, physical or mental disability, medical condition, family care status, or any other basis protected by law.`;
---

<OxJobShell
  title="Backend Engineer — First Crack Careers"
  description="Backend Engineer at First Crack — build the cloud platform for roasting data."
  department="Engineering"
  roleTitle="Backend Engineer"
  location="Remote — APAC / EMEA"
  applySubject="Backend%20Engineer%20Application"
  applyNote="Send your resume and a short note about what you've built and why you want to work on coffee software."
>
  <section>
    <h2>About Us</h2>
    <p>First Crack builds desktop software that specialty coffee roasters rely on every day. Our application connects directly to roasting machines, displays live temperature curves, and manages everything from batch history to production scheduling. We're a small, remote-first team shipping on macOS and Windows with cloud sync for teams.</p>
  </section>

  <section>
    <h2>About the Role</h2>
    <p>Own the cloud platform that syncs roast profiles, manages teams, and powers analytics for roasteries around the world. We run on Supabase, Cloudflare, and Polar — you'll build the APIs, data pipelines, and infrastructure that keep production floors connected. This is a backend role with real impact: every roast session that a user saves flows through systems you build.</p>
  </section>

  <section>
    <h2>Responsibilities</h2>
    <ul>
      <li>Design and build RESTful APIs and real-time data sync services</li>
      <li>Architect and maintain PostgreSQL schemas, migrations, and queries</li>
      <li>Build analytics pipelines for roast data aggregation and reporting</li>
      <li>Implement webhook integrations (Polar payments, LogSnag monitoring)</li>
      <li>Set up monitoring, alerting, and incident response for production services</li>
      <li>Write internal tools and automation to keep the team shipping fast</li>
    </ul>
  </section>

  <section>
    <h2>Desirable Skills, Knowledge, and Experience</h2>
    <ul>
      <li>3+ years building backend services in production</li>
      <li>Strong SQL and data modeling skills (PostgreSQL preferred)</li>
      <li>Experience with TypeScript/Node.js or similar server-side languages</li>
      <li>Familiarity with Supabase, Cloudflare Workers, or similar serverless platforms</li>
      <li>Comfortable owning infrastructure — you deploy what you build</li>
      <li>Experience with payment systems or SaaS billing is a plus</li>
    </ul>
  </section>

  <section>
    <h2>Compensation</h2>
    <p>Competitive salary based on experience and location. This role is eligible for equity participation.</p>
  </section>

  <section>
    <h2>Benefits</h2>
    <ul>
      <li>Remote-first — work from wherever your coffee tastes best</li>
      <li>Competitive pay &amp; meaningful equity</li>
      <li>Take-what-you-need vacation (we actually mean it)</li>
      <li>Tooling budget + AI credits stipend</li>
      <li>Coffee budget — green, roasted, brewing gear</li>
      <li>Hands-on roasting workshop for every new hire</li>
    </ul>
  </section>

  <section class="ox-jd-eeo"><p>{eeo}</p></section>
</OxJobShell>